{%- comment -%}
  Product Carousel — horizontal scrolling collection showcase
  Supports up to 8 products. Style: Montblanc-inspired minimal horizontal scroll.
{%- endcomment -%}

{%- liquid
  assign products = ''
  assign slots = '1,2,3,4,5,6,7,8' | split: ','
  assign any = false
  for s in slots
    assign key = 'product_' | append: s
    assign p = section.settings[key]
    if p != blank
      assign any = true
    endif
  endfor
-%}

{%- if any -%}
<div class="pc-section">
  <div class="pc-header">
    {%- if section.settings.heading != blank -%}
      <h2 class="pc-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>
  <div class="pc-track-wrap">
    <div class="pc-track" id="pc-track-{{ section.id }}">
      {%- for s in slots -%}
        {%- assign key = 'product_' | append: s -%}
        {%- assign p = section.settings[key] -%}
        {%- if p != blank -%}
          {%- assign img = p.featured_media.preview_image -%}
          {%- assign img2 = p.media[1].preview_image -%}
          <a href="{{ p.url }}" class="pc-card" aria-label="{{ p.title | escape }}">
            <div class="pc-card-image">
              {%- if img != blank -%}
                <img src="{{ img | image_url: width: 600 }}"
                     alt="{{ img.alt | default: p.title | escape }}"
                     width="{{ img.width }}" height="{{ img.height }}"
                     loading="lazy" class="pc-img-primary">
                {%- if img2 != blank -%}
                  <img src="{{ img2 | image_url: width: 600 }}"
                       alt="{{ img2.alt | default: p.title | escape }}"
                       width="{{ img2.width }}" height="{{ img2.height }}"
                       loading="lazy" class="pc-img-secondary">
                {%- endif -%}
              {%- else -%}
                <div class="pc-placeholder"></div>
              {%- endif -%}
            </div>
            <div class="pc-card-info">
              <p class="pc-card-title">{{ p.title }}</p>
              <p class="pc-card-price">
                {%- if p.compare_at_price > p.price -%}
                  <s class="pc-compare-price">{{ p.compare_at_price | money }}</s>
                {%- endif -%}
                {{ p.price | money }}
              </p>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}

<style>
  .pc-section {
    padding: 4rem 0;
    background: #fff;
    overflow: hidden;
  }
  .pc-header {
    padding: 0 2rem;
    max-width: 1400px;
    margin: 0 auto 0;
    text-align: center;
  }
  .pc-heading {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    text-align: center;
    color: var(--color-text);
    margin: 0 0 2rem;
  }
  .pc-track-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 2rem 1rem;
    cursor: grab;
  }
  .pc-track-wrap::-webkit-scrollbar { display: none; }
  .pc-track-wrap.is-dragging { cursor: grabbing; }
  .pc-track {
    display: flex;
    gap: 1.25rem;
    width: max-content;
  }
  .pc-card {
    display: block;
    text-decoration: none;
    color: inherit;
    width: 160px;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .pc-card { width: 180px; }
    .pc-header { padding-left: 3rem; }
    .pc-track-wrap { padding: 0 3rem 1rem; }
  }
  @media (min-width: 1200px) {
    .pc-card { width: 200px; }
  }
  .pc-card-image {
    position: relative;
    aspect-ratio: 1/1;
    background: #ffffff;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .pc-card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.5s ease, opacity 0.3s ease;
  }
  .pc-img-secondary {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  .pc-card:hover .pc-img-primary { opacity: 0; }
  .pc-card:hover .pc-img-secondary { opacity: 1; }
  .pc-card:hover .pc-card-image img { transform: scale(1.04); }
  .pc-placeholder {
    width: 100%;
    height: 100%;
    background: #e8e8e8;
  }
  .pc-card-info { padding: 0 0.1rem; }
  .pc-card-title {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }
  .pc-card-price {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-text);
    margin: 0;
  }
  .pc-compare-price {
    opacity: 0.45;
    margin-right: 0.35rem;
  }
</style>

<script>
  (function(){
    var wrap = document.getElementById('pc-track-{{ section.id }}');
    if (!wrap) return;
    var isDown = false, startX, scrollLeft;
    wrap.parentElement.addEventListener('mousedown', function(e){
      isDown = true;
      wrap.parentElement.classList.add('is-dragging');
      startX = e.pageX - wrap.parentElement.offsetLeft;
      scrollLeft = wrap.parentElement.scrollLeft;
    });
    document.addEventListener('mouseup', function(){
      isDown = false;
      wrap.parentElement.classList.remove('is-dragging');
    });
    wrap.parentElement.addEventListener('mousemove', function(e){
      if (!isDown) return;
      e.preventDefault();
      var x = e.pageX - wrap.parentElement.offsetLeft;
      wrap.parentElement.scrollLeft = scrollLeft - (x - startX);
    });
  })();
</script>

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the Collection"
    },
    { "type": "product", "id": "product_1", "label": "Product 1" },
    { "type": "product", "id": "product_2", "label": "Product 2" },
    { "type": "product", "id": "product_3", "label": "Product 3" },
    { "type": "product", "id": "product_4", "label": "Product 4" },
    { "type": "product", "id": "product_5", "label": "Product 5" },
    { "type": "product", "id": "product_6", "label": "Product 6" },
    { "type": "product", "id": "product_7", "label": "Product 7" },
    { "type": "product", "id": "product_8", "label": "Product 8" }
  ],
  "presets": [
    {
      "name": "Product Carousel"
    }
  ]
}
{% endschema %}
