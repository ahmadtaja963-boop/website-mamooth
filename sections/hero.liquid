
{%- comment -%} Hero — necked. {%- endcomment -%}
<section style="position:relative;min-height:90vh;display:flex;align-items:flex-end;overflow:hidden;background:#E8DCC6;">

  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.image.alt | default: 'necked.' }}"
      loading="eager"
      fetchpriority="high"
      width="2000" height="1200"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
    >
  {%- else -%}
    <div style="position:absolute;inset:0;background:#D9C7AC;display:flex;align-items:center;justify-content:center;">
      <span style="font-family:'Montserrat',sans-serif;font-size:0.75rem;letter-spacing:0.25em;color:#9A7E62;text-transform:uppercase;">Add hero image in Shopify theme editor</span>
    </div>
  {%- endif -%}

  <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(42,29,20,0.55) 0%,rgba(42,29,20,0.08) 55%,transparent 100%);"></div>

  <div style="position:relative;z-index:2;padding:clamp(3rem,6vw,5rem) clamp(1.5rem,5vw,4rem);max-width:680px;">
    {%- if section.settings.eyebrow != blank -%}
      <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.35em;text-transform:uppercase;color:rgba(244,236,223,0.7);margin:0 0 1.25rem;">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 style="font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:clamp(2.8rem,6vw,5.5rem);font-weight:400;color:#F4ECDF;line-height:1.05;margin:0 0 1.5rem;letter-spacing:-0.01em;">{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p style="font-family:'Montserrat',sans-serif;font-size:0.875rem;line-height:1.8;color:rgba(244,236,223,0.8);max-width:420px;margin:0 0 2.5rem;font-weight:300;letter-spacing:0.02em;">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_url | default: '/collections/all' }}"
        style="display:inline-block;font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.25em;text-transform:uppercase;text-decoration:none;padding:1rem 2.5rem;background:#F4ECDF;color:#2A1D14;border:1px solid #F4ECDF;"
      >{{ section.settings.button_label }} &rarr;</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pretty posture for the screen era." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tech neck, but make it cute." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Passive neck and posture care for screen-era girls who want to look longer, smoother, and more put-together." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "SHOP NOW" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
