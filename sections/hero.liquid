<section class="hero">
  {%- if section.settings.image != blank -%}
    <img
      class="hero-image"
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- else -%}
    <img
      class="hero-image"
      src="{{ 'hero-leather.jpg' | asset_url }}"
      alt="{{ section.settings.heading | escape }}"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="1080"
    >
  {%- endif -%}

  <div class="hero-overlay"></div>

  <div class="hero-content">
    <div class="hero-text">
      <h1>{{ section.settings.heading }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <button
          class="btn btn-white btn-lg"
          data-scroll-to="products"
        >
          {{ section.settings.button_label }}
        </button>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Timeless Craftsmanship"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover the art of exceptional leather goods, handcrafted with meticulous attention to detail"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore Collection"
    }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
