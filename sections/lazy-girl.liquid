{%- comment -%} Lazy Girl — two 2:1 landscape tiles, edge to edge {%- endcomment -%}
<section style="display:grid;grid-template-columns:1fr 1fr;overflow:hidden;">
  <div style="position:relative;overflow:hidden;aspect-ratio:2/1;">
    {%- if section.settings.main_image != blank -%}
      <img src="{{ section.settings.main_image | image_url: width: 1400 }}" alt="{{ section.settings.heading | escape }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" loading="lazy">
    {%- else -%}
      <img src="{{ 'lazy-girl-locked-in.jpeg' | asset_url }}" alt="{{ section.settings.heading | escape }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" loading="lazy">
    {%- endif -%}
    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(42,29,20,0.7) 0%,rgba(42,29,20,0.15) 55%,transparent 100%);"></div>
    <div style="position:relative;z-index:1;height:100%;display:flex;flex-direction:column;justify-content:flex-end;padding:clamp(1rem,2.5vw,2rem);">
      <h2 style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.25rem,3vw,2.25rem);font-weight:400;color:#F4ECDF;line-height:1.05;margin:0 0 0.4rem;">{{ section.settings.heading }}</h2>
      <p style="font-family:'Montserrat',sans-serif;font-size:0.7rem;color:#E8DCC6;margin:0 0 0.75rem;line-height:1.7;letter-spacing:0.05em;">{{ section.settings.body | newline_to_br }}</p>
      <a href="{{ section.settings.journal_url | default: '/blogs/journal' }}" style="font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.28em;text-transform:uppercase;color:#F4ECDF;text-decoration:none;">{{ section.settings.journal_label | default: 'Our Journal' }} &rarr;</a>
    </div>
  </div>
  <div style="position:relative;overflow:hidden;aspect-ratio:2/1;">
    {%- if section.settings.tile1 != blank -%}
      <img src="{{ section.settings.tile1 | image_url: width: 1400 }}" alt="necked. products" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" loading="lazy">
    {%- else -%}
      <img src="{{ 'lazy-girl-right.jpeg' | asset_url }}" alt="necked. products" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center center;" loading="lazy">
    {%- endif -%}
  </div>
</section>
{% schema %}
{ "name": "Lazy Girl", "tag": "div", "settings": [
  { "type": "text", "id": "heading", "label": "Heading", "default": "Lazy Girl, Locked In." },
  { "type": "textarea", "id": "body", "label": "Body text", "default": "Low effort.\nHigh impact." },
  { "type": "text", "id": "journal_label", "label": "Link label", "default": "Our Journal" },
  { "type": "url", "id": "journal_url", "label": "Link URL" },
  { "type": "image_picker", "id": "main_image", "label": "Left panel — lifestyle photo" },
  { "type": "image_picker", "id": "tile1", "label": "Right panel — product flatlay" },
  { "type": "image_picker", "id": "tile2", "label": "Extra image 2 (unused)" },
  { "type": "image_picker", "id": "tile3", "label": "Extra image 3 (unused)" }
], "presets": [{ "name": "Lazy Girl" }] }
{% endschema %}
