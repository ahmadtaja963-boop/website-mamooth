<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-grid">

      {%- comment -%} Newsletter {%- endcomment -%}
      <div class="footer-newsletter">
        <h3>{{ 'footer.newsletter.heading' | t }}</h3>
        <p>{{ 'footer.newsletter.body' | t }}</p>
        {%- form 'customer', id: 'FooterNewsletter' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer-newsletter-form">
            <input
              type="email"
              name="contact[email]"
              id="NewsletterEmail"
              placeholder="{{ 'newsletter.placeholder' | t }}"
              aria-label="{{ 'newsletter.label' | t }}"
              autocomplete="email"
              required
            >
            <button type="submit" class="btn btn-white btn-sm">
              {{ 'newsletter.submit' | t }}
            </button>
          </div>
          {%- if form.posted_successfully? -%}
            <p style="color:rgba(255,255,255,0.7);font-size:.875rem;margin-top:.5rem;">
              {{ 'newsletter.success' | t }}
            </p>
          {%- endif -%}
        {%- endform -%}
      </div>

      {%- comment -%} Support {%- endcomment -%}
      <div class="footer-col">
        <h4>{{ 'footer.support.heading' | t }}</h4>
        <ul>
          <li><a href="/pages/contact">{{ 'footer.support.contact' | t }}</a></li>
          <li><a href="/pages/shipping">{{ 'footer.support.shipping' | t }}</a></li>
          <li><a href="/pages/returns">{{ 'footer.support.returns' | t }}</a></li>
          <li><a href="/pages/faq">{{ 'footer.support.faq' | t }}</a></li>
        </ul>
      </div>

      {%- comment -%} Company {%- endcomment -%}
      <div class="footer-col">
        <h4>{{ 'footer.company.heading' | t }}</h4>
        <ul>
          <li><a href="/pages/about">{{ 'footer.company.about' | t }}</a></li>
          <li><a href="/pages/terms">{{ 'footer.company.terms' | t }}</a></li>
          <li><a href="/pages/privacy">{{ 'footer.company.privacy' | t }}</a></li>
        </ul>
      </div>

    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="footer-bottom">
      <div class="footer-social">
        <span>{{ 'footer.social.heading' | t }}</span>
        <div class="footer-social-links">
          <a href="#" class="footer-social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="footer-social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
          </a>
        </div>
      </div>

      {%- render 'country-language-selector' -%}

      <div class="footer-copyright">
        <p>&copy; {{ 'now' | date: '%Y' }} the pretty fix. {{ 'footer.copyright.rights' | t }}</p>
        <p>{{ 'footer.copyright.tagline' | t }}</p>
      </div>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "footer-wrapper"
}
{% endschema %}
