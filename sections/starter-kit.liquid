{%- comment -%} Starter Kit — top bar + 4-product horizontal row {%- endcomment -%}
<section style="background:#E8DCC6;padding:2.5rem 0 4rem;">
  <div style="max-width:1400px;margin:0 auto;padding:0 clamp(1.5rem,4vw,4rem);">

    <div style="display:flex;align-items:flex-end;justify-content:space-between;padding-bottom:1.25rem;border-bottom:1px solid rgba(42,29,20,0.2);margin-bottom:3rem;">
      <div>
        <p style="margin:0 0 0.35rem;font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:#2A1D14;">{{ section.settings.eyebrow }}</p>
        <p style="margin:0;font-family:'Playfair Display',Georgia,serif;font-size:1.5rem;color:#2A1D14;line-height:1;">{{ section.settings.price }}</p>
      </div>
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;color:#2A1D14;text-decoration:none;white-space:nowrap;">{{ section.settings.cta_label }} &rarr;</a>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:clamp(1rem,2vw,2rem);">

      <div style="text-align:center;">
        <div style="width:100%;aspect-ratio:3/4;background:#D9C7AC;overflow:hidden;margin-bottom:1rem;">
          {%- if section.settings.image1 != blank -%}
            <img src="{{ section.settings.image1 | image_url: width: 600 }}" alt="{{ section.settings.label1 | escape }}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
          {%- endif -%}
        </div>
        <p style="margin:0 0 0.25rem;font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:#2A1D14;">{{ section.settings.label1 }}</p>
        {%- if section.settings.sub1 != blank -%}<p style="margin:0;font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.08em;color:#9A7E62;">{{ section.settings.sub1 }}</p>{%- endif -%}
      </div>

      <div style="text-align:center;">
        <div style="width:100%;aspect-ratio:3/4;background:#D9C7AC;overflow:hidden;margin-bottom:1rem;">
          {%- if section.settings.image2 != blank -%}
            <img src="{{ section.settings.image2 | image_url: width: 600 }}" alt="{{ section.settings.label2 | escape }}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
          {%- endif -%}
        </div>
        <p style="margin:0 0 0.25rem;font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:#2A1D14;">{{ section.settings.label2 }}</p>
        {%- if section.settings.sub2 != blank -%}<p style="margin:0;font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.08em;color:#9A7E62;">{{ section.settings.sub2 }}</p>{%- endif -%}
      </div>

      <div style="text-align:center;">
        <div style="width:100%;aspect-ratio:3/4;background:#D9C7AC;overflow:hidden;margin-bottom:1rem;">
          {%- if section.settings.image3 != blank -%}
            <img src="{{ section.settings.image3 | image_url: width: 600 }}" alt="{{ section.settings.label3 | escape }}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
          {%- endif -%}
        </div>
        <p style="margin:0 0 0.25rem;font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:#2A1D14;">{{ section.settings.label3 }}</p>
        {%- if section.settings.sub3 != blank -%}<p style="margin:0;font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.08em;color:#9A7E62;">{{ section.settings.sub3 }}</p>{%- endif -%}
      </div>

      <div style="text-align:center;">
        <div style="width:100%;aspect-ratio:3/4;background:#D9C7AC;overflow:hidden;margin-bottom:1rem;">
          {%- if section.settings.image4 != blank -%}
            <img src="{{ section.settings.image4 | image_url: width: 600 }}" alt="{{ section.settings.label4 | escape }}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
          {%- endif -%}
        </div>
        <p style="margin:0 0 0.25rem;font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:#2A1D14;">{{ section.settings.label4 }}</p>
        {%- if section.settings.sub4 != blank -%}<p style="margin:0;font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.08em;color:#9A7E62;">{{ section.settings.sub4 }}</p>{%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Starter Kit",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow / set name", "default": "The Screen Body Set." },
    { "type": "text", "id": "price", "label": "Price", "default": "$125" },
    { "type": "text", "id": "price_was", "label": "Compare-at price" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Add to Cart" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "image_picker", "id": "image1", "label": "Product image 1" },
    { "type": "text", "id": "label1", "label": "Product name 1", "default": "Neck Cream" },
    { "type": "text", "id": "sub1", "label": "Subtitle 1", "default": "Lift + Smooth" },
    { "type": "image_picker", "id": "image2", "label": "Product image 2" },
    { "type": "text", "id": "label2", "label": "Product name 2", "default": "Posture Bra" },
    { "type": "text", "id": "sub2", "label": "Subtitle 2", "default": "Firm + Define" },
    { "type": "image_picker", "id": "image3", "label": "Product image 3" },
    { "type": "text", "id": "label3", "label": "Product name 3", "default": "Shapewear Suit" },
    { "type": "text", "id": "sub3", "label": "Subtitle 3", "default": "Sculpt + Support" },
    { "type": "image_picker", "id": "image4", "label": "Product image 4" },
    { "type": "text", "id": "label4", "label": "Product name 4", "default": "Sleep Pillow" },
    { "type": "text", "id": "sub4", "label": "Subtitle 4", "default": "Align + Rest" }
  ],
  "presets": [{ "name": "Starter Kit" }]
}
{% endschema %}