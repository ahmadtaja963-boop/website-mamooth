{%- comment -%} Starter Kit — 4 products, no side columns, no borders {%- endcomment -%}
<section style="background:#E8DCC6;padding:clamp(2rem,4vw,3.5rem) clamp(2rem,5vw,4rem);">
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:clamp(1rem,2.5vw,2rem);">

    <div style="display:flex;flex-direction:column;align-items:center;">
      <div style="width:100%;aspect-ratio:3/4;overflow:hidden;background:#F4ECDF;">
        {%- if section.settings.image1 != blank -%}
          <img src="{{ section.settings.image1 | image_url: width: 700 }}" alt="{{ section.settings.label1 | escape }}" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">
        {%- else -%}
          <div style="width:100%;height:100%;background:#D9C7AC;"></div>
        {%- endif -%}
      </div>
      <p style="margin:0.75rem 0 0.2rem;font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#2A1D14;text-align:center;">{{ section.settings.label1 }}</p>
      {%- if section.settings.sub1 != blank -%}<p style="margin:0;font-family:'Montserrat',sans-serif;font-size:0.48rem;color:#9A7E62;text-align:center;">{{ section.settings.sub1 }}</p>{%- endif -%}
    </div>

    <div style="display:flex;flex-direction:column;align-items:center;">
      <div style="width:100%;aspect-ratio:3/4;overflow:hidden;background:#F4ECDF;">
        {%- if section.settings.image2 != blank -%}
          <img src="{{ section.settings.image2 | image_url: width: 700 }}" alt="{{ section.settings.label2 | escape }}" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">
        {%- else -%}
          <div style="width:100%;height:100%;background:#D9C7AC;"></div>
        {%- endif -%}
      </div>
      <p style="margin:0.75rem 0 0.2rem;font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#2A1D14;text-align:center;">{{ section.settings.label2 }}</p>
      {%- if section.settings.sub2 != blank -%}<p style="margin:0;font-family:'Montserrat',sans-serif;font-size:0.48rem;color:#9A7E62;text-align:center;">{{ section.settings.sub2 }}</p>{%- endif -%}
    </div>

    <div style="display:flex;flex-direction:column;align-items:center;">
      <div style="width:100%;aspect-ratio:3/4;overflow:hidden;background:#F4ECDF;">
        {%- if section.settings.image3 != blank -%}
          <img src="{{ section.settings.image3 | image_url: width: 700 }}" alt="{{ section.settings.label3 | escape }}" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">
        {%- else -%}
          <div style="width:100%;height:100%;background:#D9C7AC;"></div>
        {%- endif -%}
      </div>
      <p style="margin:0.75rem 0 0.2rem;font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#2A1D14;text-align:center;">{{ section.settings.label3 }}</p>
      {%- if section.settings.sub3 != blank -%}<p style="margin:0;font-family:'Montserrat',sans-serif;font-size:0.48rem;color:#9A7E62;text-align:center;">{{ section.settings.sub3 }}</p>{%- endif -%}
    </div>

    <div style="display:flex;flex-direction:column;align-items:center;">
      <div style="width:100%;aspect-ratio:3/4;overflow:hidden;background:#F4ECDF;">
        {%- if section.settings.image4 != blank -%}
          <img src="{{ section.settings.image4 | image_url: width: 700 }}" alt="{{ section.settings.label4 | escape }}" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">
        {%- else -%}
          <div style="width:100%;height:100%;background:#D9C7AC;"></div>
        {%- endif -%}
      </div>
      <p style="margin:0.75rem 0 0.2rem;font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#2A1D14;text-align:center;">{{ section.settings.label4 }}</p>
      {%- if section.settings.sub4 != blank -%}<p style="margin:0;font-family:'Montserrat',sans-serif;font-size:0.48rem;color:#9A7E62;text-align:center;">{{ section.settings.sub4 }}</p>{%- endif -%}
    </div>

  </div>
</section>
{% schema %}
{ "name": "Starter Kit", "tag": "div", "settings": [
  { "type": "image_picker", "id": "image1", "label": "Product 1 image" },
  { "type": "text", "id": "label1", "label": "Product 1 name", "default": "Neck Cream" },
  { "type": "text", "id": "sub1", "label": "Product 1 subtitle", "default": "Lift + Smooth" },
  { "type": "image_picker", "id": "image2", "label": "Product 2 image" },
  { "type": "text", "id": "label2", "label": "Product 2 name", "default": "Posture Bra" },
  { "type": "text", "id": "sub2", "label": "Product 2 subtitle", "default": "Firm + Define" },
  { "type": "image_picker", "id": "image3", "label": "Product 3 image" },
  { "type": "text", "id": "label3", "label": "Product 3 name", "default": "Shapewear Suit" },
  { "type": "text", "id": "sub3", "label": "Product 3 subtitle", "default": "Sculpt + Support" },
  { "type": "image_picker", "id": "image4", "label": "Product 4 image" },
  { "type": "text", "id": "label4", "label": "Product 4 name", "default": "Sleep Pillow" },
  { "type": "text", "id": "sub4", "label": "Product 4 subtitle", "default": "Align + Rest" }
], "presets": [{ "name": "Starter Kit" }] }
{% endschema %}
