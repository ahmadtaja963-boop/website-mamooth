<section class="top-picks">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="products-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' -%}
            {%- assign picked = block.settings.product -%}
            {%- if picked != blank -%}
              {%- render 'product-card', product: picked, show_badge: true -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign show_count = section.settings.products_to_show | default: 20 -%}
        {%- if section.settings.collection != blank -%}
          {%- assign source_collection = collections[section.settings.collection.handle] -%}
        {%- elsif section.settings.collection_handle != blank -%}
          {%- assign source_collection = collections[section.settings.collection_handle] -%}
        {%- endif -%}
        {%- if source_collection != blank -%}
          {%- for product in source_collection.products limit: show_count -%}
            {%- render 'product-card', product: product, show_badge: true -%}
          {%- endfor -%}
        {%- else -%}
          {%- for product in collections.all.products limit: show_count -%}
            {%- render 'product-card', product: product, show_badge: true -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div style="text-align:center;margin-top:3rem;">
        <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn-outline">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Top Picks",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top Picks"
    },
    {
      "type": "header",
      "content": "Fallback (used only if no products added below)"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "collection_handle",
      "label": "Or enter collection handle"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 20,
      "step": 2,
      "default": 10,
      "label": "Products to show (fallback only)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "View all button label",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "View all button link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Top Picks" }
  ]
}
{% endschema %}
