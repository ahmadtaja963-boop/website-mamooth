<script>
/* ── Upsell map for cart drawer ── */
window.DiazUpsellMap = window.DiazUpsellMap || {};
window.DiazUpsellMap[{{ product.handle | json }}] = [
  {%- if section.settings.upsell_product != blank -%}{{ section.settings.upsell_product.handle | json }}{%- endif -%}
  {%- if section.settings.upsell_product_2 != blank -%}{%- if section.settings.upsell_product != blank -%},{%- endif -%}{{ section.settings.upsell_product_2.handle | json }}{%- endif -%}
];

(function () {
  var form       = document.getElementById('ProductForm');
  var mainImg    = document.getElementById('ProductMainImage');
  var thumbWrap  = document.getElementById('ProductThumbnails');
  var priceEl    = document.getElementById('ProductPrice');
  if (!form) return;

  /* ── Variant data ── */
  var variants     = JSON.parse(form.dataset.variants || '[]');
  var variantImgs  = {};
  try {
    variantImgs = JSON.parse(document.getElementById('ProductVariantImages').textContent);
  } catch(e) {}

  /* ── Gallery helpers ── */
  function getAllThumbs() {
    return thumbWrap ? Array.from(thumbWrap.querySelectorAll('.product-thumbnail')) : [];
  }

  function setMainImage(src, alt) {
    if (mainImg && src) {
      mainImg.src = src;
      if (alt) mainImg.alt = alt;
    }
  }

  function setActiveThumb(index) {
    getAllThumbs().forEach(function(t, i) { t.classList.toggle('active', i === index); });
  }

  /* ── Color-based gallery filter ── */
  function filterGalleryByColor(colorValue) {
    if (!thumbWrap) return;
    var color  = colorValue.toLowerCase().trim();
    var thumbs = getAllThumbs();
    var matches = [];

    thumbs.forEach(function(thumb) {
      var thumbColor = (thumb.dataset.color || '').toLowerCase();
      /* match if alt is empty (generic image) OR contains the selected color */
      var isMatch = thumbColor === '' || thumbColor.includes(color) || (color.includes(thumbColor) && thumbColor !== '');
      thumb.style.display = isMatch ? '' : 'none';
      if (isMatch) {
        /* lazy-load the thumbnail src if not yet loaded */
        var img = thumb.querySelector('img');
        if (img && img.dataset.thumbSrc && !img.src) {
          img.src = img.dataset.thumbSrc;
        }
        matches.push(thumb);
      }
    });

    /* If no images matched (alt texts not set up) — show all */
    if (matches.length === 0) {
      thumbs.forEach(function(t) { t.style.display = ''; });
      matches = thumbs;
    }

    /* Jump to first matching image */
    if (matches.length > 0) {
      var firstIdx = parseInt(matches[0].dataset.index || '0', 10);
      setActiveThumb(firstIdx);
      setMainImage(matches[0].dataset.src);
    }
  }

  /* ── Funnel color filter ── */
  var funnel = document.getElementById('ProductFunnel');
  var funnelSlides = funnel ? funnel.querySelectorAll('.product-funnel__slide') : [];

  function filterFunnelByColor(colorValue) {
    if (!funnelSlides.length) return;
    var color = (colorValue || '').toLowerCase().trim();
    var hasMatch = false;

    funnelSlides.forEach(function(slide) {
      var slideColor = (slide.dataset.funnelColor || '').toLowerCase().trim();
      if (slideColor === color) hasMatch = true;
    });

    funnelSlides.forEach(function(slide) {
      var slideColor = (slide.dataset.funnelColor || '').toLowerCase().trim();
      if (!hasMatch || slideColor === '' || slideColor === color) {
        slide.style.display = '';
      } else {
        slide.style.display = 'none';
      }
    });
  }

  /* Initial funnel filter based on active color */
  var initColorBtn = document.querySelector('.option-btn--color.active');
  if (initColorBtn) filterFunnelByColor(initColorBtn.dataset.value);

  /* ── Offer Selector (radio cards) ── */
  function fmtMoney(cents) { return '$' + (cents / 100).toFixed(2); }

  var offerSelector = document.getElementById('OfferSelector');
  if (offerSelector) {
    var priceEl = document.getElementById('ProductPrice');
    var offerCards = offerSelector.querySelectorAll('.offer-card');
    var offerIsTierMode = offerSelector.dataset.mode === 'tiers';
    var offerActiveTier = 2;

    function updateOfferPriceDisplay(tier) {
      if (!priceEl) return;
      if (offerIsTierMode) {
        var p = offerSelector.dataset['tier' + tier + 'Price'] || '';
        var c = offerSelector.dataset['tier' + tier + 'Compare'] || '';
        var html = '<span class="product-price-current">$' + p + '</span>';
        if (c) {
          html += ' <s class="product-price-compare">$' + c + '</s>';
          var savings = (parseFloat(c) - parseFloat(p)).toFixed(2);
          if (parseFloat(savings) > 0) html += ' <span class="product-price-badge">Save $' + savings + '</span>';
        }
        priceEl.innerHTML = html;
      }
    }

    offerCards.forEach(function(card) {
      card.addEventListener('click', function(e) {
        if (e.target.tagName === 'SELECT') return; /* don't toggle on select click */
        offerCards.forEach(function(c) {
          c.classList.remove('offer-card--selected');
          c.querySelector('.offer-card__radio').classList.remove('offer-card__radio--checked');
          var v = c.querySelector('.bogo-card__variants');
          if (v) v.classList.add('bogo-card__variants--hidden');
          var it = c.querySelector('.offer-card__items');
          if (it) it.classList.add('bogo-card__variants--hidden');
        });
        card.classList.add('offer-card--selected');
        card.querySelector('.offer-card__radio').classList.add('offer-card__radio--checked');
        var activeVariants = card.querySelector('.bogo-card__variants');
        if (activeVariants) activeVariants.classList.remove('bogo-card__variants--hidden');
        var activeItems = card.querySelector('.offer-card__items');
        if (activeItems) activeItems.classList.remove('bogo-card__variants--hidden');

        if (offerIsTierMode) {
          offerActiveTier = parseInt(card.dataset.tier, 10);
          updateOfferPriceDisplay(offerActiveTier);
          return;
        }

        /* --- Legacy 2-variant mode --- */
        var vid = card.dataset.variantId;
        form.querySelector('[name="id"]').value = vid;
        if (priceEl && variantImgs[vid]) {
          var matchedVariant = variants.find(function(v) { return String(v.id) === vid; });
          var price = matchedVariant ? matchedVariant.price : variantImgs[vid].price;
          var html = '<span class="product-price-current">' + fmtMoney(price) + '</span>';
          if (matchedVariant && matchedVariant.compare_at_price > matchedVariant.price) {
            var savings = matchedVariant.compare_at_price - matchedVariant.price;
            html += ' <s class="product-price-compare">' + fmtMoney(matchedVariant.compare_at_price) + '</s>';
            html += ' <span class="product-price-badge">Save ' + fmtMoney(savings) + '</span>';
          }
          priceEl.innerHTML = html;
        }
        var addBtn = form.querySelector('.product-atc-btn');
        if (addBtn && variantImgs[vid]) {
          addBtn.disabled = !variantImgs[vid].available;
          addBtn.textContent = variantImgs[vid].available ? 'Claim My Offer' : 'Sold Out';
          addBtn.dataset.variantId = vid;
        }
        if (variantImgs[vid] && variantImgs[vid].image_src && variantImgs[vid].image_src !== 'null') {
          setMainImage(variantImgs[vid].image_src);
        }
      });
    });

    /* Tier-mode: override submit to collect variants + qty + apply discount code */
    if (offerIsTierMode) {
      updateOfferPriceDisplay(offerActiveTier);

      function findOfferVariantByOptions(optionValues) {
        return variants.find(function(v) {
          if (!v.options || v.options.length !== optionValues.length) return false;
          for (var i = 0; i < v.options.length; i++) {
            if ((v.options[i] || '').toLowerCase() !== (optionValues[i] || '').toLowerCase()) return false;
          }
          return true;
        });
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var activeCard = offerSelector.querySelector('.offer-card--selected');
        if (!activeCard) return;
        var tier = parseInt(activeCard.dataset.tier, 10);
        var tierQty = parseInt(offerSelector.dataset['tier' + tier + 'Qty'] || '1', 10);
        var code = offerSelector.dataset['tier' + tier + 'Code'] || '';
        var btn = form.querySelector('.product-atc-btn');
        btn.disabled = true;
        var origText = btn.textContent;
        btn.textContent = 'Adding...';

        /* Collect items from variant selects inside the active card */
        var items = [];
        var itemRows = activeCard.querySelectorAll('.bogo-card__variant-item');
        if (itemRows.length > 0) {
          var comboCounts = {};
          var comboValues = {};
          itemRows.forEach(function(row) {
            var selects = row.querySelectorAll('.bogo-card__option-select');
            var vals = [];
            selects.forEach(function(sel) {
              var idx = parseInt(sel.dataset.optionIndex || '0', 10);
              vals[idx] = sel.value;
            });
            var key = vals.join('|');
            comboCounts[key] = (comboCounts[key] || 0) + 1;
            comboValues[key] = vals;
          });
          Object.keys(comboCounts).forEach(function(key) {
            var matched = findOfferVariantByOptions(comboValues[key]);
            if (matched) items.push({ id: matched.id, quantity: comboCounts[key] });
          });
        } else {
          var variantId = form.querySelector('[name="id"]').value;
          items.push({ id: parseInt(variantId, 10), quantity: tierQty });
        }
        if (items.length === 0) { btn.disabled = false; btn.textContent = origText; return; }

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: items })
        })
        .then(function(r) { if (!r.ok) throw new Error('add failed'); return r.json(); })
        .then(function() {
          if (code) return fetch('/discount/' + encodeURIComponent(code), { redirect: 'manual' }).catch(function(){});
        })
        .then(function() {
          btn.disabled = false; btn.textContent = origText;
          if (window.MammothTheme) {
            var p = window.MammothTheme.fetchCart ? window.MammothTheme.fetchCart() : Promise.resolve();
            p.then(function() { if (window.MammothTheme.openCart) window.MammothTheme.openCart(); });
          } else {
            document.dispatchEvent(new CustomEvent('cart:updated'));
          }
        })
        .catch(function(err) {
          btn.disabled = false; btn.textContent = origText;
          console.error('Tier add error:', err);
        });
      });

      /* Color swatch support for tier-mode selects */
      var offerColorMapEl = document.getElementById('OfferVariantColorMap');
      var offerOptsMapEl = document.getElementById('OfferOptionsMap');
      if (offerColorMapEl && offerOptsMapEl) {
        var offerColorMap = JSON.parse(offerColorMapEl.textContent);
        var offerOptsMap = JSON.parse(offerOptsMapEl.textContent);
        var fallbackHex = { gold: '#C4944C', silver: '#C0C0C0', black: '#1A1A1A', white: '#F5F5F5', nude: '#E4B590', beige: '#E4B590', rose: '#B76E79', 'rose gold': '#B76E79' };

        function updateOfferSwatch(sel) {
          var idx = parseInt(sel.dataset.optionIndex || '-1', 10);
          if (idx !== offerOptsMap.colorIndex) return;
          var color = sel.value.toLowerCase().trim();
          var item = sel.closest('.bogo-card__variant-item');
          var swatch = item ? item.querySelector('.bogo-card__color-swatch') : null;
          if (!swatch) return;
          var entry = offerColorMap[color];
          var img = entry && typeof entry === 'object' ? entry.image : '';
          var hex = entry && typeof entry === 'object' ? entry.hex : '';
          if (img) { swatch.style.backgroundImage = 'url(' + img + ')'; swatch.style.backgroundColor = ''; }
          else if (hex) { swatch.style.backgroundImage = ''; swatch.style.backgroundColor = hex; }
          else if (fallbackHex[color]) { swatch.style.backgroundImage = ''; swatch.style.backgroundColor = fallbackHex[color]; }
        }

        offerSelector.querySelectorAll('.bogo-card__option-select').forEach(function(sel) {
          updateOfferSwatch(sel);
          sel.addEventListener('change', function() { updateOfferSwatch(sel); });
        });
      }
    }
  }

  /* ── BOGO Quantity Tiers ── */
  var bogoContainer = document.getElementById('BogoTiers');
  if (bogoContainer) {
    var bogoCards = bogoContainer.querySelectorAll('.bogo-card');
    var bogoActiveTier = 2; /* tier 2 pre-selected */

    bogoCards.forEach(function(card) {
      card.addEventListener('click', function(e) {
        /* Don't toggle card when clicking a <select> */
        if (e.target.tagName === 'SELECT') return;

        var tier = parseInt(card.dataset.tier, 10);
        bogoActiveTier = tier;

        /* Toggle active state + accordion color selectors */
        bogoCards.forEach(function(c) {
          c.classList.remove('bogo-card--selected');
          c.querySelector('.bogo-card__radio').classList.remove('bogo-card__radio--checked');
          var v = c.querySelector('.bogo-card__variants');
          if (v) v.classList.add('bogo-card__variants--hidden');
        });
        card.classList.add('bogo-card--selected');
        card.querySelector('.bogo-card__radio').classList.add('bogo-card__radio--checked');
        var activeVariants = card.querySelector('.bogo-card__variants');
        if (activeVariants) activeVariants.classList.remove('bogo-card__variants--hidden');

        /* Update price display */
        if (priceEl) {
          var tierPrice = bogoContainer.dataset['tier' + tier + 'Price'] || '';
          var tierCompare = bogoContainer.dataset['tier' + tier + 'Compare'] || '';
          var html = '<span class="product-price-current">$' + tierPrice + '</span>';
          if (tierCompare) {
            html += ' <s class="product-price-compare">$' + tierCompare + '</s>';
            var savings = (parseFloat(tierCompare) - parseFloat(tierPrice)).toFixed(2);
            if (parseFloat(savings) > 0) {
              html += ' <span class="product-price-badge">Save $' + savings + '</span>';
            }
          }
          priceEl.innerHTML = html;
        }
      });
    });

    /* Override form submit for BOGO — multi-option support (color, size, etc.) */
    function findVariantByOptions(optionValues) {
      /* optionValues: array of values matching option indices, e.g. ['Nude', 'S/M (32-36)'] */
      return variants.find(function(v) {
        if (!v.options || v.options.length !== optionValues.length) return false;
        for (var i = 0; i < v.options.length; i++) {
          if ((v.options[i] || '').toLowerCase() !== (optionValues[i] || '').toLowerCase()) return false;
        }
        return true;
      });
    }

    form.removeEventListener('submit', form._submitHandler);
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = form.querySelector('.product-atc-btn');
      var activeCard = bogoContainer.querySelector('.bogo-card--selected');
      if (!activeCard) return;

      /* Collect all items with their selected options */
      var items = [];
      var itemRows = activeCard.querySelectorAll('.bogo-card__variant-item');

      if (itemRows.length > 0) {
        /* Group by option combination → find variant for each combo */
        var comboCounts = {};
        var comboValues = {};

        itemRows.forEach(function(row) {
          var selects = row.querySelectorAll('.bogo-card__option-select');
          var vals = [];
          selects.forEach(function(sel) {
            var idx = parseInt(sel.dataset.optionIndex || '0', 10);
            vals[idx] = sel.value;
          });
          var key = vals.join('|');
          comboCounts[key] = (comboCounts[key] || 0) + 1;
          comboValues[key] = vals;
        });

        Object.keys(comboCounts).forEach(function(key) {
          var matchedVariant = findVariantByOptions(comboValues[key]);
          if (matchedVariant) {
            items.push({ id: matchedVariant.id, quantity: comboCounts[key] });
          }
        });
      } else {
        /* No option selects — use form's current variant */
        var variantId = form.querySelector('[name="id"]').value;
        var tierQty = parseInt(activeCard.dataset.qty || '1', 10);
        items.push({ id: parseInt(variantId, 10), quantity: tierQty });
      }

      if (items.length === 0) return;

      btn.disabled = true;
      btn.textContent = 'Adding...';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      })
      .then(function(res) {
        if (!res.ok) throw new Error('Could not add to cart');
        return res.json();
      })
      .then(function() {
        btn.disabled = false;
        btn.textContent = 'Claim My Offer';
        /* Refresh cart drawer + open it */
        if (window.MammothTheme && window.MammothTheme.openCart) {
          window.MammothTheme.fetchCart
            ? window.MammothTheme.fetchCart().then(function() { window.MammothTheme.openCart(); })
            : window.MammothTheme.openCart();
        } else {
          document.dispatchEvent(new CustomEvent('cart:updated'));
        }
      })
      .catch(function(err) {
        btn.disabled = false;
        btn.textContent = 'Claim My Offer';
        console.error('BOGO add error:', err);
      });
    });

    /* Set initial price display to tier 2 */
    if (priceEl) {
      var initPrice = bogoContainer.dataset.tier2Price || '';
      var initCompare = bogoContainer.dataset.tier2Compare || '';
      var html = '<span class="product-price-current">$' + initPrice + '</span>';
      if (initCompare) {
        html += ' <s class="product-price-compare">$' + initCompare + '</s>';
        var initSavings = (parseFloat(initCompare) - parseFloat(initPrice)).toFixed(2);
        if (parseFloat(initSavings) > 0) {
          html += ' <span class="product-price-badge">Save $' + initSavings + '</span>';
        }
      }
      priceEl.innerHTML = html;
    }

    /* ── Color swatches for BOGO selects (only Color option triggers swatch) ── */
    var colorMapEl = document.getElementById('BogoVariantColorMap');
    var optsMapEl = document.getElementById('BogoOptionsMap');
    if (colorMapEl && optsMapEl) {
      var colorMap = JSON.parse(colorMapEl.textContent);
      var optsMap = JSON.parse(optsMapEl.textContent);
      var colorHex = { gold: '#C4944C', silver: '#C0C0C0', black: '#1A1A1A', white: '#F5F5F5', nude: '#E4B590', beige: '#E4B590', rose: '#B76E79', 'rose gold': '#B76E79' };

      function updateSwatch(selectEl) {
        var idx = parseInt(selectEl.dataset.optionIndex || '-1', 10);
        if (idx !== optsMap.colorIndex) return; /* only react to Color option */
        var color = selectEl.value.toLowerCase().trim();
        var item = selectEl.closest('.bogo-card__variant-item');
        var swatch = item ? item.querySelector('.bogo-card__color-swatch') : null;
        if (!swatch) return;
        var entry = colorMap[color];
        var img = entry && typeof entry === 'object' ? entry.image : '';
        var hex = entry && typeof entry === 'object' ? entry.hex : '';
        if (img) {
          swatch.style.backgroundImage = 'url(' + img + ')';
          swatch.style.backgroundColor = '';
        } else if (hex) {
          swatch.style.backgroundImage = '';
          swatch.style.backgroundColor = hex;
        } else if (colorHex[color]) {
          swatch.style.backgroundImage = '';
          swatch.style.backgroundColor = colorHex[color];
        }
      }

      bogoContainer.querySelectorAll('.bogo-card__option-select').forEach(function(sel) {
        updateSwatch(sel);
        sel.addEventListener('change', function() { updateSwatch(sel); });
      });
    }
  }

  /* ── Variant selector ── */
  var selected = {};

  /* Pre-fill selected from currently active buttons */
  form.querySelectorAll('.option-btn.active').forEach(function(b) {
    selected[b.dataset.option] = b.dataset.value;
  });

  form.querySelectorAll('.option-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var optionName = btn.dataset.option;
      var optionVal  = btn.dataset.value;
      var isColor    = btn.dataset.isColor === 'true';

      /* Deselect siblings */
      form.querySelectorAll('.option-btn[data-option="' + optionName + '"]').forEach(function(b) {
        b.classList.remove('active');
      });
      btn.classList.add('active');
      selected[optionName] = optionVal;

      /* Update color label */
      if (isColor) {
        var colorLabel = document.getElementById('SelectedColorLabel');
        if (colorLabel) colorLabel.textContent = optionVal;
      }

      /* Filter gallery when a color option changes */
      if (isColor) {
        filterGalleryByColor(optionVal);
        filterFunnelByColor(optionVal);
      }

      /* Find matching variant */
      var match = variants.find(function(v) {
        return v.options.every(function(opt, i) {
          var key = form.dataset['option' + (i + 1)];
          return !selected[key] || selected[key] === opt;
        });
      });

      if (match) {
        form.querySelector('[name="id"]').value = match.id;

        /* Update price */
        if (priceEl) {
          var imgData = variantImgs[String(match.id)];
          var price = (match.price / 100).toFixed(2);
          priceEl.textContent = '$' + price;
        }

        /* Update add-to-cart button */
        var addBtn = form.querySelector('.product-atc-btn');
        if (addBtn) {
          addBtn.disabled  = !match.available;
          addBtn.textContent = match.available ? 'Claim My Offer' : 'Sold Out';
          addBtn.dataset.variantId = match.id;
        }

        /* Update stock badge */
        var stockBadge = document.getElementById('ProductStockBadge');
        if (stockBadge && variantImgs[String(match.id)]) {
          var qty = variantImgs[String(match.id)].inventory_quantity || 0;
          var dot, text;
          if (qty < 15) {
            dot = 'product-stock-badge__dot--red';
            text = 'Only ' + qty + ' left';
          } else if (qty < 50) {
            dot = 'product-stock-badge__dot--amber';
            text = 'Low stock';
          } else {
            dot = 'product-stock-badge__dot--green';
            text = 'In stock';
          }
          stockBadge.innerHTML = '<span class="product-stock-badge__dot ' + dot + '"></span><span class="product-stock-badge__text">' + text + '</span>';
        }

        /* If NOT a color option, still jump to variant's featured image */
        if (!isColor && variantImgs[String(match.id)]) {
          var imgSrc = variantImgs[String(match.id)].image_src;
          if (imgSrc && imgSrc !== 'null') setMainImage(imgSrc);
        }
      }
    });
  });

  /* ── Thumbnail clicks ── */
  getAllThumbs().forEach(function(thumb, i) {
    thumb.addEventListener('click', function() {
      setActiveThumb(i);
      setMainImage(thumb.dataset.src);
    });
  });

  /* ── Gallery prev/next ── */
  var prevBtn = form.closest('.product-page').querySelector('[data-gallery-prev]');
  var nextBtn = form.closest('.product-page').querySelector('[data-gallery-next]');

  function getVisibleThumbs() {
    return getAllThumbs().filter(function(t) { return t.style.display !== 'none'; });
  }

  function getActiveVisibleIndex() {
    var visible = getVisibleThumbs();
    var active  = thumbWrap ? thumbWrap.querySelector('.product-thumbnail.active') : null;
    return visible.indexOf(active);
  }

  if (prevBtn) prevBtn.addEventListener('click', function() {
    var visible = getVisibleThumbs();
    var cur     = getActiveVisibleIndex();
    var prev    = (cur - 1 + visible.length) % visible.length;
    var t       = visible[prev];
    var idx     = parseInt(t.dataset.index || '0', 10);
    setActiveThumb(idx);
    setMainImage(t.dataset.src);
  });

  if (nextBtn) nextBtn.addEventListener('click', function() {
    var visible = getVisibleThumbs();
    var cur     = getActiveVisibleIndex();
    var next    = (cur + 1) % visible.length;
    var t       = visible[next];
    var idx     = parseInt(t.dataset.index || '0', 10);
    setActiveThumb(idx);
    setMainImage(t.dataset.src);
  });

  /* ── Add to cart (fallback for plain product pages, not bogo/offer_selector) ── */
  if (!bogoContainer && !offerSelector) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var variantId = form.querySelector('[name="id"]').value;
      var btn       = form.querySelector('.product-atc-btn');
      window.MammothTheme.addToCart(variantId, 1, btn);
    });
  }

  /* ── Tab Navigation ── */
  var tabBar = document.getElementById('ProductTabsBar');
  if (tabBar) {
    tabBar.querySelectorAll('.product-tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabBar.querySelectorAll('.product-tab').forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');

        var target = tab.dataset.tabTarget;

        if (target === 'overview') {
          var scrollTo = document.getElementById('ProductFunnel') || document.getElementById('ProductTabsBar');
          if (scrollTo) scrollTo.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else if (target === 'more-info') {
          var section = document.getElementById('ProductMoreInfo');
          if (section) {
            var toggle = section.querySelector('.product-card-toggle');
            var body = section.querySelector('.product-card-body');
            if (toggle && body && !body.classList.contains('open')) {
              toggle.setAttribute('aria-expanded', 'true');
              body.classList.add('open');
            }
            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        } else if (target === 'faq') {
          var section = document.getElementById('ProductFAQ');
          if (section) {
            var toggle = section.querySelector('.product-card-toggle');
            var body = section.querySelector('.product-card-body');
            if (toggle && body && !body.classList.contains('open')) {
              toggle.setAttribute('aria-expanded', 'true');
              body.classList.add('open');
            }
            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
  }

  /* ── Card Toggles (More Info & FAQ sections) ── */
  document.querySelectorAll('.product-card-toggle').forEach(function(toggle) {
    toggle.addEventListener('click', function() {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      var body = toggle.nextElementSibling;
      toggle.setAttribute('aria-expanded', String(!expanded));
      body.classList.toggle('open', !expanded);
    });
  });

  /* ── Estimated Delivery Date ── */
  var deliveryEl = document.getElementById('ProductDeliveryEstimate');
  if (deliveryEl) {
    var businessDays = parseInt(deliveryEl.dataset.businessDays || '3', 10);
    var today = new Date();
    var deliveryDate = new Date(today);
    var daysAdded = 0;
    while (daysAdded < businessDays) {
      deliveryDate.setDate(deliveryDate.getDate() + 1);
      var dayOfWeek = deliveryDate.getDay();
      if (dayOfWeek !== 0 && dayOfWeek !== 6) daysAdded++;
    }
    var months = ['Jan.','Feb.','Mar.','Apr.','May','Jun.','Jul.','Aug.','Sep.','Oct.','Nov.','Dec.'];
    var days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    var formatted = days[deliveryDate.getDay()] + ', ' + months[deliveryDate.getMonth()] + ' ' + deliveryDate.getDate();
    deliveryEl.innerHTML = '\ud83c\uddfa\ud83c\uddf8 Order today and get it by <strong>' + formatted + '</strong>';
  }

  /* ── Review Badge click → scroll to reviews ── */
  var reviewBadge = document.getElementById('ProductReviewBadge');
  if (reviewBadge) {
    reviewBadge.addEventListener('click', function() {
      var target = document.querySelector('.jdgm-widget')
        || document.querySelector('.jdgm-review-widget')
        || document.querySelector('[data-judgeme]')
        || document.getElementById('judgeme_product_reviews');
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  /* ── Upsell Add to Cart ── */
  document.querySelectorAll('.product-upsell-add').forEach(function(btn) {
    if (!btn.disabled) {
      btn.addEventListener('click', function() {
        var variantId = btn.dataset.upsellVariantId;
        if (variantId && window.MammothTheme) {
          window.MammothTheme.addToCart(variantId, 1, btn);
        }
      });
    }
  });

})();
</script>

