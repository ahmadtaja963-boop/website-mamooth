          <button class="product-card-toggle" aria-expanded="false" type="button">
            <span>FAQ</span>
            <svg class="product-card-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <div class="product-card-body">
            <div class="pfaq-list">
              {%- comment -%} Legacy: multiple faq_item blocks {%- endcomment -%}
              {%- for block in faq_blocks -%}
                <div class="pfaq-item" {{ block.shopify_attributes }}>
                  <h4 class="pfaq-question-title">{{ block.settings.faq_question }}</h4>
                  <div class="pfaq-answer-text">{{ block.settings.faq_answer }}</div>
                </div>
              {%- endfor -%}
              {%- comment -%} New: single faq_section block {%- endcomment -%}
              {%- for block in faq_section_blocks -%}
                {%- if block.settings.q1 != blank -%}<div class="pfaq-item" {{ block.shopify_attributes }}><h4 class="pfaq-question-title">{{ block.settings.q1 }}</h4><div class="pfaq-answer-text">{{ block.settings.a1 }}</div></div>{%- endif -%}
                {%- if block.settings.q2 != blank -%}<div class="pfaq-item"><h4 class="pfaq-question-title">{{ block.settings.q2 }}</h4><div class="pfaq-answer-text">{{ block.settings.a2 }}</div></div>{%- endif -%}
                {%- if block.settings.q3 != blank -%}<div class="pfaq-item"><h4 class="pfaq-question-title">{{ block.settings.q3 }}</h4><div class="pfaq-answer-text">{{ block.settings.a3 }}</div></div>{%- endif -%}
                {%- if block.settings.q4 != blank -%}<div class="pfaq-item"><h4 class="pfaq-question-title">{{ block.settings.q4 }}</h4><div class="pfaq-answer-text">{{ block.settings.a4 }}</div></div>{%- endif -%}
                {%- if block.settings.q5 != blank -%}<div class="pfaq-item"><h4 class="pfaq-question-title">{{ block.settings.q5 }}</h4><div class="pfaq-answer-text">{{ block.settings.a5 }}</div></div>{%- endif -%}
                {%- if block.settings.q6 != blank -%}<div class="pfaq-item"><h4 class="pfaq-question-title">{{ block.settings.q6 }}</h4><div class="pfaq-answer-text">{{ block.settings.a6 }}</div></div>{%- endif -%}
                {%- if block.settings.q7 != blank -%}<div class="pfaq-item"><h4 class="pfaq-question-title">{{ block.settings.q7 }}</h4><div class="pfaq-answer-text">{{ block.settings.a7 }}</div></div>{%- endif -%}
                {%- if block.settings.q8 != blank -%}<div class="pfaq-item"><h4 class="pfaq-question-title">{{ block.settings.q8 }}</h4><div class="pfaq-answer-text">{{ block.settings.a8 }}</div></div>{%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
{%- endif -%}

{%- comment -%} ── Styles for Tabs, Cards, FAQ, Reviews ── {%- endcomment -%}
<style>
  /* ── Tab Bar — Pill/Capsule Style ── */
