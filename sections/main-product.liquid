{%- comment -%} ── Video Showcase — moved to product-info column (see trust badges section above) ── {%- endcomment -%}

{%- comment -%} ── Product Funnel ── {%- endcomment -%}
{%- if funnel_blocks.size > 0 -%}
  <div class="product-funnel" id="ProductFunnel">
    {%- for block in funnel_blocks -%}
      {%- assign color_value = block.settings.funnel_color | downcase | strip -%}
      {%- assign funnel_alt = block.settings.funnel_alt | default: 'Product funnel image' -%}
      {%- assign img_slots = "1,2,3,4,5" | split: "," -%}
      {%- for slot in img_slots -%}
        {%- if slot == "1" -%}
          {%- assign desk_img = block.settings.desktop_image -%}
          {%- assign mob_img = block.settings.mobile_image -%}
        {%- elsif slot == "2" -%}
          {%- assign desk_img = block.settings.desktop_image_2 -%}
          {%- assign mob_img = block.settings.mobile_image_2 -%}
        {%- elsif slot == "3" -%}
          {%- assign desk_img = block.settings.desktop_image_3 -%}
          {%- assign mob_img = block.settings.mobile_image_3 -%}
        {%- elsif slot == "4" -%}
          {%- assign desk_img = block.settings.desktop_image_4 -%}
          {%- assign mob_img = block.settings.mobile_image_4 -%}
        {%- elsif slot == "5" -%}
          {%- assign desk_img = block.settings.desktop_image_5 -%}
          {%- assign mob_img = block.settings.mobile_image_5 -%}
        {%- endif -%}
        {%- if desk_img != blank or mob_img != blank -%}
          <div
            class="product-funnel__slide"
            data-funnel-color="{{ color_value }}"
            {% if slot == "1" %}{{ block.shopify_attributes }}{% endif %}
          >
            {%- if desk_img != blank and mob_img != blank -%}
              <picture>
                <source
                  media="(max-width: 749px)"
                  srcset="{{ mob_img | image_url: width: 750 }} 750w,
                          {{ mob_img | image_url: width: 1080 }} 1080w,
                          {{ mob_img | image_url: width: 1500 }} 1500w"
                  sizes="100vw"
                >
                <source
                  media="(min-width: 750px)"
                  srcset="{{ desk_img | image_url: width: 1200 }} 1200w,
                          {{ desk_img | image_url: width: 1800 }} 1800w,
                          {{ desk_img | image_url: width: 2400 }} 2400w,
                          {{ desk_img | image_url: width: 3200 }} 3200w"
                  sizes="100vw"
                >
                <img
                  src="{{ desk_img | image_url: width: 1800 }}"
                  alt="{{ funnel_alt | escape }}"
                  width="{{ desk_img.width }}"
                  height="{{ desk_img.height }}"
                  loading="lazy"
                  class="product-funnel__img"
                >
              </picture>
            {%- elsif desk_img != blank -%}
              <img
                src="{{ desk_img | image_url: width: 1800 }}"
                srcset="{{ desk_img | image_url: width: 1200 }} 1200w,
                        {{ desk_img | image_url: width: 1800 }} 1800w,
                        {{ desk_img | image_url: width: 2400 }} 2400w,
                        {{ desk_img | image_url: width: 3200 }} 3200w"
                sizes="100vw"
                alt="{{ funnel_alt | escape }}"
                width="{{ desk_img.width }}"
                height="{{ desk_img.height }}"
                loading="lazy"
                class="product-funnel__img"
              >
            {%- elsif mob_img != blank -%}
              <img
                src="{{ mob_img | image_url: width: 1080 }}"
                srcset="{{ mob_img | image_url: width: 750 }} 750w,
                        {{ mob_img | image_url: width: 1080 }} 1080w,
                        {{ mob_img | image_url: width: 1500 }} 1500w"
                sizes="100vw"
                alt="{{ funnel_alt | escape }}"
                width="{{ mob_img.width }}"
                height="{{ mob_img.height }}"
                loading="lazy"
                class="product-funnel__img"
              >
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
{%- endif -%}

