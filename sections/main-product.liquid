{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign info_blocks = section.blocks | where: 'type', 'more_info_group' -%}
{%- assign faq_blocks = section.blocks | where: 'type', 'faq_item' -%}
{%- assign funnel_blocks = section.blocks | where: 'type', 'funnel_image' -%}
{%- assign bundle_blocks     = section.blocks | where: 'type', 'bundle_deals' -%}
{%- assign info_tabs_blocks  = section.blocks | where: 'type', 'more_info_tabs' -%}
{%- assign faq_section_blocks = section.blocks | where: 'type', 'faq_section' -%}
{%- assign video_hero_blocks = section.blocks | where: 'type', 'video_hero' -%}
{%- if bundle_blocks.size > 0 -%}
  {{ 'bundle-deals.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<div class="product-page" style="padding-bottom:0;">
  <div class="container">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="product-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      {%- if collection -%}
        &nbsp;/&nbsp;<a href="{{ collection.url }}">{{ collection.title }}</a>
      {%- endif -%}
      &nbsp;/&nbsp;<span>{{ product.title }}</span>
    </nav>

    <div class="product-layout">

      {%- comment -%} ── Gallery ── {%- endcomment -%}
      <div class="product-gallery">
        <div class="product-main-image">
          <img
            id="ProductMainImage"
            src="{{ product.featured_media | image_url: width: 900 }}"
            alt="{{ product.featured_media.alt | default: product.title | escape }}"
            width="900" height="900"
            loading="eager"
            fetchpriority="high"
          >
          {%- if product.media.size > 1 -%}
            <div class="gallery-nav">
              <button class="gallery-nav-btn" data-gallery-prev aria-label="Previous image">
                {%- render 'icon-arrow-left' -%}
              </button>
              <button class="gallery-nav-btn" data-gallery-next aria-label="Next image" style="transform:rotate(180deg);">
                {%- render 'icon-arrow-left' -%}
              </button>
            </div>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          {%- assign default_color = current_variant.option1 | downcase | strip -%}
          {%- assign has_color_option = false -%}
          {%- for opt in product.options_with_values -%}
            {%- assign opt_lower = opt.name | downcase -%}
            {%- if opt_lower == 'color' or opt_lower == 'colour' or opt_lower == 'colore' or opt_lower == 'couleur' -%}
              {%- assign has_color_option = true -%}
            {%- endif -%}
          {%- endfor -%}
          <div class="product-thumbnails" id="ProductThumbnails">
            {%- for media in product.media -%}
              {%- assign media_color = media.alt | downcase | strip -%}
              {%- assign is_default = false -%}
              {%- if has_color_option == false or forloop.first -%}
                {%- assign is_default = true -%}
              {%- elsif default_color != '' and media_color contains default_color -%}
                {%- assign is_default = true -%}
              {%- elsif default_color != '' and default_color contains media_color and media_color != '' -%}
                {%- assign is_default = true -%}
              {%- endif -%}
              <div
                class="product-thumbnail{% if forloop.first %} active{% endif %}"
                data-src="{{ media | image_url: width: 900 }}"
                data-color="{{ media.alt | downcase | strip | escape }}"
                data-index="{{ forloop.index0 }}"
                {% unless is_default %}style="display:none;"{% endunless %}
                aria-label="Product image {{ forloop.index }}"
                role="button"
                tabindex="0"
              >
                <img
                  {% if is_default %}src="{{ media | image_url: width: 160 }}"{% else %}data-thumb-src="{{ media | image_url: width: 160 }}"{% endif %}
                  alt="{{ media.alt | default: product.title | escape }}"
                  width="80" height="80"
                  loading="lazy"
                >
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Product Info ── {%- endcomment -%}
      <div class="product-info">

        {%- comment -%} 1. Judge.me Review Badge {%- endcomment -%}
        {%- if section.settings.show_judgeme_badge -%}
          <div class="product-review-badge" id="ProductReviewBadge">
            <!-- Start of Judge.me code -->
            <div style='{{ jm_style }}' class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>
              {{ product.metafields.judgeme.badge }}
            </div>
            <!-- End of Judge.me code -->
          </div>
        {%- endif -%}

        {%- comment -%} 2. Social Proof {%- endcomment -%}
        {%- if section.settings.social_proof_text != blank -%}
          <p class="product-social-proof">{{ section.settings.social_proof_text }}</p>
        {%- endif -%}

        {%- comment -%} 3. Product Title {%- endcomment -%}
        <h1 class="product-title">{{ product.title }}</h1>

        {%- comment -%} 4. Product Price {%- endcomment -%}
        <p class="product-price" id="ProductPrice">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <s style="color:var(--color-text-muted);margin-right:.5rem;font-size:1rem;">
              {{ current_variant.compare_at_price | money }}
            </s>
          {%- endif -%}
          {{ current_variant.price | money }}
        </p>

        {%- comment -%} 5. Free Shipping Text {%- endcomment -%}
        {%- unless section.settings.shipping_text == blank -%}
          <p class="product-shipping-text">{{ section.settings.shipping_text }}</p>
        {%- endunless -%}

        {%- comment -%} 5b. Shop Pay Installments {%- endcomment -%}
        <div class="product-payment-terms">
          {%- form 'product', product, id: 'ProductPaymentTerms' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            {{ form | payment_terms }}
          {%- endform -%}
        </div>

        {%- comment -%} 6. Product Description (moved up) {%- endcomment -%}
        {%- if product.description != blank -%}
          <div class="product-description">
            {{ product.description }}
          </div>
        {%- endif -%}

        {%- comment -%} 7. Variant Form {%- endcomment -%}
        <script id="ProductVariantImages" type="application/json">
          {
            {%- for variant in product.variants -%}
              "{{ variant.id }}": {
                "price": {{ variant.price }},
                "available": {{ variant.available }},
                "image_src": "{{ variant.featured_image | image_url: width: 900 }}",
                "image_color": "{{ variant.featured_image.alt | downcase | strip | escape }}",
                "inventory_quantity": {{ variant.inventory_quantity | default: 0 }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          }
        </script>

        {%- assign product_variants_json = product.variants | json -%}
        {%- form 'product', product, id: 'ProductForm',
            data-variants: product_variants_json,
            data-option1: product.options[0],
            data-option2: product.options[1],
            data-option3: product.options[2]
        -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {%- unless product.has_only_default_variant -%}
            <div class="product-options">
              {%- for option in product.options_with_values -%}
                {%- assign is_color = false -%}
                {%- assign option_lower = option.name | downcase -%}
                {%- if option_lower == 'color' or option_lower == 'colour' or option_lower == 'colore' or option_lower == 'couleur' -%}
                  {%- assign is_color = true -%}
                {%- endif -%}
                <div style="margin-bottom:1.5rem;">
                  <div class="option-label-row">
                    <span class="option-label">{% if is_color %}Color: <span id="SelectedColorLabel">{{ option.selected_value }}</span>{% else %}{{ option.name }}{% endif %}</span>
                    {%- if is_color -%}
                      {%- assign inv = current_variant.inventory_quantity | default: 0 -%}
                      <span class="product-stock-badge" id="ProductStockBadge">
                        {%- if inv < 15 -%}<span class="product-stock-badge__dot product-stock-badge__dot--red"></span><span class="product-stock-badge__text">Only {{ inv }} left</span>
                        {%- elsif inv < 50 -%}<span class="product-stock-badge__dot product-stock-badge__dot--amber"></span><span class="product-stock-badge__text">Low stock</span>
                        {%- else -%}<span class="product-stock-badge__dot product-stock-badge__dot--green"></span><span class="product-stock-badge__text">In stock</span>
                        {%- endif -%}
                      </span>
                    {%- endif -%}
                  </div>
                  <div class="option-values{% if is_color %} option-values--color{% endif %}">
                    {%- for value in option.values -%}
                      {%- if is_color -%}
                        <button
                          type="button"
                          class="option-btn option-btn--color{% if option.selected_value == value %} active{% endif %}"
                          data-option="{{ option.name }}"
                          data-value="{{ value }}"
                          data-is-color="true"
                          aria-label="{{ option.name }}: {{ value }}"
                          title="{{ value }}"
                        >
                          {%- if value.swatch.image -%}
                            <img src="{{ value.swatch.image | image_url: width: 120 }}" alt="{{ value | escape }}" width="60" height="60" loading="lazy" class="color-swatch-img">
                          {%- elsif value.swatch.color -%}
                            <span class="color-swatch-img" style="background-color: {{ value.swatch.color }};"></span>
                          {%- else -%}
                            <span class="color-swatch-img color-swatch-img--fallback">{{ value | slice: 0, 2 }}</span>
                          {%- endif -%}
                        </button>
                      {%- else -%}
                        <button
                          type="button"
                          class="option-btn{% if option.selected_value == value %} active{% endif %}"
                          data-option="{{ option.name }}"
                          data-value="{{ value }}"
                          data-is-color="false"
                          aria-label="{{ option.name }}: {{ value }}"
                        >
                          {{ value }}
                        </button>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          {%- comment -%} 8. Add to Cart {%- endcomment -%}
          <div class="product-atc">
            <button
              type="submit"
              class="product-atc-btn"
              data-variant-id="{{ current_variant.id }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}

        {%- comment -%} 9. Delivery Estimate {%- endcomment -%}
        {%- if section.settings.show_delivery_estimate -%}
          <div class="product-delivery-estimate" id="ProductDeliveryEstimate"
               data-business-days="{{ section.settings.delivery_business_days }}">
          </div>
        {%- endif -%}

        {%- comment -%} 10. Payment Icons {%- endcomment -%}
        {%- if section.settings.show_payment_icons -%}
          <div class="product-payment-icons">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} 10b. Trust Badges {%- endcomment -%}
        <div class="product-trust-badges">
          <div class="product-trust-badge">
            <img src="https://cdn.shopify.com/s/files/1/0674/0636/4749/files/2088741_430x.png?v=1773561823" alt="Full-Grain Leather" width="28" height="28" style="width:28px;height:28px;object-fit:contain;">
            <span>Full-Grain<br>Leather</span>
          </div>
          <div class="product-trust-badge">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="0"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Free US<br>Shipping</span>
          </div>
          <div class="product-trust-badge">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            <span>30-Day<br>Returns</span>
          </div>
          <div class="product-trust-badge">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Manufacturer<br>Warranty</span>
          </div>
        </div>

        {%- comment -%} 10c. Bundle Deals {%- endcomment -%}
        {%- assign bundle_blocks = section.blocks | where: 'type', 'bundle_deals' -%}
        {%- if bundle_blocks.size > 0 -%}
          <div class="product-bundle-deals">
            {%- for block in bundle_blocks -%}
              {%- assign bd = block.settings -%}
              {%- assign bd_p2 = bd.product_2 -%}
              {%- assign bd_p3 = bd.product_3 -%}
              {%- assign bd_p4 = bd.product_4 -%}

              {%- comment -%} Bundle price overrides (in cents) — set in block settings as dollars e.g. "24.00" {%- endcomment -%}
              {%- assign bd_bp1_cents = bd.bundle_price_1 | times: 100 | round -%}
              {%- assign bd_bp2_cents = bd.bundle_price_2 | times: 100 | round -%}
              {%- assign bd_bp3_cents = bd.bundle_price_3 | times: 100 | round -%}
              {%- assign bd_bp4_cents = bd.bundle_price_4 | times: 100 | round -%}

              {%- comment -%} Pre-calculate totals — use bundle price override if set {%- endcomment -%}
              {%- if bd_bp1_cents > 0 -%}
                {%- assign bd_total = bd_bp1_cents -%}
                {%- assign bd_compare = current_variant.price -%}
              {%- else -%}
                {%- assign bd_total = current_variant.price -%}
                {%- if current_variant.compare_at_price > current_variant.price -%}
                  {%- assign bd_compare = current_variant.compare_at_price -%}
                {%- else -%}
                  {%- assign bd_compare = current_variant.price -%}
                {%- endif -%}
              {%- endif -%}
              {%- if bd_p2 != blank -%}
                {%- if bd_bp2_cents > 0 -%}
                  {%- assign bd_total = bd_total | plus: bd_bp2_cents -%}
                  {%- assign bd_compare = bd_compare | plus: bd_p2.price -%}
                {%- else -%}
                  {%- assign bd_total = bd_total | plus: bd_p2.price -%}
                  {%- if bd_p2.compare_at_price > bd_p2.price -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p2.compare_at_price -%}
                  {%- else -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p2.price -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endif -%}
              {%- if bd_p3 != blank -%}
                {%- if bd_bp3_cents > 0 -%}
                  {%- assign bd_total = bd_total | plus: bd_bp3_cents -%}
                  {%- assign bd_compare = bd_compare | plus: bd_p3.price -%}
                {%- else -%}
                  {%- assign bd_total = bd_total | plus: bd_p3.price -%}
                  {%- if bd_p3.compare_at_price > bd_p3.price -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p3.compare_at_price -%}
                  {%- else -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p3.price -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endif -%}
              {%- if bd_p4 != blank -%}
                {%- if bd_bp4_cents > 0 -%}
                  {%- assign bd_total = bd_total | plus: bd_bp4_cents -%}
                  {%- assign bd_compare = bd_compare | plus: bd_p4.price -%}
                {%- else -%}
                  {%- assign bd_total = bd_total | plus: bd_p4.price -%}
                  {%- if bd_p4.compare_at_price > bd_p4.price -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p4.compare_at_price -%}
                  {%- else -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p4.price -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endif -%}

              <bundle-deals class="bundle-deals" {{ block.shopify_attributes }}>
                <p class="product-bundle-deals__heading">{{ bd.heading | default: 'Build Your Bundle' }}</p>

                {%- comment -%} Thumbnails row {%- endcomment -%}
                <div class="bundle-deals__media">
                  <div class="bundle-deals__media-item" data-media-index="0" id="bd-thumb-{{ block.id }}-0">
                    {%- if current_variant.featured_media -%}
                      <img src="{{ current_variant.featured_media | image_url: width: 144 }}" alt="{{ product.title | escape }}" width="72" height="72" loading="lazy">
                    {%- elsif product.featured_media -%}
                      <img src="{{ product.featured_media | image_url: width: 144 }}" alt="{{ product.title | escape }}" width="72" height="72" loading="lazy">
                    {%- endif -%}
                  </div>
                  {%- if bd_p2 != blank -%}
                    <div class="bundle-deals__media-item" data-media-index="1">
                      {%- if bd_p2.featured_media -%}
                        <img src="{{ bd_p2.featured_media | image_url: width: 144 }}" alt="{{ bd_p2.title | escape }}" width="72" height="72" loading="lazy">
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- if bd_p3 != blank -%}
                    <div class="bundle-deals__media-item" data-media-index="2">
                      {%- if bd_p3.featured_media -%}
                        <img src="{{ bd_p3.featured_media | image_url: width: 144 }}" alt="{{ bd_p3.title | escape }}" width="72" height="72" loading="lazy">
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- if bd_p4 != blank -%}
                    <div class="bundle-deals__media-item" data-media-index="3">
                      {%- if bd_p4.featured_media -%}
                        <img src="{{ bd_p4.featured_media | image_url: width: 144 }}" alt="{{ bd_p4.title | escape }}" width="72" height="72" loading="lazy">
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>

                {%- comment -%} WAS / TODAY summary {%- endcomment -%}
                {%- if bd_compare > bd_total -%}
                  <p class="bundle-deals__summary">
                    <span class="bundle-deals__summary-was">WAS: {{ bd_compare | money }}</span>
                    <span class="bundle-deals__summary-today">TODAY: {{ bd_total | money }}</span>
                  </p>
                {%- endif -%}

                {%- comment -%} Product rows — first item always = current page product {%- endcomment -%}
                <div class="bundle-deals__product" data-product-index="0">
                  <div class="bundle-deals__checkbox-container">
                    <input type="checkbox" class="bundle-deals__checkbox" id="bd-check-{{ block.id }}-0"
                      data-variant-id="{{ current_variant.id }}"
                      data-price="{% if bd_bp1_cents > 0 %}{{ bd_bp1_cents }}{% else %}{{ current_variant.price }}{% endif %}"
                      data-compare-price="{{ current_variant.price }}"
                      checked disabled>
                    <label class="bundle-deals__checkbox-label" for="bd-check-{{ block.id }}-0">
                      <svg viewBox="0 0 20 20" class="checkmark-checked" aria-hidden="true"><path fill="currentColor" d="M2 10a8 8 0 1 1 16 0A8 8 0 0 1 2 10zm11.78-2.97a.75.75 0 0 0-1.06-1.06L9 9.69 7.28 7.97a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l4.25-4.25z"/></svg>
                      <svg viewBox="0 0 20 20" class="checkmark-unchecked" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2z"/></svg>
                      <p class="bundle-deals__title">{{ product.title }}</p>
                    </label>
                    <div class="bundle-deals__prices">
                      {%- if bd_bp1_cents > 0 -%}
                        <span class="bundle-deals__compare-price" id="bd-cprice-{{ block.id }}-0">{{ current_variant.price | money }}</span>
                        <span class="bundle-deals__price" id="bd-price-{{ block.id }}-0">{{ bd_bp1_cents | money }}</span>
                      {%- else -%}
                        {%- if current_variant.compare_at_price > current_variant.price -%}
                          <span class="bundle-deals__compare-price" id="bd-cprice-{{ block.id }}-0">{{ current_variant.compare_at_price | money }}</span>
                        {%- else -%}
                          <span class="bundle-deals__compare-price" id="bd-cprice-{{ block.id }}-0" style="display:none"></span>
                        {%- endif -%}
                        <span class="bundle-deals__price" id="bd-price-{{ block.id }}-0">{{ current_variant.price | money }}</span>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
                {%- if bd_p2 != blank -%}
                  {%- assign bp_variant = bd_p2.selected_or_first_available_variant -%}
                  <div class="bundle-deals__product" data-product-index="1">
                    <div class="bundle-deals__checkbox-container">
                      <input type="checkbox" class="bundle-deals__checkbox" id="bd-check-{{ block.id }}-1" data-variant-id="{{ bp_variant.id }}" data-price="{% if bd_bp2_cents > 0 %}{{ bd_bp2_cents }}{% else %}{{ bp_variant.price }}{% endif %}" data-compare-price="{{ bp_variant.price }}" checked>
                      <label class="bundle-deals__checkbox-label" for="bd-check-{{ block.id }}-1">
                        <svg viewBox="0 0 20 20" class="checkmark-checked" aria-hidden="true"><path fill="currentColor" d="M2 10a8 8 0 1 1 16 0A8 8 0 0 1 2 10zm11.78-2.97a.75.75 0 0 0-1.06-1.06L9 9.69 7.28 7.97a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l4.25-4.25z"/></svg>
                        <svg viewBox="0 0 20 20" class="checkmark-unchecked" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2z"/></svg>
                        <p class="bundle-deals__title">{{ bd_p2.title }}</p>
                      </label>
                      <div class="bundle-deals__prices">
                        {%- if bd_bp2_cents > 0 -%}
                          <span class="bundle-deals__compare-price">{{ bp_variant.price | money }}</span>
                          <span class="bundle-deals__price">{{ bd_bp2_cents | money }}</span>
                        {%- else -%}
                          {%- if bp_variant.compare_at_price > bp_variant.price -%}<span class="bundle-deals__compare-price">{{ bp_variant.compare_at_price | money }}</span>{%- endif -%}
                          <span class="bundle-deals__price">{{ bp_variant.price | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    {%- if bd_p2.variants.size > 1 -%}
                      <div class="bundle-deals__variant-selects">
                        {%- for option in bd_p2.options_with_values -%}
                          <div class="select"><select data-product-index="1" data-option-index="{{ forloop.index0 }}" aria-label="{{ option.name }}">{%- for value in option.values -%}<option value="{{ value | escape }}"{% if option.selected_value == value %} selected{% endif %}>{{ value }}</option>{%- endfor -%}</select><svg class="icon-caret" viewBox="0 0 10 6" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M1 1l4 4 4-4"/></svg></div>
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
