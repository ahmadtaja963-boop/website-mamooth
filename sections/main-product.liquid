{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign info_blocks = section.blocks | where: 'type', 'more_info_group' -%}
{%- assign faq_blocks = section.blocks | where: 'type', 'faq_item' -%}
{%- assign funnel_blocks = section.blocks | where: 'type', 'funnel_image' -%}
{%- assign bundle_blocks     = section.blocks | where: 'type', 'bundle_deals' -%}
{%- assign info_tabs_blocks  = section.blocks | where: 'type', 'more_info_tabs' -%}
{%- assign faq_section_blocks = section.blocks | where: 'type', 'faq_section' -%}
{%- assign video_hero_blocks = section.blocks | where: 'type', 'video_hero' -%}
{%- assign offer_selector_blocks = section.blocks | where: 'type', 'offer_selector' -%}
{%- assign bogo_blocks = section.blocks | where: 'type', 'bogo_tiers' -%}
{%- assign video_showcase_blocks = section.blocks | where: 'type', 'video_showcase' -%}
{%- assign urgency_blocks = section.blocks | where: 'type', 'urgency_counter' -%}
{%- assign stock_blocks = section.blocks | where: 'type', 'stock_indicator' -%}
{%- if bundle_blocks.size > 0 -%}
  {{ 'bundle-deals.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- if section.settings.accent_color != blank -%}
<style>
  .product-page {
    --color-accent: {{ section.settings.accent_color }};
  }
  .product-page .product-atc-btn,
  .product-page .offer-card.active { border-color: var(--color-accent); }
  .product-page .product-atc-btn { background: var(--color-accent); }
  .product-page .product-atc-btn:hover { background: color-mix(in srgb, var(--color-accent) 85%, #000); }
  .product-page .offer-card.active { background: color-mix(in srgb, var(--color-accent) 6%, #fff); }
  .product-page .offer-card { border-color: color-mix(in srgb, var(--color-accent) 30%, #DDE4EA); }
  .product-page .offer-card__radio::after { background: var(--color-accent); }
  .product-page .offer-card__check path { stroke: var(--color-accent); }
  .product-page .product-price-badge { background: var(--color-accent); }
  .product-page .product-stock-badge__dot--amber { background: var(--color-accent); }
  .product-page .offer-card__deal-badge { background: var(--color-accent); }
  .product-page .offer-card__free { color: var(--color-accent); }
  .product-page .bogo-card.bogo-card--selected { border-color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 6%, #fff); }
  .product-page .bogo-card { border-color: color-mix(in srgb, var(--color-accent) 30%, #DDE4EA); }
  .product-page .bogo-card__radio--checked { border-color: var(--color-accent); }
  .product-page .bogo-card__radio--checked::after { background: var(--color-accent); }
  .product-page .bogo-card__badge { background: var(--color-accent); }
  .product-page .bogo-social-proof__dot { background: var(--color-accent); }
  .product-page .product-info a { color: var(--color-accent); }
  .announcement-bar { background: {{ section.settings.accent_color }} !important; }
  .cart-reserved { background: {{ section.settings.accent_color }} !important; }
  .cart-checkout-btn { background: {{ section.settings.accent_color }} !important; }
  .cart-checkout-btn:hover { background: color-mix(in srgb, {{ section.settings.accent_color }} 85%, #000) !important; }
  .cart-discount-milestone.reached .cart-discount-dot { background: {{ section.settings.accent_color }}; border-color: {{ section.settings.accent_color }}; box-shadow: 0 0 0 3px rgba(181,115,106,0.15); }
  .cart-discount-fill { background: {{ section.settings.accent_color }}; }
</style>
{%- endif -%}
<div class="product-page" style="padding-bottom:0;">
  <div class="container">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="product-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      {%- if collection -%}
        &nbsp;/&nbsp;<a href="{{ collection.url }}">{{ collection.title }}</a>
      {%- endif -%}
      &nbsp;/&nbsp;<span>{{ product.title }}</span>
    </nav>

    <div class="product-layout">

      {%- comment -%} ── Gallery ── {%- endcomment -%}
      <div class="product-gallery">
        <div class="product-main-image">
          <img
            id="ProductMainImage"
            src="{{ product.featured_media | image_url: width: 900 }}"
            alt="{{ product.featured_media.alt | default: product.title | escape }}"
            width="900" height="900"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          >
          {%- if product.media.size > 1 -%}
            <div class="gallery-nav">
              <button class="gallery-nav-btn" data-gallery-prev aria-label="Previous image">
                {%- render 'icon-arrow-left' -%}
              </button>
              <button class="gallery-nav-btn" data-gallery-next aria-label="Next image" style="transform:rotate(180deg);">
                {%- render 'icon-arrow-left' -%}
              </button>
            </div>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          {%- assign default_color = current_variant.option1 | downcase | strip -%}
          {%- assign has_color_option = false -%}
          {%- assign color_option_values = '' -%}
          {%- for opt in product.options_with_values -%}
            {%- assign opt_lower = opt.name | downcase -%}
            {%- if opt_lower == 'color' or opt_lower == 'colour' or opt_lower == 'colore' or opt_lower == 'couleur' -%}
              {%- assign has_color_option = true -%}
              {%- for v in opt.values -%}
                {%- assign color_option_values = color_option_values | append: '|' | append: v | downcase -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
          {%- assign product_title_lower = product.title | downcase | strip -%}
          <div class="product-thumbnails" id="ProductThumbnails">
            {%- for media in product.media -%}
              {%- assign raw_alt = media.alt | default: '' | downcase | strip -%}
              {%- comment -%} Treat alt as generic (empty) if it equals the product title OR doesn't match any color option value {%- endcomment -%}
              {%- assign media_color = '' -%}
              {%- if raw_alt != '' and raw_alt != product_title_lower -%}
                {%- comment -%} Check if alt matches any color value {%- endcomment -%}
                {%- assign color_vals_arr = color_option_values | split: '|' -%}
                {%- for cv in color_vals_arr -%}
                  {%- if cv != '' and raw_alt contains cv -%}
                    {%- assign media_color = cv -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- assign is_default = false -%}
              {%- if has_color_option == false or forloop.first -%}
                {%- assign is_default = true -%}
              {%- elsif media_color == '' -%}
                {%- comment -%} Generic image (no specific color assigned) — show for all variants {%- endcomment -%}
                {%- assign is_default = true -%}
              {%- elsif default_color != '' and media_color contains default_color -%}
                {%- assign is_default = true -%}
              {%- elsif default_color != '' and default_color contains media_color and media_color != '' -%}
                {%- assign is_default = true -%}
              {%- endif -%}
              <div
                class="product-thumbnail{% if forloop.first %} active{% endif %}"
                data-src="{{ media | image_url: width: 900 }}"
                data-color="{{ media_color | escape }}"
                data-index="{{ forloop.index0 }}"
                {% unless is_default %}style="display:none;"{% endunless %}
                aria-label="Product image {{ forloop.index }}"
                role="button"
                tabindex="0"
              >
                <img
                  {% if is_default %}src="{{ media | image_url: width: 160 }}"{% else %}data-thumb-src="{{ media | image_url: width: 160 }}"{% endif %}
                  alt="{{ media.alt | default: product.title | escape }}"
                  width="80" height="80"
                  loading="lazy"
                >
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Product Info ── {%- endcomment -%}
      <div class="product-info">

        {%- comment -%} 1. Judge.me Review Badge {%- endcomment -%}
        {%- if section.settings.show_judgeme_badge -%}
          <div class="product-review-badge" id="ProductReviewBadge">
            <!-- Start of Judge.me code -->
            <div class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>
              {{ product.metafields.judgeme.badge }}
            </div>
            <!-- End of Judge.me code -->
          </div>
        {%- endif -%}

        {%- comment -%} 2. Social Proof {%- endcomment -%}
        {%- if section.settings.social_proof_text != blank -%}
          <p class="product-social-proof">{{ section.settings.social_proof_text }}</p>
        {%- endif -%}

        {%- comment -%} 3. Product Title {%- endcomment -%}
        <h1 class="product-title">{{ product.title }}</h1>

        {%- comment -%} 4. Product Price {%- endcomment -%}
        {%- if bogo_blocks.size > 0 -%}
          {%- assign display_variant = current_variant -%}
        {%- elsif offer_selector_blocks.size > 0 -%}
          {%- assign display_variant = product.variants.last -%}
        {%- else -%}
          {%- assign display_variant = current_variant -%}
        {%- endif -%}
        <div class="product-price-row" id="ProductPrice">
          <span class="product-price-current">{{ display_variant.price | money }}</span>
          {%- if display_variant.compare_at_price > display_variant.price -%}
            <s class="product-price-compare">{{ display_variant.compare_at_price | money }}</s>
            {%- assign savings = display_variant.compare_at_price | minus: display_variant.price -%}
            <span class="product-price-badge">Limited Offer&nbsp;&nbsp;·&nbsp;&nbsp;Save {{ savings | money }}</span>
          {%- endif -%}
        </div>

        {%- comment -%} 5. Free Shipping Text {%- endcomment -%}
        {%- unless section.settings.shipping_text == blank -%}
          <p class="product-shipping-text">{{ section.settings.shipping_text }}</p>
        {%- endunless -%}

        {%- comment -%} 5b. Shop Pay Installments {%- endcomment -%}
        <div class="product-payment-terms">
          {%- form 'product', product, id: 'ProductPaymentTerms' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            {{ form | payment_terms }}
          {%- endform -%}
        </div>

        {%- comment -%} 6. Product Description (moved up) {%- endcomment -%}
        {%- if product.description != blank -%}
          <div class="product-description">
            {{ product.description }}
          </div>
        {%- endif -%}

        {%- comment -%} 7. Variant Form {%- endcomment -%}
        <script id="ProductVariantImages" type="application/json">
          {
            {%- for variant in product.variants -%}
              "{{ variant.id }}": {
                "price": {{ variant.price }},
                "available": {{ variant.available }},
                "image_src": "{{ variant.featured_image | image_url: width: 900 }}",
                "image_color": "{{ variant.featured_image.alt | downcase | strip | escape }}",
                "inventory_quantity": {{ variant.inventory_quantity | default: 0 }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          }
        </script>

        {%- assign product_variants_json = product.variants | json -%}
        {%- form 'product', product, id: 'ProductForm',
            data-variants: product_variants_json,
            data-option1: product.options[0],
            data-option2: product.options[1],
            data-option3: product.options[2]
        -%}
          {%- if bogo_blocks.size > 0 -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {%- elsif offer_selector_blocks.size > 0 -%}
            <input type="hidden" name="id" value="{{ product.variants.last.id }}">
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {%- endif -%}

          {%- unless product.has_only_default_variant -%}
            {%- if bogo_blocks.size > 0 -%}
              {%- assign bogo_block = bogo_blocks.first -%}
              {%- assign bg = bogo_block.settings -%}

              {%- comment -%} Detect ALL product options (color, size, anything) for BOGO selectors {%- endcomment -%}
              {%- assign bogo_has_options = false -%}
              {%- unless product.has_only_default_variant -%}
                {%- assign bogo_has_options = true -%}
              {%- endunless -%}

              {%- comment -%} Find color option index for swatch (if exists) {%- endcomment -%}
              {%- assign bogo_color_index = -1 -%}
              {%- for opt in product.options_with_values -%}
                {%- assign opt_lower = opt.name | downcase -%}
                {%- if opt_lower == 'color' or opt_lower == 'colour' or opt_lower == 'colore' or opt_lower == 'couleur' -%}
                  {%- assign bogo_color_index = forloop.index0 -%}
                {%- endif -%}
              {%- endfor -%}
              {%- assign bogo_opts_count = product.options_with_values | size -%}
              {%- capture bogo_grid -%}28px{%- if bogo_color_index >= 0 %} 22px{% endif %} repeat({{ bogo_opts_count }}, minmax(0, 1fr)){%- endcapture -%}

              {%- comment -%} Dynamic prices from product {%- endcomment -%}
              {%- assign bogo_unit_cents = current_variant.price -%}
              {%- assign tier1_qty_num = bg.tier1_qty | plus: 0 -%}
              {%- assign tier2_qty_num = bg.tier2_qty | plus: 0 -%}
              {%- assign tier3_qty_num = bg.tier3_qty | plus: 0 -%}
              {%- assign tier1_compare_cents = bogo_unit_cents | times: tier1_qty_num -%}
              {%- assign tier2_compare_cents = bogo_unit_cents | times: tier2_qty_num -%}
              {%- assign tier3_compare_cents = bogo_unit_cents | times: tier3_qty_num -%}

              {%- comment -%} Build color swatch map from native product_option_value swatches (hex + image) {%- endcomment -%}
              <script id="BogoVariantColorMap" type="application/json">
                {
                  {%- if bogo_color_index >= 0 -%}
                    {%- for opt in product.options_with_values -%}
                      {%- if forloop.index0 == bogo_color_index -%}
                        {%- for val in opt.values -%}
                          "{{ val | downcase | strip }}": { "hex": "{{ val.swatch.color }}", "image": "{%- if val.swatch.image -%}{{ val.swatch.image | image_url: width: 60 }}{%- endif -%}" }{% unless forloop.last %},{% endunless %}
                        {%- endfor -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                }
              </script>

              {%- comment -%} Build option definitions for JS {%- endcomment -%}
              <script id="BogoOptionsMap" type="application/json">
                {
                  "colorIndex": {{ bogo_color_index }},
                  "options": [
                    {%- for opt in product.options_with_values -%}
                      {
                        "name": "{{ opt.name | escape }}",
                        "index": {{ forloop.index0 }},
                        "values": [{% for v in opt.values %}"{{ v | escape }}"{% unless forloop.last %},{% endunless %}{% endfor %}]
                      }{% unless forloop.last %},{% endunless %}
                    {%- endfor -%}
                  ]
                }
              </script>

              <div class="bogo-tiers" id="BogoTiers" {{ bogo_block.shopify_attributes }}
                data-tier1-qty="{{ bg.tier1_qty }}"
                data-tier1-price="{{ current_variant.price | money_without_currency }}"
                data-tier1-compare=""
                data-tier2-qty="{{ bg.tier2_qty }}"
                data-tier2-price="{{ current_variant.price | money_without_currency }}"
                data-tier2-compare="{{ tier2_compare_cents | money_without_currency }}"
                data-tier3-qty="{{ bg.tier3_qty }}"
                data-tier3-price="{{ bogo_unit_cents | times: 2 | money_without_currency }}"
                data-tier3-compare="{{ tier3_compare_cents | money_without_currency }}"
              >
                {%- comment -%} ── Tier 1 ── {%- endcomment -%}
                <label class="bogo-card" data-tier="1" data-qty="{{ bg.tier1_qty }}">
                  <span class="bogo-card__radio"></span>
                  <span class="bogo-card__body">
                    <span class="bogo-card__top">
                      <span class="bogo-card__label-wrap">
                        <span class="bogo-card__label">{{ bg.tier1_label }}</span>
                        {%- if bg.tier1_sublabel != blank -%}
                          <span class="bogo-card__sublabel">{{ bg.tier1_sublabel }}</span>
                        {%- endif -%}
                      </span>
                      <span class="bogo-card__prices">
                        <span class="bogo-card__price">{{ current_variant.price | money }}</span>
                      </span>
                    </span>
                    {%- if bogo_has_options -%}
                      <span class="bogo-card__variants bogo-card__variants--hidden">
                        <span class="bogo-card__variant-selects" style="--bogo-grid: {{ bogo_grid }};">
                          <span class="bogo-card__variant-header">
                            <span></span>
                            {%- if bogo_color_index >= 0 -%}<span></span>{%- endif -%}
                            {%- for opt in product.options_with_values -%}
                              <span class="bogo-card__variant-header-label">{{ opt.name }}</span>
                            {%- endfor -%}
                          </span>
                          {%- for i in (1..tier1_qty_num) -%}
                            <span class="bogo-card__variant-item">
                              <span class="bogo-card__variant-num">{%- if tier1_qty_num > 1 -%}#{{ i }}{%- endif -%}</span>
                              {%- if bogo_color_index >= 0 -%}<span class="bogo-card__color-swatch" data-select-target="{{ i }}"></span>{%- endif -%}
                              {%- for opt in product.options_with_values -%}
                                <select class="bogo-card__option-select" data-item-index="{{ i }}" data-option-index="{{ forloop.index0 }}" data-option-name="{{ opt.name | escape }}">
                                  {%- for val in opt.values -%}
                                    <option value="{{ val }}"{% if val == opt.selected_value %} selected{% endif %}>{{ val }}</option>
                                  {%- endfor -%}
                                </select>
                              {%- endfor -%}
                            </span>
                          {%- endfor -%}
                        </span>
                      </span>
                    {%- endif -%}
                  </span>
                </label>

                {%- comment -%} ── Tier 2 (B1G1F) ── {%- endcomment -%}
                <label class="bogo-card bogo-card--selected" data-tier="2" data-qty="{{ bg.tier2_qty }}">
                  <span class="bogo-card__radio bogo-card__radio--checked"></span>
                  {%- if bg.tier2_badge != blank -%}
                    <span class="bogo-card__badge">{{ bg.tier2_badge }}</span>
                  {%- endif -%}
                  <span class="bogo-card__body">
                    <span class="bogo-card__top">
                      <span class="bogo-card__label-wrap">
                        <span class="bogo-card__label">{{ bg.tier2_label }}</span>
                        {%- if bg.tier2_sublabel != blank -%}
                          <span class="bogo-card__sublabel bogo-card__sublabel--urgent">{{ bg.tier2_sublabel }}</span>
                        {%- endif -%}
                      </span>
                      <span class="bogo-card__prices">
                        <span class="bogo-card__price">{{ current_variant.price | money }}</span>
                        <s class="bogo-card__compare">{{ tier2_compare_cents | money }}</s>
                      </span>
                    </span>
                    {%- if bogo_has_options and tier2_qty_num > 0 -%}
                      <span class="bogo-card__variants">
                        <span class="bogo-card__variant-selects" style="--bogo-grid: {{ bogo_grid }};">
                          <span class="bogo-card__variant-header">
                            <span></span>
                            {%- if bogo_color_index >= 0 -%}<span></span>{%- endif -%}
                            {%- for opt in product.options_with_values -%}
                              <span class="bogo-card__variant-header-label">{{ opt.name }}</span>
                            {%- endfor -%}
                          </span>
                          {%- for i in (1..tier2_qty_num) -%}
                            <span class="bogo-card__variant-item">
                              <span class="bogo-card__variant-num">#{{ i }}</span>
                              {%- if bogo_color_index >= 0 -%}<span class="bogo-card__color-swatch" data-select-target="{{ i }}"></span>{%- endif -%}
                              {%- for opt in product.options_with_values -%}
                                <select class="bogo-card__option-select" data-item-index="{{ i }}" data-option-index="{{ forloop.index0 }}" data-option-name="{{ opt.name | escape }}">
                                  {%- for val in opt.values -%}
                                    <option value="{{ val }}"{% if val == opt.selected_value %} selected{% endif %}>{{ val }}</option>
                                  {%- endfor -%}
                                </select>
                              {%- endfor -%}
                            </span>
                          {%- endfor -%}
                        </span>
                      </span>
                    {%- endif -%}
                  </span>
                </label>

                {%- comment -%} ── Tier 3 (B2G2F — pay for 2, get 4) ── {%- endcomment -%}
                <label class="bogo-card" data-tier="3" data-qty="{{ bg.tier3_qty }}">
                  <span class="bogo-card__radio"></span>
                  {%- if bg.tier3_badge != blank -%}
                    <span class="bogo-card__badge">{{ bg.tier3_badge }}</span>
                  {%- endif -%}
                  <span class="bogo-card__body">
                    <span class="bogo-card__top">
                      <span class="bogo-card__label-wrap">
                        <span class="bogo-card__label">{{ bg.tier3_label }}</span>
                        {%- if bg.tier3_sublabel != blank -%}
                          <span class="bogo-card__sublabel bogo-card__sublabel--urgent">{{ bg.tier3_sublabel }}</span>
                        {%- endif -%}
                      </span>
                      <span class="bogo-card__prices">
                        <span class="bogo-card__price">{{ bogo_unit_cents | times: 2 | money }}</span>
                        <s class="bogo-card__compare">{{ tier3_compare_cents | money }}</s>
                      </span>
                    </span>
                    {%- if bogo_has_options and tier3_qty_num > 0 -%}
                      <span class="bogo-card__variants bogo-card__variants--hidden">
                        <span class="bogo-card__variant-selects" style="--bogo-grid: {{ bogo_grid }};">
                          <span class="bogo-card__variant-header">
                            <span></span>
                            {%- if bogo_color_index >= 0 -%}<span></span>{%- endif -%}
                            {%- for opt in product.options_with_values -%}
                              <span class="bogo-card__variant-header-label">{{ opt.name }}</span>
                            {%- endfor -%}
                          </span>
                          {%- for i in (1..tier3_qty_num) -%}
                            <span class="bogo-card__variant-item">
                              <span class="bogo-card__variant-num">#{{ i }}</span>
                              {%- if bogo_color_index >= 0 -%}<span class="bogo-card__color-swatch" data-select-target="{{ i }}"></span>{%- endif -%}
                              {%- for opt in product.options_with_values -%}
                                <select class="bogo-card__option-select" data-item-index="{{ i }}" data-option-index="{{ forloop.index0 }}" data-option-name="{{ opt.name | escape }}">
                                  {%- for val in opt.values -%}
                                    <option value="{{ val }}"{% if val == opt.selected_value %} selected{% endif %}>{{ val }}</option>
                                  {%- endfor -%}
                                </select>
                              {%- endfor -%}
                            </span>
                          {%- endfor -%}
                        </span>
                      </span>
                    {%- endif -%}
                  </span>
                </label>

                {%- comment -%} Social proof {%- endcomment -%}
                {%- if bg.social_proof_count != blank -%}
                  {%- assign sp_placeholder = '{count}' -%}
                  <p class="bogo-social-proof">
                    <span class="bogo-social-proof__dot"></span>
                    <span class="bogo-social-proof__text">
                      {{ bg.social_proof_text | replace: sp_placeholder, bg.social_proof_count }}
                    </span>
                  </p>
                {%- endif -%}
              </div>

            {%- elsif offer_selector_blocks.size > 0 -%}
              {%- assign os_block = offer_selector_blocks.first -%}
              {%- assign os = os_block.settings -%}
              {%- comment -%} Detect mode: if option3_label is set → quantity-tier mode (3 cards, same variant, qty multiplier + discount code). Else → legacy 2-variant mode. {%- endcomment -%}
              {%- assign os_is_tier_mode = false -%}
              {%- if os.option3_label != blank -%}{%- assign os_is_tier_mode = true -%}{%- endif -%}

              <div class="offer-selector{% if os_is_tier_mode %} offer-selector--tiers{% endif %}" id="OfferSelector" {{ os_block.shopify_attributes }}
                {%- if os_is_tier_mode -%}
                  data-mode="tiers"
                  data-tier1-qty="{{ os.option1_qty | default: 1 }}"
                  data-tier1-code="{{ os.option1_discount_code }}"
                  data-tier1-price="{{ os.option1_price }}"
                  data-tier1-compare="{{ os.option1_compare }}"
                  data-tier2-qty="{{ os.option2_qty | default: 2 }}"
                  data-tier2-code="{{ os.option2_discount_code }}"
                  data-tier2-price="{{ os.option2_price }}"
                  data-tier2-compare="{{ os.option2_compare }}"
                  data-tier3-qty="{{ os.option3_qty | default: 3 }}"
                  data-tier3-code="{{ os.option3_discount_code }}"
                  data-tier3-price="{{ os.option3_price }}"
                  data-tier3-compare="{{ os.option3_compare }}"
                {%- endif -%}
              >

                {%- comment -%} Stock badge — standalone block (preferred) or legacy embedded fallback {%- endcomment -%}
                {%- if stock_blocks.size > 0 -%}
                  {%- for block in stock_blocks -%}
                    {%- assign sb = block.settings -%}
                    {%- assign low_threshold = sb.low_threshold | default: 50 | plus: 0 -%}
                    {%- assign critical_threshold = sb.critical_threshold | default: 15 | plus: 0 -%}
                    {%- assign inv = current_variant.inventory_quantity | default: 0 -%}
                    <span class="product-stock-badge offer-selector__stock" id="ProductStockBadge" {{ block.shopify_attributes }}>
                      {%- if inv < critical_threshold -%}<span class="product-stock-badge__dot product-stock-badge__dot--red"></span><span class="product-stock-badge__text">{{ sb.critical_text | default: 'Only' }} {{ inv }} {{ sb.critical_suffix | default: 'left' }}</span>
                      {%- elsif inv < low_threshold -%}<span class="product-stock-badge__dot product-stock-badge__dot--amber"></span><span class="product-stock-badge__text">{{ sb.low_text | default: 'Low stock' }}</span>
                      {%- else -%}<span class="product-stock-badge__dot product-stock-badge__dot--green"></span><span class="product-stock-badge__text">{{ sb.in_stock_text | default: 'In stock' }}</span>
                      {%- endif -%}
                    </span>
                  {%- endfor -%}
                {%- else -%}
                  {%- assign inv = current_variant.inventory_quantity | default: 0 -%}
                  <span class="product-stock-badge offer-selector__stock" id="ProductStockBadge">
                    {%- if inv < 15 -%}<span class="product-stock-badge__dot product-stock-badge__dot--red"></span><span class="product-stock-badge__text">Only {{ inv }} left</span>
                    {%- elsif inv < 50 -%}<span class="product-stock-badge__dot product-stock-badge__dot--amber"></span><span class="product-stock-badge__text">Low stock</span>
                    {%- else -%}<span class="product-stock-badge__dot product-stock-badge__dot--green"></span><span class="product-stock-badge__text">In stock</span>
                    {%- endif -%}
                  </span>
                {%- endif -%}

                {%- if os.heading != blank -%}
                  <p class="offer-selector__heading">{{ os.heading }}</p>
                {%- endif -%}

                {%- if os_is_tier_mode -%}
                  {%- comment -%} ── 3-Tier Quantity Mode (same variant × qty + discount code) ── {%- endcomment -%}
                  {%- assign offer_has_options = false -%}
                  {%- unless product.has_only_default_variant -%}{%- assign offer_has_options = true -%}{%- endunless -%}
                  {%- assign offer_color_index = -1 -%}
                  {%- for opt in product.options_with_values -%}
                    {%- assign opt_lower = opt.name | downcase -%}
                    {%- if opt_lower == 'color' or opt_lower == 'colour' -%}{%- assign offer_color_index = forloop.index0 -%}{%- endif -%}
                  {%- endfor -%}
                  {%- assign offer_opts_count = product.options_with_values | size -%}
                  {%- capture offer_grid -%}28px{%- if offer_color_index >= 0 %} 22px{% endif %} repeat({{ offer_opts_count }}, minmax(0, 1fr)){%- endcapture -%}

                  {%- if offer_has_options -%}
                    <script id="OfferVariantColorMap" type="application/json">
                      {
                        {%- if offer_color_index >= 0 -%}
                          {%- for opt in product.options_with_values -%}
                            {%- if forloop.index0 == offer_color_index -%}
                              {%- for val in opt.values -%}
                                "{{ val | downcase | strip }}": { "hex": "{{ val.swatch.color }}", "image": "{%- if val.swatch.image -%}{{ val.swatch.image | image_url: width: 60 }}{%- endif -%}" }{% unless forloop.last %},{% endunless %}
                              {%- endfor -%}
                            {%- endif -%}
                          {%- endfor -%}
                        {%- endif -%}
                      }
                    </script>
                    <script id="OfferOptionsMap" type="application/json">
                      {
                        "colorIndex": {{ offer_color_index }},
                        "options": [
                          {%- for opt in product.options_with_values -%}
                            {
                              "name": "{{ opt.name | escape }}",
                              "index": {{ forloop.index0 }},
                              "values": [{% for v in opt.values %}"{{ v | escape }}"{% unless forloop.last %},{% endunless %}{% endfor %}]
                            }{% unless forloop.last %},{% endunless %}
                          {%- endfor -%}
                        ]
                      }
                    </script>
                  {%- endif -%}

                  {%- for n in (1..3) -%}
                    {%- assign label_key = 'option' | append: n | append: '_label' -%}
                    {%- assign sub_key = 'option' | append: n | append: '_sublabel' -%}
                    {%- assign badge_key = 'option' | append: n | append: '_badge' -%}
                    {%- assign price_key = 'option' | append: n | append: '_price' -%}
                    {%- assign compare_key = 'option' | append: n | append: '_compare' -%}
                    {%- assign qty_key = 'option' | append: n | append: '_qty' -%}
                    {%- assign tier_qty_num = os[qty_key] | default: n | plus: 0 -%}
                    {%- assign is_selected = false -%}
                    {%- if n == 2 -%}{%- assign is_selected = true -%}{%- endif -%}
                    {%- assign bonus_prefix = 'option' | append: n | append: '_bonus' -%}
                    <label class="offer-card{% if is_selected %} offer-card--selected{% endif %}" data-variant-id="{{ current_variant.id }}" data-tier="{{ n }}">
                      <span class="offer-card__radio{% if is_selected %} offer-card__radio--checked{% endif %}"></span>
                      {%- if os[badge_key] != blank -%}
                        <span class="offer-card__badge">{{ os[badge_key] }}</span>
                      {%- endif -%}
                      <span class="offer-card__body">
                        <span class="offer-card__top">
                          <span class="offer-card__label-wrap">
                            <span class="offer-card__label">{{ os[label_key] }}</span>
                            {%- if os[sub_key] != blank -%}<span class="offer-card__sublabel">{{ os[sub_key] }}</span>{%- endif -%}
                          </span>
                          <span class="offer-card__prices">
                            <span class="offer-card__price">${{ os[price_key] }}</span>
                            {%- if os[compare_key] != blank -%}<s class="offer-card__compare">${{ os[compare_key] }}</s>{%- endif -%}
                          </span>
                        </span>
                        {%- comment -%} Bonuses inside card (tier mode) — explicit keys to avoid Liquid dynamic-access quirks {%- endcomment -%}
                        {%- capture bonus_list -%}
                          {%- if n == 2 -%}
                            {%- if os.option2_bonus1 != blank -%}{{ os.option2_bonus1 }}||{%- endif -%}
                            {%- if os.option2_bonus2 != blank -%}{{ os.option2_bonus2 }}||{%- endif -%}
                            {%- if os.option2_bonus3 != blank -%}{{ os.option2_bonus3 }}||{%- endif -%}
                          {%- elsif n == 3 -%}
                            {%- if os.option3_bonus1 != blank -%}{{ os.option3_bonus1 }}||{%- endif -%}
                            {%- if os.option3_bonus2 != blank -%}{{ os.option3_bonus2 }}||{%- endif -%}
                            {%- if os.option3_bonus3 != blank -%}{{ os.option3_bonus3 }}||{%- endif -%}
                            {%- if os.option3_bonus4 != blank -%}{{ os.option3_bonus4 }}||{%- endif -%}
                            {%- if os.option3_bonus5 != blank -%}{{ os.option3_bonus5 }}||{%- endif -%}
                          {%- endif -%}
                        {%- endcapture -%}
                        {%- comment -%} Variant selectors (color/size) — ABOVE bonuses, only shown when card is selected {%- endcomment -%}
                        {%- if offer_has_options and tier_qty_num > 0 -%}
                          <span class="bogo-card__variants{% unless is_selected %} bogo-card__variants--hidden{% endunless %}">
                            <span class="bogo-card__variant-selects" style="--bogo-grid: {{ offer_grid }};">
                              <span class="bogo-card__variant-header">
                                <span></span>
                                {%- if offer_color_index >= 0 -%}<span></span>{%- endif -%}
                                {%- for opt in product.options_with_values -%}
                                  <span class="bogo-card__variant-header-label">{{ opt.name }}</span>
                                {%- endfor -%}
                              </span>
                              {%- for i in (1..tier_qty_num) -%}
                                <span class="bogo-card__variant-item">
                                  <span class="bogo-card__variant-num">{%- if tier_qty_num > 1 -%}#{{ i }}{%- endif -%}</span>
                                  {%- if offer_color_index >= 0 -%}<span class="bogo-card__color-swatch" data-select-target="{{ i }}"></span>{%- endif -%}
                                  {%- for opt in product.options_with_values -%}
                                    <select class="bogo-card__option-select" data-item-index="{{ i }}" data-option-index="{{ forloop.index0 }}" data-option-name="{{ opt.name | escape }}">
                                      {%- for val in opt.values -%}
                                        <option value="{{ val }}"{% if val == opt.selected_value %} selected{% endif %}>{{ val }}</option>
                                      {%- endfor -%}
                                    </select>
                                  {%- endfor -%}
                                </span>
                              {%- endfor -%}
                            </span>
                          </span>
                        {%- endif -%}

                        {%- assign bonuses = bonus_list | split: '||' -%}
                        {%- if bonuses.size > 0 -%}
                          <span class="offer-card__items{% unless is_selected %} bogo-card__variants--hidden{% endunless %}">
                            {%- for bonus in bonuses -%}
                              {%- assign trimmed = bonus | strip -%}
                              {%- if trimmed != blank -%}
                                {%- assign parts = trimmed | split: '|' -%}
                                <span class="offer-card__item">
                                  <span class="offer-card__item-left">
                                    <svg class="offer-card__check" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3 3 7-7" stroke="currentColor" style="color: var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    <span class="offer-card__item-name">{{ parts[0] }}</span>
                                  </span>
                                  <span class="offer-card__item-right">
                                    <span class="offer-card__item-free">FREE</span>
                                    {%- if parts[1] -%}<span class="offer-card__item-value">{{ parts[1] }}</span>{%- endif -%}
                                  </span>
                                </span>
                              {%- endif -%}
                            {%- endfor -%}
                          </span>
                        {%- endif -%}
                      </span>
                    </label>
                  {%- endfor -%}
                {%- else -%}
                  {%- comment -%} ── Legacy 2-Variant Mode ── {%- endcomment -%}
                  {%- assign v_first = product.variants.first -%}
                  {%- assign v_last  = product.variants.last  -%}

                  <label class="offer-card" data-variant-id="{{ v_first.id }}" data-offer-index="0">
                    <span class="offer-card__radio"></span>
                    <span class="offer-card__body">
                      <span class="offer-card__top">
                        <span class="offer-card__label-wrap">
                          <span class="offer-card__label">{{ os.option1_label }}</span>
                          <span class="offer-card__sublabel">{{ os.option1_sublabel }}</span>
                        </span>
                        <span class="offer-card__prices">
                          <span class="offer-card__price">{{ v_first.price | money }}</span>
                          {%- if v_first.compare_at_price > v_first.price -%}
                            <span class="offer-card__compare">{{ v_first.compare_at_price | money }}</span>
                          {%- endif -%}
                        </span>
                      </span>
                    </span>
                  </label>

                  <label class="offer-card offer-card--selected" data-variant-id="{{ v_last.id }}" data-offer-index="1">
                    <span class="offer-card__radio offer-card__radio--checked"></span>
                    {%- if os.deal_badge_text != blank -%}
                      <span class="offer-card__badge">{{ os.deal_badge_text }}</span>
                    {%- endif -%}
                    <span class="offer-card__body">
                      <span class="offer-card__top">
                        <span class="offer-card__label-wrap">
                          <span class="offer-card__label">{{ os.option2_label }}</span>
                          <span class="offer-card__sublabel">{{ os.option2_sublabel }}</span>
                        </span>
                        <span class="offer-card__prices">
                          <span class="offer-card__price">{{ v_last.price | money }}</span>
                          {%- if v_last.compare_at_price > v_last.price -%}
                            <span class="offer-card__compare">{{ v_last.compare_at_price | money }}</span>
                          {%- endif -%}
                        </span>
                      </span>
                      <span class="offer-card__items">
                        {%- for i in (1..4) -%}
                          {%- assign name_key  = 'item' | append: i | append: '_name' -%}
                          {%- assign value_key = 'item' | append: i | append: '_value' -%}
                          {%- assign free_key  = 'item' | append: i | append: '_free_label' -%}
                          {%- assign item_name  = os[name_key] -%}
                          {%- assign item_value = os[value_key] -%}
                          {%- assign item_free  = os[free_key] -%}
                          {%- if item_name != blank -%}
                            <span class="offer-card__item">
                              <span class="offer-card__item-left">
                                <svg class="offer-card__check" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3 3 7-7" stroke="currentColor" style="color: var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <span class="offer-card__item-name">{{ item_name }}</span>
                              </span>
                              <span class="offer-card__item-right">
                                {%- if item_free != blank -%}<span class="offer-card__item-free">{{ item_free }}</span>{%- endif -%}
                                {%- if item_value != blank -%}<span class="offer-card__item-value">{{ item_value }}</span>{%- endif -%}
                              </span>
                            </span>
                          {%- endif -%}
                        {%- endfor -%}
                      </span>
                    </span>
                  </label>
                {%- endif -%}

                {%- if os.show_trust_line and os.trust_text != blank -%}
                  <p class="offer-selector__trust">{{ os.trust_text }}</p>
                {%- endif -%}
              </div>
            {%- else -%}
            <div class="product-options">
              {%- for option in product.options_with_values -%}
                {%- assign is_color = false -%}
                {%- assign option_lower = option.name | downcase -%}
                {%- if option_lower == 'color' or option_lower == 'colour' or option_lower == 'colore' or option_lower == 'couleur' -%}
                  {%- assign is_color = true -%}
                {%- endif -%}
                <div style="margin-bottom:1.5rem;">
                  <div class="option-label-row">
                    <span class="option-label">{% if is_color %}Color: <span id="SelectedColorLabel">{{ option.selected_value }}</span>{% else %}{{ option.name }}{% endif %}</span>
                    {%- if is_color -%}
                      {%- assign inv = current_variant.inventory_quantity | default: 0 -%}
                      <span class="product-stock-badge" id="ProductStockBadge">
                        {%- if inv < 15 -%}<span class="product-stock-badge__dot product-stock-badge__dot--red"></span><span class="product-stock-badge__text">Only {{ inv }} left</span>
                        {%- elsif inv < 50 -%}<span class="product-stock-badge__dot product-stock-badge__dot--amber"></span><span class="product-stock-badge__text">Low stock</span>
                        {%- else -%}<span class="product-stock-badge__dot product-stock-badge__dot--green"></span><span class="product-stock-badge__text">In stock</span>
                        {%- endif -%}
                      </span>
                    {%- endif -%}
                  </div>
                  <div class="option-values{% if is_color %} option-values--color{% endif %}">
                    {%- for value in option.values -%}
                      {%- if is_color -%}
                        <button
                          type="button"
                          class="option-btn option-btn--color{% if option.selected_value == value %} active{% endif %}"
                          data-option="{{ option.name }}"
                          data-value="{{ value }}"
                          data-is-color="true"
                          aria-label="{{ option.name }}: {{ value }}"
                          title="{{ value }}"
                        >
                          {%- if value.swatch.image -%}
                            <img src="{{ value.swatch.image | image_url: width: 120 }}" alt="{{ value | escape }}" width="60" height="60" loading="lazy" class="color-swatch-img">
                          {%- elsif value.swatch.color -%}
                            <span class="color-swatch-img" style="background-color: {{ value.swatch.color }};"></span>
                          {%- else -%}
                            {%- assign val_lower = value | downcase | strip -%}
                            {%- assign hex_fallback = '' -%}
                            {%- case val_lower -%}
                              {%- when 'nude' -%}{%- assign hex_fallback = '#E4B590' -%}
                              {%- when 'beige' -%}{%- assign hex_fallback = '#E4B590' -%}
                              {%- when 'black' -%}{%- assign hex_fallback = '#1A1A1A' -%}
                              {%- when 'white' -%}{%- assign hex_fallback = '#F5F5F5' -%}
                              {%- when 'gold' -%}{%- assign hex_fallback = '#C4944C' -%}
                              {%- when 'silver' -%}{%- assign hex_fallback = '#C0C0C0' -%}
                              {%- when 'rose gold' -%}{%- assign hex_fallback = '#B76E79' -%}
                              {%- when 'rose' -%}{%- assign hex_fallback = '#B76E79' -%}
                              {%- when 'pink' -%}{%- assign hex_fallback = '#FFC0CB' -%}
                              {%- when 'red' -%}{%- assign hex_fallback = '#D0342C' -%}
                              {%- when 'blue' -%}{%- assign hex_fallback = '#2C5282' -%}
                              {%- when 'navy' -%}{%- assign hex_fallback = '#1A365D' -%}
                              {%- when 'green' -%}{%- assign hex_fallback = '#38A169' -%}
                              {%- when 'gray' -%}{%- assign hex_fallback = '#718096' -%}
                              {%- when 'grey' -%}{%- assign hex_fallback = '#718096' -%}
                              {%- when 'brown' -%}{%- assign hex_fallback = '#795548' -%}
                              {%- when 'tan' -%}{%- assign hex_fallback = '#D2B48C' -%}
                              {%- when 'cream' -%}{%- assign hex_fallback = '#FFFDD0' -%}
                            {%- endcase -%}
                            {%- if hex_fallback != '' -%}
                              <span class="color-swatch-img" style="background-color: {{ hex_fallback }};"></span>
                            {%- else -%}
                              <span class="color-swatch-img color-swatch-img--fallback">{{ value | slice: 0, 2 }}</span>
                            {%- endif -%}
                          {%- endif -%}
                        </button>
                      {%- else -%}
                        <button
                          type="button"
                          class="option-btn{% if option.selected_value == value %} active{% endif %}"
                          data-option="{{ option.name }}"
                          data-value="{{ value }}"
                          data-is-color="false"
                          aria-label="{{ option.name }}: {{ value }}"
                        >
                          {{ value }}
                        </button>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
            {%- endif -%}
          {%- endunless -%}

          {%- comment -%} 7b. Urgency Counter (standalone block) — pulsing dot style, tight to CTA {%- endcomment -%}
          {%- for block in urgency_blocks -%}
            {%- assign uc = block.settings -%}
            {%- assign placeholder = '{count}' -%}
            <p class="urgency-counter" {{ block.shopify_attributes }}>
              {%- if uc.icon != blank -%}
                <span class="urgency-counter__icon">{{ uc.icon }}</span>
              {%- else -%}
                <span class="urgency-counter__dot"></span>
              {%- endif -%}
              <span class="urgency-counter__text">{{ uc.text | replace: placeholder, uc.count }}</span>
            </p>
          {%- endfor -%}

          {%- comment -%} 8. Add to Cart {%- endcomment -%}
          <div class="product-atc">
            <button
              type="submit"
              class="product-atc-btn"
              data-variant-id="{{ current_variant.id }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}

        {%- comment -%} 9. Delivery Estimate {%- endcomment -%}
        {%- if section.settings.show_delivery_estimate -%}
          <div class="product-delivery-estimate" id="ProductDeliveryEstimate"
               data-business-days="{{ section.settings.delivery_business_days }}">
          </div>
        {%- endif -%}

        {%- comment -%} 10. Payment Icons {%- endcomment -%}
        {%- if section.settings.show_payment_icons -%}
          <div class="product-payment-icons">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} 10b. Trust Badges — Hormozi-optimized: social proof, risk reversal, friction kill, time delay kill {%- endcomment -%}
        {%- liquid
          assign jdg_data = product.metafields.judgeme.review_widget_data.value
          assign jdg_count = jdg_data.number_of_reviews | default: 0
          assign jdg_rating = jdg_data.average_rating | default: 0
          assign jdg_rating_display = jdg_rating | times: 1.0 | round: 1
        -%}
        <div class="product-trust-badges">
          <div class="product-trust-badge">
            <span class="product-trust-badge__emoji">⭐</span>
            <span>{%- if jdg_count > 0 -%}{{ jdg_rating_display }} · {{ jdg_count }}<br>Reviews{%- else -%}Loved by<br>Customers{%- endif -%}</span>
          </div>
          <div class="product-trust-badge">
            <span class="product-trust-badge__emoji">🛡️</span>
            <span>60-Day<br>Money-Back</span>
          </div>
          <div class="product-trust-badge">
            <span class="product-trust-badge__emoji">🚚</span>
            <span>Free US<br>Shipping</span>
          </div>
          <div class="product-trust-badge">
            <span class="product-trust-badge__emoji">⚡</span>
            <span>Ships Within<br>48 Hours</span>
          </div>
        </div>

        {%- comment -%} 10b-2. See It In Action — inline autoplay video strip {%- endcomment -%}
        {%- if video_showcase_blocks.size > 0 -%}
          {%- for block in video_showcase_blocks -%}
            {%- liquid
              assign vs_count = 0
              for i in (1..4)
                assign vs_vkey = 'video_' | append: i
                assign vs_ukey = 'video_url_' | append: i
                assign vs_v = block.settings[vs_vkey]
                assign vs_u = block.settings[vs_ukey]
                if vs_v != blank or vs_u != blank
                  assign vs_count = vs_count | plus: 1
                endif
              endfor
            -%}
            {%- if vs_count > 0 -%}
              <div class="product-video-strip" id="ProductVideoStrip-{{ block.id }}" {{ block.shopify_attributes }}>
                <p class="product-video-strip__heading">{{ block.settings.heading | default: 'See it in action' }}</p>
                <div class="product-video-strip__scroll">
                  {%- for i in (1..4) -%}
                    {%- assign vs_vkey = 'video_' | append: i -%}
                    {%- assign vs_ukey = 'video_url_' | append: i -%}
                    {%- assign vs_v = block.settings[vs_vkey] -%}
                    {%- assign vs_u = block.settings[vs_ukey] -%}
                    {%- if vs_v != blank or vs_u != blank -%}
                      {%- assign vs_src = '' -%}
                      {%- if vs_v != blank -%}
                        {%- for source in vs_v.sources -%}
                          {%- if source.format == 'mp4' -%}{%- assign vs_src = source.url -%}{%- endif -%}
                        {%- endfor -%}
                      {%- elsif vs_u != blank -%}
                        {%- assign vs_src = vs_u -%}
                      {%- endif -%}
                      <div class="product-video-strip__item" data-video-src="{{ vs_src }}">
                        <video
                          muted
                          loop
                          playsinline
                          preload="none"
                          poster=""
                        >
                          <source data-src="{{ vs_src }}" type="video/mp4">
                        </video>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>

              <style>
                .product-video-strip {
                  margin: 1.25rem 0 0.5rem;
                }
                .product-video-strip__heading {
                  font-family: var(--font-heading, sans-serif);
                  font-size: 0.8125rem;
                  font-weight: 700;
                  letter-spacing: 0.06em;
                  text-transform: uppercase;
                  color: var(--color-text-muted, #6B7B8D);
                  margin: 0 0 0.6rem;
                }
                .product-video-strip__scroll {
                  display: flex;
                  gap: 10px;
                  overflow-x: auto;
                  scrollbar-width: none;
                  -ms-overflow-style: none;
                  padding-bottom: 4px;
                }
                .product-video-strip__scroll::-webkit-scrollbar { display: none; }
                .product-video-strip__item {
                  flex: 0 0 auto;
                  width: 100px;
                  aspect-ratio: 9/16;
                  border-radius: 10px;
                  overflow: hidden;
                  background: linear-gradient(135deg, #e8ecf0, #c9d2da);
                  box-shadow: 0 1px 4px rgba(0,0,0,0.08);
                }
                .product-video-strip__item video {
                  width: 100%;
                  height: 100%;
                  object-fit: cover;
                  display: block;
                  background: #000;
                }
                @media (min-width: 768px) {
                  .product-video-strip__item { width: 110px; }
                }
              </style>

              <script>
                (function() {
                  var strip = document.getElementById('ProductVideoStrip-{{ block.id }}');
                  if (!strip) return;
                  var items = strip.querySelectorAll('.product-video-strip__item');
                  var observer = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                      var video = entry.target.querySelector('video');
                      if (!video) return;
                      if (entry.isIntersecting) {
                        /* Lazy-load src on first intersection */
                        var source = video.querySelector('source[data-src]');
                        if (source && source.dataset.src) {
                          source.src = source.dataset.src;
                          source.removeAttribute('data-src');
                          video.load();
                        }
                        video.play().catch(function() {});
                      } else {
                        video.pause();
                      }
                    });
                  }, { threshold: 0.3 });
                  items.forEach(function(item) { observer.observe(item); });
                })();
              </script>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {%- comment -%} 10b-3. Value Stack card (Hormozi offer stack) {%- endcomment -%}
        {%- assign value_stack_blocks = section.blocks | where: 'type', 'value_stack' -%}
        {%- for block in value_stack_blocks -%}
          {%- assign vs = block.settings -%}
          <div class="offer-value-stack" {{ block.shopify_attributes }}>
            <p class="offer-value-stack__heading">{{ vs.heading }}</p>
            <table class="offer-value-stack__items">
              {%- for n in (1..6) -%}
                {%- assign key = 'item' | append: n -%}
                {%- assign raw = vs[key] -%}
                {%- if raw != blank -%}
                  {%- assign parts = raw | split: '|' -%}
                  <tr>
                    <td>✅ {{ parts[0] }}</td>
                    <td class="offer-value-stack__val">{{ parts[1] }}</td>
                  </tr>
                {%- endif -%}
              {%- endfor -%}
            </table>
            <hr class="offer-value-stack__sep">
            <table class="offer-value-stack__totals">
              <tr><td>Total Value</td><td class="offer-value-stack__val"><s>{{ vs.total_value }}</s></td></tr>
              <tr class="offer-value-stack__price"><td>Your Price Today</td><td class="offer-value-stack__val">{{ vs.your_price }}</td></tr>
              <tr class="offer-value-stack__save"><td>You Save</td><td class="offer-value-stack__val">{{ vs.you_save }}</td></tr>
            </table>
          </div>
        {%- endfor -%}

        {%- comment -%} 10b-4. Guarantee Promise (Hormozi risk reversal) {%- endcomment -%}
        {%- assign guarantee_blocks = section.blocks | where: 'type', 'guarantee_promise' -%}
        {%- for block in guarantee_blocks -%}
          {%- assign gp = block.settings -%}
          <div class="offer-guarantee" {{ block.shopify_attributes }}>
            <p class="offer-guarantee__label">{{ gp.label }}</p>
            <p class="offer-guarantee__headline">{{ gp.headline }}</p>
            <div class="offer-guarantee__body">{{ gp.body }}</div>
          </div>
        {%- endfor -%}

        {%- comment -%} 10c. Bundle Deals {%- endcomment -%}
        {%- assign bundle_blocks = section.blocks | where: 'type', 'bundle_deals' -%}
        {%- if bundle_blocks.size > 0 -%}
          <div class="product-bundle-deals">
            {%- for block in bundle_blocks -%}
              {%- assign bd = block.settings -%}
              {%- assign bd_p2 = bd.product_2 -%}
              {%- assign bd_p3 = bd.product_3 -%}
              {%- assign bd_p4 = bd.product_4 -%}

              {%- comment -%} Bundle price overrides (in cents) — set in block settings as dollars e.g. "24.00" {%- endcomment -%}
              {%- assign bd_bp1_cents = bd.bundle_price_1 | times: 100 | round -%}
              {%- assign bd_bp2_cents = bd.bundle_price_2 | times: 100 | round -%}
              {%- assign bd_bp3_cents = bd.bundle_price_3 | times: 100 | round -%}
              {%- assign bd_bp4_cents = bd.bundle_price_4 | times: 100 | round -%}

              {%- comment -%} Pre-calculate totals — use bundle price override if set {%- endcomment -%}
              {%- if bd_bp1_cents > 0 -%}
                {%- assign bd_total = bd_bp1_cents -%}
                {%- assign bd_compare = current_variant.price -%}
              {%- else -%}
                {%- assign bd_total = current_variant.price -%}
                {%- if current_variant.compare_at_price > current_variant.price -%}
                  {%- assign bd_compare = current_variant.compare_at_price -%}
                {%- else -%}
                  {%- assign bd_compare = current_variant.price -%}
                {%- endif -%}
              {%- endif -%}
              {%- if bd_p2 != blank -%}
                {%- if bd_bp2_cents > 0 -%}
                  {%- assign bd_total = bd_total | plus: bd_bp2_cents -%}
                  {%- assign bd_compare = bd_compare | plus: bd_p2.price -%}
                {%- else -%}
                  {%- assign bd_total = bd_total | plus: bd_p2.price -%}
                  {%- if bd_p2.compare_at_price > bd_p2.price -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p2.compare_at_price -%}
                  {%- else -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p2.price -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endif -%}
              {%- if bd_p3 != blank -%}
                {%- if bd_bp3_cents > 0 -%}
                  {%- assign bd_total = bd_total | plus: bd_bp3_cents -%}
                  {%- assign bd_compare = bd_compare | plus: bd_p3.price -%}
                {%- else -%}
                  {%- assign bd_total = bd_total | plus: bd_p3.price -%}
                  {%- if bd_p3.compare_at_price > bd_p3.price -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p3.compare_at_price -%}
                  {%- else -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p3.price -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endif -%}
              {%- if bd_p4 != blank -%}
                {%- if bd_bp4_cents > 0 -%}
                  {%- assign bd_total = bd_total | plus: bd_bp4_cents -%}
                  {%- assign bd_compare = bd_compare | plus: bd_p4.price -%}
                {%- else -%}
                  {%- assign bd_total = bd_total | plus: bd_p4.price -%}
                  {%- if bd_p4.compare_at_price > bd_p4.price -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p4.compare_at_price -%}
                  {%- else -%}
                    {%- assign bd_compare = bd_compare | plus: bd_p4.price -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endif -%}

              <bundle-deals class="bundle-deals" {{ block.shopify_attributes }}>
                <p class="product-bundle-deals__heading">{{ bd.heading | default: 'Build Your Bundle' }}</p>

                {%- comment -%} Thumbnails row {%- endcomment -%}
                <div class="bundle-deals__media">
                  <div class="bundle-deals__media-item" data-media-index="0" id="bd-thumb-{{ block.id }}-0">
                    {%- if current_variant.featured_media -%}
                      <img src="{{ current_variant.featured_media | image_url: width: 144 }}" alt="{{ product.title | escape }}" width="72" height="72" loading="lazy">
                    {%- elsif product.featured_media -%}
                      <img src="{{ product.featured_media | image_url: width: 144 }}" alt="{{ product.title | escape }}" width="72" height="72" loading="lazy">
                    {%- endif -%}
                  </div>
                  {%- if bd_p2 != blank -%}
                    <div class="bundle-deals__media-item" data-media-index="1">
                      {%- if bd_p2.featured_media -%}
                        <img src="{{ bd_p2.featured_media | image_url: width: 144 }}" alt="{{ bd_p2.title | escape }}" width="72" height="72" loading="lazy">
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- if bd_p3 != blank -%}
                    <div class="bundle-deals__media-item" data-media-index="2">
                      {%- if bd_p3.featured_media -%}
                        <img src="{{ bd_p3.featured_media | image_url: width: 144 }}" alt="{{ bd_p3.title | escape }}" width="72" height="72" loading="lazy">
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- if bd_p4 != blank -%}
                    <div class="bundle-deals__media-item" data-media-index="3">
                      {%- if bd_p4.featured_media -%}
                        <img src="{{ bd_p4.featured_media | image_url: width: 144 }}" alt="{{ bd_p4.title | escape }}" width="72" height="72" loading="lazy">
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>

                {%- comment -%} WAS / TODAY summary {%- endcomment -%}
                {%- if bd_compare > bd_total -%}
                  <p class="bundle-deals__summary">
                    <span class="bundle-deals__summary-was">WAS: {{ bd_compare | money }}</span>
                    <span class="bundle-deals__summary-today">TODAY: {{ bd_total | money }}</span>
                  </p>
                {%- endif -%}

                {%- comment -%} Product rows — first item always = current page product {%- endcomment -%}
                <div class="bundle-deals__product" data-product-index="0">
                  <div class="bundle-deals__checkbox-container">
                    <input type="checkbox" class="bundle-deals__checkbox" id="bd-check-{{ block.id }}-0"
                      data-variant-id="{{ current_variant.id }}"
                      data-price="{% if bd_bp1_cents > 0 %}{{ bd_bp1_cents }}{% else %}{{ current_variant.price }}{% endif %}"
                      data-compare-price="{{ current_variant.price }}"
                      checked disabled>
                    <label class="bundle-deals__checkbox-label" for="bd-check-{{ block.id }}-0">
                      <svg viewBox="0 0 20 20" class="checkmark-checked" aria-hidden="true"><path fill="currentColor" d="M2 10a8 8 0 1 1 16 0A8 8 0 0 1 2 10zm11.78-2.97a.75.75 0 0 0-1.06-1.06L9 9.69 7.28 7.97a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l4.25-4.25z"/></svg>
                      <svg viewBox="0 0 20 20" class="checkmark-unchecked" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2z"/></svg>
                      <p class="bundle-deals__title">{{ product.title }}</p>
                    </label>
                    <div class="bundle-deals__prices">
                      {%- if bd_bp1_cents > 0 -%}
                        <span class="bundle-deals__compare-price" id="bd-cprice-{{ block.id }}-0">{{ current_variant.price | money }}</span>
                        <span class="bundle-deals__price" id="bd-price-{{ block.id }}-0">{{ bd_bp1_cents | money }}</span>
                      {%- else -%}
                        {%- if current_variant.compare_at_price > current_variant.price -%}
                          <span class="bundle-deals__compare-price" id="bd-cprice-{{ block.id }}-0">{{ current_variant.compare_at_price | money }}</span>
                        {%- else -%}
                          <span class="bundle-deals__compare-price" id="bd-cprice-{{ block.id }}-0" style="display:none"></span>
                        {%- endif -%}
                        <span class="bundle-deals__price" id="bd-price-{{ block.id }}-0">{{ current_variant.price | money }}</span>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
                {%- if bd_p2 != blank -%}
                  {%- assign bp_variant = bd_p2.selected_or_first_available_variant -%}
                  <div class="bundle-deals__product" data-product-index="1">
                    <div class="bundle-deals__checkbox-container">
                      <input type="checkbox" class="bundle-deals__checkbox" id="bd-check-{{ block.id }}-1" data-variant-id="{{ bp_variant.id }}" data-price="{% if bd_bp2_cents > 0 %}{{ bd_bp2_cents }}{% else %}{{ bp_variant.price }}{% endif %}" data-compare-price="{{ bp_variant.price }}" checked>
                      <label class="bundle-deals__checkbox-label" for="bd-check-{{ block.id }}-1">
                        <svg viewBox="0 0 20 20" class="checkmark-checked" aria-hidden="true"><path fill="currentColor" d="M2 10a8 8 0 1 1 16 0A8 8 0 0 1 2 10zm11.78-2.97a.75.75 0 0 0-1.06-1.06L9 9.69 7.28 7.97a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l4.25-4.25z"/></svg>
                        <svg viewBox="0 0 20 20" class="checkmark-unchecked" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2z"/></svg>
                        <p class="bundle-deals__title">{{ bd_p2.title }}</p>
                      </label>
                      <div class="bundle-deals__prices">
                        {%- if bd_bp2_cents > 0 -%}
                          <span class="bundle-deals__compare-price">{{ bp_variant.price | money }}</span>
                          <span class="bundle-deals__price">{{ bd_bp2_cents | money }}</span>
                        {%- else -%}
                          {%- if bp_variant.compare_at_price > bp_variant.price -%}<span class="bundle-deals__compare-price">{{ bp_variant.compare_at_price | money }}</span>{%- endif -%}
                          <span class="bundle-deals__price">{{ bp_variant.price | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    {%- if bd_p2.variants.size > 1 -%}
                      <div class="bundle-deals__variant-selects">
                        {%- for option in bd_p2.options_with_values -%}
                          <div class="select"><select data-product-index="1" data-option-index="{{ forloop.index0 }}" aria-label="{{ option.name }}">{%- for value in option.values -%}<option value="{{ value | escape }}"{% if option.selected_value == value %} selected{% endif %}>{{ value }}</option>{%- endfor -%}</select><svg class="icon-caret" viewBox="0 0 10 6" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M1 1l4 4 4-4"/></svg></div>
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
                {%- if bd_p3 != blank -%}
                  {%- assign bp_variant = bd_p3.selected_or_first_available_variant -%}
                  <div class="bundle-deals__product" data-product-index="2">
                    <div class="bundle-deals__checkbox-container">
                      <input type="checkbox" class="bundle-deals__checkbox" id="bd-check-{{ block.id }}-2" data-variant-id="{{ bp_variant.id }}" data-price="{% if bd_bp3_cents > 0 %}{{ bd_bp3_cents }}{% else %}{{ bp_variant.price }}{% endif %}" data-compare-price="{{ bp_variant.price }}" checked>
                      <label class="bundle-deals__checkbox-label" for="bd-check-{{ block.id }}-2">
                        <svg viewBox="0 0 20 20" class="checkmark-checked" aria-hidden="true"><path fill="currentColor" d="M2 10a8 8 0 1 1 16 0A8 8 0 0 1 2 10zm11.78-2.97a.75.75 0 0 0-1.06-1.06L9 9.69 7.28 7.97a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l4.25-4.25z"/></svg>
                        <svg viewBox="0 0 20 20" class="checkmark-unchecked" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2z"/></svg>
                        <p class="bundle-deals__title">{{ bd_p3.title }}</p>
                      </label>
                      <div class="bundle-deals__prices">
                        {%- if bd_bp3_cents > 0 -%}
                          <span class="bundle-deals__compare-price">{{ bp_variant.price | money }}</span>
                          <span class="bundle-deals__price">{{ bd_bp3_cents | money }}</span>
                        {%- else -%}
                          {%- if bp_variant.compare_at_price > bp_variant.price -%}<span class="bundle-deals__compare-price">{{ bp_variant.compare_at_price | money }}</span>{%- endif -%}
                          <span class="bundle-deals__price">{{ bp_variant.price | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    {%- if bd_p3.variants.size > 1 -%}
                      <div class="bundle-deals__variant-selects">
                        {%- for option in bd_p3.options_with_values -%}
                          <div class="select"><select data-product-index="2" data-option-index="{{ forloop.index0 }}" aria-label="{{ option.name }}">{%- for value in option.values -%}<option value="{{ value | escape }}"{% if option.selected_value == value %} selected{% endif %}>{{ value }}</option>{%- endfor -%}</select><svg class="icon-caret" viewBox="0 0 10 6" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M1 1l4 4 4-4"/></svg></div>
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
                {%- if bd_p4 != blank -%}
                  {%- assign bp_variant = bd_p4.selected_or_first_available_variant -%}
                  <div class="bundle-deals__product" data-product-index="3">
                    <div class="bundle-deals__checkbox-container">
                      <input type="checkbox" class="bundle-deals__checkbox" id="bd-check-{{ block.id }}-3" data-variant-id="{{ bp_variant.id }}" data-price="{% if bd_bp4_cents > 0 %}{{ bd_bp4_cents }}{% else %}{{ bp_variant.price }}{% endif %}" data-compare-price="{{ bp_variant.price }}" checked>
                      <label class="bundle-deals__checkbox-label" for="bd-check-{{ block.id }}-3">
                        <svg viewBox="0 0 20 20" class="checkmark-checked" aria-hidden="true"><path fill="currentColor" d="M2 10a8 8 0 1 1 16 0A8 8 0 0 1 2 10zm11.78-2.97a.75.75 0 0 0-1.06-1.06L9 9.69 7.28 7.97a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l4.25-4.25z"/></svg>
                        <svg viewBox="0 0 20 20" class="checkmark-unchecked" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2z"/></svg>
                        <p class="bundle-deals__title">{{ bd_p4.title }}</p>
                      </label>
                      <div class="bundle-deals__prices">
                        {%- if bd_bp4_cents > 0 -%}
                          <span class="bundle-deals__compare-price">{{ bp_variant.price | money }}</span>
                          <span class="bundle-deals__price">{{ bd_bp4_cents | money }}</span>
                        {%- else -%}
                          {%- if bp_variant.compare_at_price > bp_variant.price -%}<span class="bundle-deals__compare-price">{{ bp_variant.compare_at_price | money }}</span>{%- endif -%}
                          <span class="bundle-deals__price">{{ bp_variant.price | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    {%- if bd_p4.variants.size > 1 -%}
                      <div class="bundle-deals__variant-selects">
                        {%- for option in bd_p4.options_with_values -%}
                          <div class="select"><select data-product-index="3" data-option-index="{{ forloop.index0 }}" aria-label="{{ option.name }}">{%- for value in option.values -%}<option value="{{ value | escape }}"{% if option.selected_value == value %} selected{% endif %}>{{ value }}</option>{%- endfor -%}</select><svg class="icon-caret" viewBox="0 0 10 6" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" d="M1 1l4 4 4-4"/></svg></div>
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                <div class="bundle-deals__divider"></div>

                <button type="button" class="bundle-deals__btn" data-bundle-block-id="{{ block.id }}"{% if bd.discount_code != blank %} data-discount-code="{{ bd.discount_code | escape }}"{% endif %}>
                  {{ bd.button_label | default: 'Add Bundle to Cart' }}
                </button>
                <p class="bundle-deals__error" id="bd-error-{{ block.id }}"></p>

              </bundle-deals>
            {%- endfor -%}
          </div>

          <script>
          (function() {
            var form    = document.getElementById('ProductForm');
            var addBtn  = form && form.querySelector('.product-atc-btn');
            if (!addBtn) return;

            var variants = JSON.parse(form.dataset.variants || '[]');

            function fmtMoney(cents) {
              var fmt = (window.Shopify && window.Shopify.money_format) || '${{amount}}';
              return fmt.replace('{{amount}}', (cents / 100).toFixed(2))
                        .replace('{{amount_no_decimals}}', Math.round(cents / 100))
                        .replace('{{amount_with_comma_separator}}', (cents / 100).toFixed(2).replace('.', ','));
            }

            function syncBundle(variant) {
              document.querySelectorAll('.bundle-deals').forEach(function(bundle) {
                var blockId = bundle.querySelector('.bundle-deals__btn').dataset.bundleBlockId;

                // Update first checkbox data
                var cb0 = bundle.querySelector('[data-product-index="0"] .bundle-deals__checkbox');
                if (cb0) {
                  cb0.dataset.variantId    = variant.id;
                  cb0.dataset.price        = variant.price;
                  cb0.dataset.comparePrice = variant.compare_at_price > variant.price ? variant.compare_at_price : variant.price;
                }

                // Update first product price display
                var priceEl  = document.getElementById('bd-price-'  + blockId + '-0');
                var cpriceEl = document.getElementById('bd-cprice-' + blockId + '-0');
                if (priceEl)  priceEl.textContent = fmtMoney(variant.price);
                if (cpriceEl) {
                  if (variant.compare_at_price > variant.price) {
                    cpriceEl.textContent  = fmtMoney(variant.compare_at_price);
                    cpriceEl.style.display = '';
                  } else {
                    cpriceEl.textContent  = '';
                    cpriceEl.style.display = 'none';
                  }
                }

                // Update thumbnail
                var thumb = document.querySelector('#bd-thumb-' + blockId + '-0 img');
                if (thumb && variant.featured_image && variant.featured_image.src) {
                  var src = variant.featured_image.src;
                  thumb.src = src.replace(/(\.[a-z]+)(\?|$)/, '_144x$1$2');
                }

              });
            }

            // Watch for variant changes via ATC button attribute mutation
            new MutationObserver(function(mutations) {
              mutations.forEach(function(m) {
                if (m.attributeName === 'data-variant-id') {
                  var vid     = parseInt(addBtn.dataset.variantId);
                  var variant = variants.find(function(v) { return v.id === vid; });
                  if (variant) syncBundle(variant);
                }
              });
            }).observe(addBtn, { attributes: true, attributeFilter: ['data-variant-id'] });

            // Add Bundle to Cart handler
            document.querySelectorAll('.bundle-deals__btn').forEach(function(btn) {
              btn.addEventListener('click', async function() {
                var bundle  = btn.closest('bundle-deals');
                var errorEl = bundle && bundle.querySelector('.bundle-deals__error');
                if (errorEl) { errorEl.textContent = ''; errorEl.classList.remove('is-visible'); }

                var items = [];
                bundle && bundle.querySelectorAll('.bundle-deals__checkbox').forEach(function(cb) {
                  if (cb.checked && cb.dataset.variantId) {
                    items.push({ id: parseInt(cb.dataset.variantId), quantity: 1 });
                  }
                });
                if (!items.length) return;

                btn.disabled    = true;
                btn.textContent = 'Adding…';

                try {
                  var res = await fetch('/cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: items })
                  });
                  if (!res.ok) { var e = await res.json().catch(function(){return{};}); throw new Error(e.description || 'Could not add to cart.'); }

                  // Apply discount code silently to session if set
                  var discountCode = btn.dataset.discountCode;
                  if (discountCode) {
                    await fetch('/discount/' + encodeURIComponent(discountCode), { redirect: 'manual' }).catch(function(){});
                  }

                  if (window.MammothTheme) {
                    await window.MammothTheme.fetchCart();
                    if (window.MammothTheme.openCart)  window.MammothTheme.openCart();
                    if (window.MammothTheme.showToast) window.MammothTheme.showToast('Bundle added to cart!');
                  } else { window.location.href = '/cart'; }
                } catch(err) {
                  if (errorEl) { errorEl.textContent = err.message; errorEl.classList.add('is-visible'); }
                } finally {
                  btn.disabled    = false;
                  btn.textContent = btn.dataset.label || 'Add Bundle to Cart';
                }
              });
            });
          })();
          </script>
        {%- endif -%}

        {%- comment -%} 11. Upsell Component {%- endcomment -%}
        {%- if section.settings.show_upsell and section.settings.upsell_product != blank -%}
          <div class="product-upsell">
            <p class="product-upsell-heading">{{ section.settings.upsell_heading }}</p>
            {%- assign upsell = section.settings.upsell_product -%}
            {%- assign upsell_variant = upsell.selected_or_first_available_variant -%}
            <div class="product-upsell-card">
              <a href="{{ upsell.url }}" class="product-upsell-image">
                {%- if upsell.featured_media -%}
                  <img
                    src="{{ upsell.featured_media | image_url: width: 200 }}"
                    alt="{{ upsell.featured_media.alt | default: upsell.title | escape }}"
                    width="100" height="100"
                    loading="lazy"
                  >
                {%- endif -%}
              </a>
              <div class="product-upsell-details">
                <a href="{{ upsell.url }}" class="product-upsell-title">{{ upsell.title }}</a>
                <p class="product-upsell-price">
                  {%- if upsell_variant.compare_at_price > upsell_variant.price -%}
                    <s style="color:var(--color-text-muted);margin-right:.25rem;font-size:0.8rem;">
                      {{ upsell_variant.compare_at_price | money }}
                    </s>
                  {%- endif -%}
                  {{ upsell_variant.price | money }}
                </p>
              </div>
              <button
                type="button"
                class="product-upsell-add"
                data-upsell-variant-id="{{ upsell_variant.id }}"
                {% unless upsell_variant.available %}disabled{% endunless %}
              >
                {%- if upsell_variant.available -%}+{%- else -%}Sold Out{%- endif -%}
              </button>
            </div>
            {%- if section.settings.upsell_product_2 != blank -%}
              {%- assign upsell2 = section.settings.upsell_product_2 -%}
              {%- assign upsell2_variant = upsell2.selected_or_first_available_variant -%}
              <div class="product-upsell-card">
                <a href="{{ upsell2.url }}" class="product-upsell-image">
                  {%- if upsell2.featured_media -%}
                    <img
                      src="{{ upsell2.featured_media | image_url: width: 200 }}"
                      alt="{{ upsell2.featured_media.alt | default: upsell2.title | escape }}"
                      width="100" height="100"
                      loading="lazy"
                    >
                  {%- endif -%}
                </a>
                <div class="product-upsell-details">
                  <a href="{{ upsell2.url }}" class="product-upsell-title">{{ upsell2.title }}</a>
                  <p class="product-upsell-price">
                    {%- if upsell2_variant.compare_at_price > upsell2_variant.price -%}
                      <s style="color:var(--color-text-muted);margin-right:.25rem;font-size:0.8rem;">
                        {{ upsell2_variant.compare_at_price | money }}
                      </s>
                    {%- endif -%}
                    {{ upsell2_variant.price | money }}
                  </p>
                </div>
                <button
                  type="button"
                  class="product-upsell-add"
                  data-upsell-variant-id="{{ upsell2_variant.id }}"
                  {% unless upsell2_variant.available %}disabled{% endunless %}
                >
                  {%- if upsell2_variant.available -%}+{%- else -%}Sold Out{%- endif -%}
                </button>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

      </div>
    </div>

  </div>
</div>

