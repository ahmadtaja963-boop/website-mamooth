{%- comment -%} ── Video Hero ── {%- endcomment -%}
{%- if video_hero_blocks.size > 0 -%}
  {%- for block in video_hero_blocks -%}
    <div class="product-video-hero" {{ block.shopify_attributes }}>
      {%- assign has_shopify_video = false -%}
      {%- assign has_ext_video = false -%}
      {%- if block.settings.shopify_video != blank -%}{%- assign has_shopify_video = true -%}{%- endif -%}
      {%- if block.settings.video_url != blank -%}{%- assign has_ext_video = true -%}{%- endif -%}
      {%- if has_shopify_video or has_ext_video -%}
        <div class="product-video-hero__media">
          {%- if has_shopify_video -%}
            {%- assign sv = block.settings.shopify_video -%}
            <video
              autoplay muted loop playsinline
              style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
            >
              {%- for source in sv.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
          {%- elsif has_ext_video -%}
            {%- if block.settings.video_url.type == 'youtube' -%}
              <iframe
                src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ block.settings.video_url.id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
                frameborder="0"
                allow="autoplay; encrypted-media"
                loading="lazy"
              ></iframe>
            {%- elsif block.settings.video_url.type == 'vimeo' -%}
              <iframe
                src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1&playsinline=1"
                frameborder="0"
                allow="autoplay"
                loading="lazy"
              ></iframe>
            {%- endif -%}
          {%- endif -%}
          <div class="product-video-hero__overlay" style="opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>
        </div>
      {%- endif -%}
      <div class="product-video-hero__content">
        {%- if block.settings.subtitle != blank -%}
          <p class="product-video-hero__subtitle">{{ block.settings.subtitle }}</p>
        {%- endif -%}
        {%- if block.settings.title != blank -%}
          <h2 class="product-video-hero__title">{{ block.settings.title }}</h2>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
{%- endif -%}

{%- comment -%} ── Product Funnel ── {%- endcomment -%}
{%- if funnel_blocks.size > 0 -%}
  <div class="product-funnel" id="ProductFunnel">
    {%- for block in funnel_blocks -%}
      {%- assign color_value = block.settings.funnel_color | downcase | strip -%}
      {%- assign funnel_alt = block.settings.funnel_alt | default: 'Product funnel image' -%}
      {%- assign img_slots = "1,2,3,4,5" | split: "," -%}
      {%- for slot in img_slots -%}
        {%- if slot == "1" -%}
          {%- assign desk_img = block.settings.desktop_image -%}
          {%- assign mob_img = block.settings.mobile_image -%}
        {%- elsif slot == "2" -%}
          {%- assign desk_img = block.settings.desktop_image_2 -%}
          {%- assign mob_img = block.settings.mobile_image_2 -%}
        {%- elsif slot == "3" -%}
          {%- assign desk_img = block.settings.desktop_image_3 -%}
          {%- assign mob_img = block.settings.mobile_image_3 -%}
        {%- elsif slot == "4" -%}
          {%- assign desk_img = block.settings.desktop_image_4 -%}
          {%- assign mob_img = block.settings.mobile_image_4 -%}
        {%- elsif slot == "5" -%}
          {%- assign desk_img = block.settings.desktop_image_5 -%}
          {%- assign mob_img = block.settings.mobile_image_5 -%}
        {%- endif -%}
        {%- if desk_img != blank or mob_img != blank -%}
          <div
            class="product-funnel__slide"
            data-funnel-color="{{ color_value }}"
            {% if slot == "1" %}{{ block.shopify_attributes }}{% endif %}
          >
            {%- if desk_img != blank and mob_img != blank -%}
              <picture>
                <source
                  media="(max-width: 749px)"
                  srcset="{{ mob_img | image_url: width: 750 }} 750w,
                          {{ mob_img | image_url: width: 1080 }} 1080w,
                          {{ mob_img | image_url: width: 1500 }} 1500w"
                  sizes="100vw"
                >
                <source
                  media="(min-width: 750px)"
                  srcset="{{ desk_img | image_url: width: 1200 }} 1200w,
                          {{ desk_img | image_url: width: 1800 }} 1800w,
                          {{ desk_img | image_url: width: 2400 }} 2400w,
                          {{ desk_img | image_url: width: 3200 }} 3200w"
                  sizes="100vw"
                >
                <img
                  src="{{ desk_img | image_url: width: 1800 }}"
                  alt="{{ funnel_alt | escape }}"
                  width="{{ desk_img.width }}"
                  height="{{ desk_img.height }}"
                  loading="lazy"
                  class="product-funnel__img"
                >
              </picture>
            {%- elsif desk_img != blank -%}
              <img
                src="{{ desk_img | image_url: width: 1800 }}"
                srcset="{{ desk_img | image_url: width: 1200 }} 1200w,
                        {{ desk_img | image_url: width: 1800 }} 1800w,
                        {{ desk_img | image_url: width: 2400 }} 2400w,
                        {{ desk_img | image_url: width: 3200 }} 3200w"
                sizes="100vw"
                alt="{{ funnel_alt | escape }}"
                width="{{ desk_img.width }}"
                height="{{ desk_img.height }}"
                loading="lazy"
                class="product-funnel__img"
              >
            {%- elsif mob_img != blank -%}
              <img
                src="{{ mob_img | image_url: width: 1080 }}"
                srcset="{{ mob_img | image_url: width: 750 }} 750w,
                        {{ mob_img | image_url: width: 1080 }} 1080w,
                        {{ mob_img | image_url: width: 1500 }} 1500w"
                sizes="100vw"
                alt="{{ funnel_alt | escape }}"
                width="{{ mob_img.width }}"
                height="{{ mob_img.height }}"
                loading="lazy"
                class="product-funnel__img"
              >
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
{%- endif -%}

