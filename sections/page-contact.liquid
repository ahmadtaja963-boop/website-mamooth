<div class="page-contact pt-nav">

  {%- comment -%} Hero {%- endcomment -%}
  <div style="position:relative;height:38vh;min-height:280px;overflow:hidden;">
    <img src="{{ 'mammoth-contact.jpg' | asset_url }}" alt="Contact MAMMOTH" style="width:100%;height:100%;object-fit:cover;" loading="eager">
    <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(26,35,50,0.75) 0%,rgba(26,35,50,0.4) 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:2rem;">
      <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3.5rem);color:#fff;margin-bottom:0.75rem;letter-spacing:0.08em;text-transform:uppercase;">Contact Us</h1>
      <p style="font-size:1.1rem;color:rgba(255,255,255,0.8);max-width:480px;margin:0 auto;">We typically respond within 24 hours.</p>
    </div>
  </div>

  <section style="padding:5rem 0;background:#fff;">
    <div class="container" style="max-width:1100px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:flex-start;">

        {%- comment -%} Contact Info {%- endcomment -%}
        <div>
          <h2 style="font-family:var(--font-heading);font-size:2rem;margin-bottom:1.5rem;">Get In Touch</h2>
          <p style="color:var(--color-text-muted);margin-bottom:2rem;line-height:1.8;">
            Our dedicated team is available to answer any questions about our products, services, or to assist with your order.
          </p>

          <div style="display:flex;flex-direction:column;gap:1.5rem;margin-bottom:2rem;">
            <div style="display:flex;align-items:flex-start;gap:1rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:3px;color:var(--color-accent);"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <div>
                <h3 style="font-size:0.95rem;font-weight:600;margin-bottom:0.25rem;">Email</h3>
                <p style="color:var(--color-text-muted);margin-bottom:0.1rem;"><a href="mailto:support@mammothstore.com" style="color:inherit;">support@mammothstore.com</a></p>
                <p style="font-size:0.85rem;color:var(--color-text-muted);margin:0;">Response within 24 hours</p>
              </div>
            </div>
            <div style="display:flex;align-items:flex-start;gap:1rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:3px;color:var(--color-accent);"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 4.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 11.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 18.09z"/></svg>
              <div>
                <h3 style="font-size:0.95rem;font-weight:600;margin-bottom:0.25rem;">Phone</h3>
                <p style="color:var(--color-text-muted);margin-bottom:0.1rem;">Mon–Fri, 9AM–6PM EST</p>
                <p style="font-size:0.85rem;color:var(--color-text-muted);margin:0;">Response within 24 hours</p>
          </div>

          <div style="background:var(--color-bg-secondary);padding:1.5rem;border-radius:var(--radius-card);">
            <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin-bottom:0.75rem;">Business Hours</h3>
            <div style="display:flex;flex-direction:column;gap:0.4rem;font-size:0.9rem;color:var(--color-text-muted);">
              <p style="margin:0;">Monday – Friday: 9:00 AM – 6:00 PM EST</p>
              <p style="margin:0;">Saturday: 10:00 AM – 4:00 PM EST</p>
              <p style="margin:0;">Sunday: Closed</p>
            </div>
          </div>
        </div>

        {%- comment -%} Contact Form {%- endcomment -%}
        <div>
          {%- form 'contact', id: 'ContactForm' -%}
            {% if form.posted_successfully? %}
              <div style="padding:1rem;background:#f0f8ea;border:1px solid #c3e6cb;color:#155724;margin-bottom:1.5rem;">
                Thank you for your message. We'll get back to you within 24 hours.
              </div>
            {% endif %}
            {{ form.errors | default_errors }}

            <div style="display:flex;flex-direction:column;gap:1.25rem;">
              <div class="form-field">
                <label style="display:block;font-size:0.9rem;font-weight:500;margin-bottom:0.4rem;">Name</label>
                <input type="text" name="contact[name]" placeholder="Your name" value="{{ form.name }}" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;font-size:0.95rem;font-family:inherit;">
              </div>
              <div class="form-field">
                <label style="display:block;font-size:0.9rem;font-weight:500;margin-bottom:0.4rem;">Email</label>
                <input type="email" name="contact[email]" placeholder="your@email.com" value="{{ form.email }}" required style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;font-size:0.95rem;font-family:inherit;">
              </div>
              <div class="form-field">
                <label style="display:block;font-size:0.9rem;font-weight:500;margin-bottom:0.4rem;">Phone (optional)</label>
                <input type="tel" name="contact[phone]" placeholder="+1 (555) 000-0000" value="{{ form.phone }}" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;font-size:0.95rem;font-family:inherit;">
              </div>
              <div class="form-field">
                <label style="display:block;font-size:0.9rem;font-weight:500;margin-bottom:0.4rem;">Subject</label>
                <input type="text" name="contact[subject]" placeholder="How can we help?" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;font-size:0.95rem;font-family:inherit;">
              </div>
              <div class="form-field">
                <label style="display:block;font-size:0.9rem;font-weight:500;margin-bottom:0.4rem;">Message</label>
                <textarea name="contact[body]" placeholder="Your message" rows="6" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;font-size:0.95rem;font-family:inherit;resize:vertical;">{{ form.body }}</textarea>
              </div>
              <button type="submit" class="btn btn-primary" style="width:100%;">Send Message</button>
            </div>
          {%- endform -%}
        </div>

      </div>
    </div>
  </section>

</div>

<style>
@media (max-width: 767px) {
  .page-contact [style*="grid-template-columns:1fr 1fr"] {
    grid-template-columns: 1fr !important;
  }
}
</style>

{% schema %}
{
  "name": "Contact Page",
  "tag": "div"
}
{% endschema %}
