{%- comment -%} Announcement bar {%- endcomment -%}
<div class="announcement-bar">
  {{ section.settings.announcement | default: 'Free Shipping on Orders Over $50' }}
</div>

<header class="site-header" id="SiteHeader">
  <div class="container header-inner">

    {%- comment -%} Logo — left {%- endcomment -%}
    {%- assign logo_width = section.settings.logo_width | default: 140 -%}
    <a class="header-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: logo_width }}"
          alt="{{ shop.name }}"
          style="width: {{ logo_width }}px; height: auto;"
          loading="eager"
        >
      {%- else -%}
        <span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:1.25rem;letter-spacing:0.15em;color:var(--color-text);text-transform:uppercase;">MAMMOTH</span>
      {%- endif -%}
    </a>

    {%- comment -%} Center nav (desktop) {%- endcomment -%}
    <nav class="header-nav" aria-label="Main navigation">
      <a href="/collections/all">Shop</a>
      <a href="/collections/wellness">Wellness</a>
      <a href="/collections/skincare">Skincare</a>
      <a href="/collections/fitness">Fitness</a>
      <a href="/collections/lifestyle">Lifestyle</a>
      <a href="/pages/about">About</a>
    </nav>

    {%- comment -%} Right icons {%- endcomment -%}
    <div class="header-right">
      <a href="{{ routes.search_url }}" class="btn-ghost btn-icon" aria-label="Search">
        {%- render 'icon-search' -%}
      </a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="btn-ghost btn-icon" aria-label="Account">
          {%- render 'icon-user' -%}
        </a>
      {%- endif -%}
      <button
        class="btn-ghost btn-icon cart-icon-wrapper"
        id="CartToggle"
        aria-label="Open cart"
        aria-expanded="false"
        aria-controls="CartDrawer"
      >
        {%- render 'icon-cart' -%}
        <span class="cart-count-badge" id="CartCount" aria-hidden="true">
          {{- cart.item_count -}}
        </span>
      </button>

      <button
        class="mobile-menu-toggle btn-ghost btn-icon"
        id="MobileMenuToggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="MobileNav"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

  </div>
</header>

{%- comment -%} Collection sub-nav (sticky below header on collection/home pages) {%- endcomment -%}
{%- if template.name == 'index' or template.name == 'collection' -%}
  {%- if section.blocks.size > 0 -%}
    <nav class="collection-nav" aria-label="Category navigation">
      <div class="collection-nav-inner">
        {%- for block in section.blocks -%}
          {%- if block.type == 'collection_link' -%}
            <a
              href="/collections/{{ block.settings.collection_handle }}"
              class="collection-nav-link"
              {{ block.shopify_attributes }}
            >
              {{- block.settings.label -}}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </nav>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Header",
  "tag": "div",
  "class": "header-group",
  "settings": [
    {
      "type": "text",
      "id": "announcement",
      "label": "Announcement bar text",
      "default": "Free Shipping on Orders Over $50 — Shop Now"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 220,
      "step": 10,
      "default": 140,
      "unit": "px",
      "label": "Logo width"
    }
  ],
  "blocks": [
    {
      "type": "collection_link",
      "name": "Sub-nav link",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "collection_handle",
          "label": "Collection handle",
          "default": "all"
        }
      ]
    }
  ]
}
{% endschema %}
