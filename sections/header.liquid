{%- comment -%} Announcement bar — scrolling marquee {%- endcomment -%}
<div class="announcement-bar">
  <div class="announcement-marquee">
    <div class="announcement-marquee__track">
      {%- for i in (1..2) -%}
        <span class="announcement-marquee__item">{% if section.settings.announcement_1 != blank %}{{ section.settings.announcement_1 }}{% else %}{{ 'header.announcement_1' | t }}{% endif %}</span>
        <span class="announcement-marquee__sep">✦</span>
        <span class="announcement-marquee__item">{% if section.settings.announcement_2 != blank %}{{ section.settings.announcement_2 }}{% else %}{{ 'header.announcement_2' | t }}{% endif %}</span>
        <span class="announcement-marquee__sep">✦</span>
        <span class="announcement-marquee__item">{% if section.settings.announcement_3 != blank %}{{ section.settings.announcement_3 }}{% else %}{{ 'header.announcement_3' | t }}{% endif %}</span>
        <span class="announcement-marquee__sep">✦</span>
      {%- endfor -%}
    </div>
  </div>
</div>

<header class="site-header" id="SiteHeader">
  <div class="container header-inner">

    {%- comment -%} Wordmark — left (forced; ignores stale legacy logo setting) {%- endcomment -%}
    <a class="header-logo" href="{{ routes.root_url }}" aria-label="the pretty fix.">
      <span style="font-family:var(--font-script,'Caveat Brush',cursive);font-weight:400;font-size:2rem;letter-spacing:0.01em;color:var(--color-accent);line-height:1;text-shadow:1px 1px 0 var(--color-accent-hover);transform:rotate(-1.5deg);display:inline-block;">the pretty fix.</span>
    </a>

    {%- comment -%} Center nav (desktop) — pretty fix lineup {%- endcomment -%}
    <nav class="header-nav" aria-label="Main navigation">
      <a href="/collections/all">Shop</a>
      <a href="/products/mammoth-posture-corrective-wireless-bra">The Bra</a>
      <a href="/pages/about">The Science</a>
      <a href="/pages/about">About</a>
    </nav>

    {%- comment -%} Right icons {%- endcomment -%}
    <div class="header-right">
      <a href="{{ routes.search_url }}" class="btn-ghost btn-icon" aria-label="Search">
        {%- render 'icon-search' -%}
      </a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="btn-ghost btn-icon" aria-label="Account">
          {%- render 'icon-user' -%}
        </a>
      {%- endif -%}
      <button
        class="btn-ghost btn-icon cart-icon-wrapper"
        id="CartToggle"
        aria-label="Open cart"
        aria-expanded="false"
        aria-controls="CartDrawer"
      >
        {%- render 'icon-cart' -%}
        <span class="cart-count-badge" id="CartCount" aria-hidden="true">
          {{- cart.item_count -}}
        </span>
      </button>

      <button
        class="mobile-menu-toggle btn-ghost btn-icon"
        id="MobileMenuToggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="MobileNav"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

  </div>
</header>

{%- comment -%} Collection sub-nav (sticky below header on collection/home pages) {%- endcomment -%}
{%- if template.name == 'index' or template.name == 'collection' -%}
  {%- if section.blocks.size > 0 -%}
    <nav class="collection-nav" aria-label="Category navigation">
      <div class="collection-nav-inner">
        {%- for block in section.blocks -%}
          {%- if block.type == 'collection_link' -%}
            <a
              href="/collections/{{ block.settings.collection_handle }}"
              class="collection-nav-link"
              {{ block.shopify_attributes }}
            >
              {{- block.settings.label -}}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </nav>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Header",
  "tag": "div",
  "class": "header-group",
  "settings": [
    {
      "type": "text",
      "id": "announcement_1",
      "label": "Announcement message 1",
      "default": "🚚 FREE SHIPPING ON ALL ORDERS — TODAY ONLY"
    },
    {
      "type": "text",
      "id": "announcement_2",
      "label": "Announcement message 2",
      "default": ""
    },
    {
      "type": "text",
      "id": "announcement_3",
      "label": "Announcement message 3",
      "default": ""
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 220,
      "step": 10,
      "default": 140,
      "unit": "px",
      "label": "Logo width"
    }
  ],
  "blocks": [
    {
      "type": "collection_link",
      "name": "Sub-nav link",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "collection_handle",
          "label": "Collection handle",
          "default": "all"
        }
      ]
    }
  ]
}
{% endschema %}
