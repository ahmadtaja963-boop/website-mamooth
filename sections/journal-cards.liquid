
{%- comment -%} Journal Cards — necked. {%- endcomment -%}
<section style="background:#F4ECDF;padding:clamp(4rem,8vw,6rem) 0;border-top:1px solid #E8DCC6;">
  <div style="max-width:1200px;margin:0 auto;padding:0 clamp(1.5rem,4vw,2rem);">

    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:3rem;flex-wrap:wrap;gap:1rem;">
      <h2 style="font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:clamp(1.5rem,3vw,2.25rem);font-weight:400;color:#2A1D14;margin:0;">{{ section.settings.heading }}</h2>
      <a href="{{ section.settings.all_url | default: '/blogs/journal' }}" style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;color:#5C4632;border-bottom:1px solid #5C4632;padding-bottom:2px;white-space:nowrap;">{{ section.settings.all_label }} &rarr;</a>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;">

      {%- for block in section.blocks -%}
        <article style="display:flex;flex-direction:column;" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.url | default: '/blogs/journal' }}" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;height:100%;">
            <div style="aspect-ratio:4/3;background:#E8DCC6;margin-bottom:1.25rem;overflow:hidden;display:flex;align-items:center;justify-content:center;">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
              {%- else -%}
                <span style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;color:#9A7E62;text-transform:uppercase;">Journal image</span>
              {%- endif -%}
            </div>
            {%- if block.settings.date != blank -%}
              <p style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:#9A7E62;margin:0 0 0.5rem;">{{ block.settings.date }}</p>
            {%- endif -%}
            <h3 style="font-family:'Playfair Display',Georgia,serif;font-size:1.1rem;font-weight:400;color:#2A1D14;line-height:1.3;margin:0 0 1rem;flex:1;">{{ block.settings.title }}</h3>
            <span style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:#5C4632;border-bottom:1px solid #5C4632;padding-bottom:1px;align-self:flex-start;">Read &rarr;</span>
          </a>
        </article>
      {%- else -%}
        {%- assign default_titles = 'What Is Screen Body?,Tech Neck But Make It Cute,The Lazy Girl Guide to Better Posture' | split: ',' -%}
        {%- for i in (1..3) -%}
          <article style="display:flex;flex-direction:column;">
            <div style="aspect-ratio:4/3;background:#E8DCC6;margin-bottom:1.25rem;display:flex;align-items:center;justify-content:center;">
              <span style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;color:#9A7E62;text-transform:uppercase;">Journal image</span>
            </div>
            <p style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:#9A7E62;margin:0 0 0.5rem;">May 2026</p>
            <h3 style="font-family:'Playfair Display',Georgia,serif;font-size:1.1rem;font-weight:400;color:#2A1D14;line-height:1.3;margin:0 0 1rem;flex:1;">{{ default_titles[forloop.index0] }}</h3>
            <span style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:#5C4632;border-bottom:1px solid #5C4632;padding-bottom:1px;align-self:flex-start;">Read &rarr;</span>
          </article>
        {%- endfor -%}
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Journal Cards",
  "tag": "div",
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Thumbnail" },
        { "type": "text", "id": "date", "label": "Date", "default": "May 2026" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "url", "id": "url", "label": "Article URL" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Latest from the journal." },
    { "type": "text", "id": "all_label", "label": "View all label", "default": "View All" },
    { "type": "url", "id": "all_url", "label": "View all URL" }
  ],
  "presets": [{ "name": "Journal Cards" }]
}
{% endschema %}
