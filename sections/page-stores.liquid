<div class="page-stores pt-nav">

  {%- comment -%} Hero {%- endcomment -%}
  <div style="position:relative;height:40vh;min-height:280px;overflow:hidden;">
    <img
      src="{{ 'store-interior.jpg' | asset_url }}"
      alt="Our Boutiques"
      style="width:100%;height:100%;object-fit:cover;"
    >
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:2rem;">
      <h1 style="font-family:var(--font-heading);font-size:clamp(2.5rem,6vw,4.5rem);color:#fff;margin-bottom:1rem;letter-spacing:0.05em;">Our Boutiques</h1>
      <p style="font-size:1.1rem;color:rgba(255,255,255,0.85);max-width:500px;">Experience DIAZ in person</p>
    </div>
  </div>

  {%- comment -%} Store Grid {%- endcomment -%}
  <section style="padding:5rem 0;background:#fff;">
    <div class="container" style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <h2 style="font-family:var(--font-heading);font-size:2rem;margin-bottom:1rem;">Visit Us</h2>
        <p style="color:var(--color-text-muted);max-width:600px;margin:0 auto;line-height:1.7;">
          Experience the full DIAZ collection at one of our locations worldwide. Our team is ready to help you find the perfect piece.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;" class="stores-grid-wrap">

        {%- comment -%} 1. Hallandale Beach, FL — US HQ {%- endcomment -%}
        <div style="background:#f5f0ea;padding:2rem;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
            <h3 style="font-family:var(--font-heading);font-size:1.5rem;margin:0;">Hallandale Beach</h3>
            <span style="font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;background:#111;color:#fff;padding:0.3rem 0.75rem;font-weight:600;">Open</span>
          </div>
          <div style="display:flex;flex-direction:column;gap:1rem;">
            <div style="display:flex;align-items:flex-start;gap:0.75rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:2px;color:var(--color-accent)"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <p style="color:var(--color-text-muted);margin:0;">1025 E Hallandale Beach Blvd #1520<br>Hallandale Beach, FL 33009</p>
            </div>
            <div style="display:flex;align-items:center;gap:0.75rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;color:var(--color-accent)"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 4.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 11.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 18.09z"/></svg>
              <p style="color:var(--color-text-muted);margin:0;">+1 (786) 714-8605</p>
            </div>
            <div style="display:flex;align-items:center;gap:0.75rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;color:var(--color-accent)"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <p style="color:var(--color-text-muted);margin:0;">Mon–Fri: 9AM–6PM EST</p>
            </div>
          </div>
        </div>

        {%- comment -%} 2. Ambato, Ecuador — tannery headquarters {%- endcomment -%}
        <div style="background:#f5f0ea;padding:2rem;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
            <h3 style="font-family:var(--font-heading);font-size:1.5rem;margin:0;">Ambato</h3>
            <span style="font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;background:#111;color:#fff;padding:0.3rem 0.75rem;font-weight:600;">Open</span>
          </div>
          <div style="display:flex;flex-direction:column;gap:1rem;">
            <div style="display:flex;align-items:flex-start;gap:0.75rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:2px;color:var(--color-accent)"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <p style="color:var(--color-text-muted);margin:0;">Panamericana Norte, Sector El Pisque<br>Calle Arenillas, Entrada a Macasto<br>Ambato, Ecuador</p>
            </div>
            <div style="display:flex;align-items:center;gap:0.75rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;color:var(--color-accent)"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 4.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 11.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 18.09z"/></svg>
              <p style="color:var(--color-text-muted);margin:0;">+593 99 274 1582</p>
            </div>
            <div style="display:flex;align-items:center;gap:0.75rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;color:var(--color-accent)"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <p style="color:var(--color-text-muted);margin:0;">Mon–Fri: 8AM–5PM</p>
            </div>
          </div>
        </div>

        {%- comment -%} 3. Bogotá — Coming Soon {%- endcomment -%}
        <div style="background:#f5f0ea;padding:2rem;opacity:0.72;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
            <h3 style="font-family:var(--font-heading);font-size:1.5rem;margin:0;">Bogotá</h3>
            <span style="font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;border:1px solid #bbb;color:#999;padding:0.3rem 0.75rem;font-weight:600;">Coming Soon</span>
          </div>
          <div style="display:flex;align-items:flex-start;gap:0.75rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:2px;color:var(--color-accent)"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <p style="color:var(--color-text-muted);margin:0;">Calle 82 #11-37, Zona Rosa<br>Bogotá, Colombia</p>
          </div>
        </div>


      </div>
    </div>
  </section>

  {%- comment -%} Private Appointments {%- endcomment -%}
  <section style="padding:5rem 0;background:#f5f0ea;text-align:center;">
    <div class="container" style="max-width:700px;margin:0 auto;">
      <h2 style="font-family:var(--font-heading);font-size:2rem;margin-bottom:1.5rem;">Private Appointments</h2>
      <p style="color:var(--color-text-muted);margin-bottom:1.5rem;line-height:1.8;">
        For a personalized experience, we offer private appointments at our Ecuador headquarters. Get expert guidance on leather selection, custom orders, and wholesale inquiries.
      </p>
      <p style="color:var(--color-text-muted);line-height:1.8;">
        Contact us at <a href="mailto:info@diazleather.com" style="color:var(--color-text);text-decoration:underline;text-underline-offset:3px;">info@diazleather.com</a>
      </p>
    </div>
  </section>

</div>

<style>
@media (max-width: 767px) {
  .stores-grid-wrap {
    grid-template-columns: 1fr !important;
  }
}
</style>

{% schema %}
{
  "name": "Stores Page",
  "tag": "div"
}
{% endschema %}
