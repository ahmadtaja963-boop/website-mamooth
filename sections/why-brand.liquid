<section class="why-brand">
  <div class="container">
    <div class="why-brand-inner">

      <div class="why-brand-image">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.heading | escape }}"
            width="900" height="675"
            loading="lazy"
          >
        {%- else -%}
          <img
            src="{{ 'mammoth-why-brand.jpg' | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            width="900" height="675"
            loading="lazy"
          >
        {%- endif -%}
      </div>

      <div class="why-brand-card">
        <h2>{{ section.settings.heading | default: 'Why the pretty fix' }}</h2>
        {%- if section.settings.text1 != blank -%}
          <p>{{ section.settings.text1 }}</p>
        {%- endif -%}
        {%- if section.settings.text2 != blank -%}
          <p>{{ section.settings.text2 }}</p>
        {%- endif -%}
        {%- if section.settings.text3 != blank -%}
          <p>{{ section.settings.text3 }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url | default: '/pages/about' }}" class="btn btn-outline" style="margin-top:1.5rem;color:#fff;border-color:rgba(255,255,255,0.4);">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Brand",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Lifestyle image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why the pretty fix" },
    { "type": "textarea", "id": "text1", "label": "Paragraph 1", "default": "She tried braces, reminders, and 5 days of yoga. Nothing stuck — not because she's lazy, but because she's exhausted, and the methods were wrong." },
    { "type": "textarea", "id": "text2", "label": "Paragraph 2", "default": "the pretty fix is the passive way to fix tech neck while you scroll. Three pieces, designed to disappear into your routine. No new habits." },
    { "type": "textarea", "id": "text3", "label": "Paragraph 3" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Our Story" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [{ "name": "Why Brand" }]
}
{% endschema %}
