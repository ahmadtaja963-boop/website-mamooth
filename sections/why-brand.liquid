{%- comment -%} Mission — two 2:1 landscape tiles: photo left, text right {%- endcomment -%}
<section style="display:grid;grid-template-columns:1fr 1fr;overflow:hidden;">
  <div style="position:relative;overflow:hidden;aspect-ratio:2/1;background:#D9C7AC;">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1400 }}" alt="necked. mission" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center center;" loading="lazy">
    {%- else -%}
      <img src="{{ 'founder.jpeg' | asset_url }}" alt="necked. founder" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;" loading="lazy">
    {%- endif -%}
  </div>
  <div style="background:#F4ECDF;aspect-ratio:2/1;display:flex;align-items:center;overflow:hidden;">
    <div style="padding:clamp(1.5rem,3.5vw,3.5rem) clamp(2rem,4.5vw,4.5rem);">
      {%- if section.settings.eyebrow != blank -%}
        <p style="margin:0 0 0.6rem;font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.35em;text-transform:uppercase;color:#9A7E62;">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.25rem,2.5vw,2rem);font-weight:400;color:#2A1D14;line-height:1.15;margin:0 0 0.85rem;">{{ section.settings.heading }}</h2>
      {%- if section.settings.text1 != blank -%}
        <p style="font-family:'Montserrat',sans-serif;font-size:0.7rem;color:#5C4632;line-height:1.8;margin:0 0 0.6rem;">{{ section.settings.text1 }}</p>
      {%- endif -%}
      {%- if section.settings.text2 != blank -%}
        <p style="font-family:'Montserrat',sans-serif;font-size:0.7rem;color:#5C4632;line-height:1.8;margin:0 0 1rem;">{{ section.settings.text2 }}</p>
      {%- endif -%}
      <a href="{{ section.settings.button_url | default: '/pages/about' }}" style="font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;color:#2A1D14;text-decoration:none;border-bottom:1px solid rgba(42,29,20,0.4);padding-bottom:2px;">{{ section.settings.button_label | default: 'Our Story' }} &rarr;</a>
    </div>
  </div>
</section>
{% schema %}
{ "name": "Mission", "tag": "div", "settings": [
  { "type": "image_picker", "id": "image", "label": "Left image — horizontal crop" },
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Mission" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "Built for the woman who does it all." },
  { "type": "textarea", "id": "text1", "label": "Paragraph 1", "default": "necked. was born from a simple truth: your neck deserves the same care as your face." },
  { "type": "textarea", "id": "text2", "label": "Paragraph 2", "default": "Every product is designed to fit seamlessly into your routine — no effort, all results." },
  { "type": "text", "id": "button_label", "label": "Button label", "default": "Our Story" },
  { "type": "url", "id": "button_url", "label": "Button URL" }
], "presets": [{ "name": "Mission" }] }
{% endschema %}