{%- comment -%} Mission — full-bleed: photo left, text right {%- endcomment -%}
<section style="display:grid;grid-template-columns:2fr 3fr;min-height:60vh;overflow:hidden;">

  {%- comment -%} LEFT: portrait photo {%- endcomment -%}
  <div style="position:relative;overflow:hidden;background:#D9C7AC;">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;" loading="lazy">
    {%- else -%}
      <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;"><span style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.25em;color:#9A7E62;text-transform:uppercase;text-align:center;padding:1rem;">Portrait image<br>(add in editor)</span></div>
    {%- endif -%}
  </div>

  {%- comment -%} RIGHT: copy block {%- endcomment -%}
  <div style="background:#F4ECDF;display:flex;align-items:center;">
    <div style="padding:clamp(3rem,6vw,6rem) clamp(2.5rem,6vw,6rem);max-width:560px;">
      <p style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.35em;text-transform:uppercase;color:#9A7E62;margin:0 0 2rem;">{{ section.settings.eyebrow }}</p>
      <h2 style="font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:clamp(1.5rem,2.5vw,2rem);font-weight:400;color:#2A1D14;line-height:1.3;margin:0 0 1.5rem;">{{ section.settings.heading }}</h2>
      {%- if section.settings.text1 != blank -%}
        <p style="font-family:'Montserrat',sans-serif;font-size:0.875rem;line-height:1.9;color:#5C4632;margin:0 0 1rem;font-weight:300;">{{ section.settings.text1 }}</p>
      {%- endif -%}
      {%- if section.settings.text2 != blank -%}
        <p style="font-family:'Montserrat',sans-serif;font-size:0.875rem;line-height:1.9;color:#5C4632;margin:0 0 2.5rem;font-weight:300;">{{ section.settings.text2 }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url | default: '/pages/about' }}" style="display:inline-block;font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;text-decoration:none;color:#2A1D14;border-bottom:1px solid rgba(42,29,20,0.5);padding-bottom:0.2rem;">{{ section.settings.button_label }} &rarr;</a>
      {%- endif -%}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Mission",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Portrait image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Mission" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Founded by a screen girl." },
    { "type": "textarea", "id": "text1", "label": "Paragraph 1", "default": "necked. was created by a woman who noticed the same thing every modern girl eventually sees: her phone was changing the way her neck, shoulders, and posture looked." },
    { "type": "textarea", "id": "text2", "label": "Paragraph 2", "default": "Not overnight. Quietly. A little more tension, a little more folding, a little less lifted in photos." },
    { "type": "text", "id": "button_label", "label": "Button", "default": "Read Our Story" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [{ "name": "Mission" }]
}
{% endschema %}