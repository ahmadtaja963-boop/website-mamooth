<div class="cart-page pt-nav">
  <div class="container">
    <h1>{{ 'cart.general.title' | t }}</h1>

    {%- if cart.item_count == 0 -%}
      <div style="text-align:center;padding:5rem 0;">
        <p style="color:var(--color-text-muted);margin-bottom:2rem;">{{ 'cart.general.empty' | t }}</p>
        <a href="/collections/all" class="btn btn-primary">Continue Shopping</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" id="CartPageForm">
        <div class="cart-page-layout">

          <div class="cart-page-items">
            {%- for item in cart.items -%}
              <div class="cart-line">
                <a href="{{ item.url }}" class="cart-line-image">
                  {%- if item.image -%}
                    <img
                      src="{{ item.image | image_url: width: 200 }}"
                      alt="{{ item.title | escape }}"
                      width="100" height="100"
                      loading="lazy"
                    >
                  {%- endif -%}
                </a>

                <div>
                  <a href="{{ item.url }}" class="cart-line-title">{{ item.product_title }}</a>
                  {%- unless item.variant_title == 'Default Title' -%}
                    <p class="cart-line-variant">{{ item.variant_title }}</p>
                  {%- endunless -%}
                  <p class="cart-line-price">{{ item.line_price | money }}</p>

                  <div class="cart-qty-input">
                    <button
                      type="button"
                      class="cart-qty-change"
                      data-key="{{ item.key }}"
                      data-delta="-1"
                      aria-label="Decrease quantity"
                    >
                      {%- render 'icon-minus' -%}
                    </button>
                    <input
                      type="number"
                      name="updates[]"
                      data-key="{{ item.key }}"
                      value="{{ item.quantity }}"
                      min="0"
                      aria-label="Quantity for {{ item.title }}"
                    >
                    <button
                      type="button"
                      class="cart-qty-change"
                      data-key="{{ item.key }}"
                      data-delta="1"
                      aria-label="Increase quantity"
                    >
                      {%- render 'icon-plus' -%}
                    </button>
                  </div>
                </div>

                <div>
                  <a href="{{ item.url_to_remove }}" class="cart-line-remove">Remove</a>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <div class="cart-summary">
            <h2>Order Summary</h2>
            <div class="cart-summary-line">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-summary-line" style="color:var(--color-text-muted);font-size:.875rem;">
              <span>Shipping</span>
              <span>Calculated at checkout</span>
            </div>
            <div class="cart-summary-line cart-summary-total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <a href="/checkout" class="btn btn-primary w-full" style="margin-top:1.5rem;display:block;text-align:center;padding:1rem;">
              {{ 'cart.general.checkout' | t }}
            </a>
            <a href="/collections/all" style="display:block;text-align:center;margin-top:1rem;font-size:.875rem;color:var(--color-text-muted);">
              {{ 'cart.general.continue_shopping' | t }}
            </a>
          </div>

        </div>
      </form>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cart",
  "tag": "div"
}
{% endschema %}
