<div class="page-careers pt-nav">

  {%- comment -%} Hero {%- endcomment -%}
  <div style="position:relative;height:60vh;min-height:400px;overflow:hidden;">
    <img
      src="{{ 'craftsmanship-hero.jpg' | asset_url }}"
      alt="Careers at DIAZ"
      style="width:100%;height:100%;object-fit:cover;"
    >
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:2rem;">
      <h1 style="font-family:var(--font-heading);font-size:clamp(2.5rem,6vw,4.5rem);color:#fff;margin-bottom:1rem;letter-spacing:0.05em;">Careers at DIAZ</h1>
      <p style="font-size:1.1rem;color:rgba(255,255,255,0.85);max-width:500px;">Join our family of artisans and innovators</p>
    </div>
  </div>

  {%- comment -%} Why DIAZ {%- endcomment -%}
  <section style="padding:5rem 0;background:#fff;">
    <div class="container" style="max-width:1000px;margin:0 auto;">
      <h2 style="font-family:var(--font-heading);font-size:2rem;margin-bottom:1.25rem;text-align:center;">Why DIAZ?</h2>
      <p style="color:var(--color-text-muted);text-align:center;max-width:700px;margin:0 auto 3.5rem;line-height:1.8;">
        At DIAZ, we're more than a luxury brand — we're a community dedicated to preserving traditional craftsmanship while embracing innovation. Join us in creating pieces that stand the test of time.
      </p>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-bottom:4rem;">
        <div style="text-align:center;">
          <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin-bottom:0.75rem;">Master Craftsmanship</h3>
          <p style="font-size:0.9rem;color:var(--color-text-muted);line-height:1.7;">Learn from master artisans with decades of experience in traditional leather working techniques</p>
        </div>
        <div style="text-align:center;">
          <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin-bottom:0.75rem;">Growth Opportunities</h3>
          <p style="font-size:0.9rem;color:var(--color-text-muted);line-height:1.7;">We invest in our team through apprenticeships, training programs, and career advancement</p>
        </div>
        <div style="text-align:center;">
          <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin-bottom:0.75rem;">Global Community</h3>
          <p style="font-size:0.9rem;color:var(--color-text-muted);line-height:1.7;">Work alongside talented individuals from around the world in our boutiques and workshops</p>
        </div>
      </div>

      {%- comment -%} Open Positions {%- endcomment -%}
      <div style="background:#f5f0ea;padding:2.5rem;margin-bottom:3rem;">
        <h2 style="font-family:var(--font-heading);font-size:1.75rem;margin-bottom:2rem;">Open Positions</h2>

        <div style="display:flex;flex-direction:column;gap:0;">

          <div style="border-bottom:1px solid rgba(0,0,0,0.1);padding-bottom:1.75rem;margin-bottom:1.75rem;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;">
              <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin:0;">Senior Leather Craftsman</h3>
              <span style="font-size:0.85rem;color:var(--color-text-muted);">New York</span>
            </div>
            <p style="color:var(--color-text-muted);margin-bottom:1rem;line-height:1.7;font-size:0.95rem;">
              Seeking experienced artisan with 10+ years in luxury leather goods production. Expertise in hand-stitching and edge finishing required.
            </p>
            <a href="mailto:info@diazleather.com?subject=Application: Senior Leather Craftsman" style="display:inline-block;padding:0.5rem 1.25rem;border:1px solid var(--color-text);font-size:0.875rem;text-decoration:none;color:var(--color-text);">Apply Now</a>
          </div>

          <div style="border-bottom:1px solid rgba(0,0,0,0.1);padding-bottom:1.75rem;margin-bottom:1.75rem;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;">
              <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin:0;">Boutique Manager</h3>
              <span style="font-size:0.85rem;color:var(--color-text-muted);">Los Angeles</span>
            </div>
            <p style="color:var(--color-text-muted);margin-bottom:1rem;line-height:1.7;font-size:0.95rem;">
              Lead our Beverly Hills boutique team. 5+ years retail management experience in luxury goods required. Passion for exceptional customer service essential.
            </p>
            <a href="mailto:info@diazleather.com?subject=Application: Boutique Manager" style="display:inline-block;padding:0.5rem 1.25rem;border:1px solid var(--color-text);font-size:0.875rem;text-decoration:none;color:var(--color-text);">Apply Now</a>
          </div>

          <div style="border-bottom:1px solid rgba(0,0,0,0.1);padding-bottom:1.75rem;margin-bottom:1.75rem;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;">
              <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin:0;">Product Designer</h3>
              <span style="font-size:0.85rem;color:var(--color-text-muted);">New York</span>
            </div>
            <p style="color:var(--color-text-muted);margin-bottom:1rem;line-height:1.7;font-size:0.95rem;">
              Create next-generation designs that honor our heritage. Background in leather goods design and understanding of traditional techniques preferred.
            </p>
            <a href="mailto:info@diazleather.com?subject=Application: Product Designer" style="display:inline-block;padding:0.5rem 1.25rem;border:1px solid var(--color-text);font-size:0.875rem;text-decoration:none;color:var(--color-text);">Apply Now</a>
          </div>

          <div style="border-bottom:1px solid rgba(0,0,0,0.1);padding-bottom:1.75rem;margin-bottom:1.75rem;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;">
              <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin:0;">Customer Experience Specialist</h3>
              <span style="font-size:0.85rem;color:var(--color-text-muted);">Remote</span>
            </div>
            <p style="color:var(--color-text-muted);margin-bottom:1rem;line-height:1.7;font-size:0.95rem;">
              Join our concierge team providing world-class service to our global clientele. Multilingual candidates preferred.
            </p>
            <a href="mailto:info@diazleather.com?subject=Application: Customer Experience Specialist" style="display:inline-block;padding:0.5rem 1.25rem;border:1px solid var(--color-text);font-size:0.875rem;text-decoration:none;color:var(--color-text);">Apply Now</a>
          </div>

          <div>
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;">
              <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin:0;">Apprentice Leather Worker</h3>
              <span style="font-size:0.85rem;color:var(--color-text-muted);">New York</span>
            </div>
            <p style="color:var(--color-text-muted);margin-bottom:1rem;line-height:1.7;font-size:0.95rem;">
              Begin your journey in luxury craftsmanship. No experience required — we'll teach you everything. Passion for learning and attention to detail essential.
            </p>
            <a href="mailto:info@diazleather.com?subject=Application: Apprentice Leather Worker" style="display:inline-block;padding:0.5rem 1.25rem;border:1px solid var(--color-text);font-size:0.875rem;text-decoration:none;color:var(--color-text);">Apply Now</a>
          </div>

        </div>
      </div>

      {%- comment -%} General Applications {%- endcomment -%}
      <div style="padding:2rem 2rem 2rem 2.5rem;border-left:4px solid var(--color-accent);background:#f9f6f2;">
        <h3 style="font-family:var(--font-heading);font-size:1.5rem;margin-bottom:0.75rem;">Don't See Your Role?</h3>
        <p style="color:var(--color-text-muted);margin-bottom:0.75rem;line-height:1.8;">
          We're always looking for talented individuals who share our passion for excellence. Send your resume and portfolio to <a href="mailto:info@diazleather.com" style="color:var(--color-accent);">info@diazleather.com</a>.
        </p>
        <p style="color:var(--color-text-muted);line-height:1.8;margin:0;">
          DIAZ is an equal opportunity employer committed to diversity and inclusion in our workforce.
        </p>
      </div>
    </div>
  </section>

</div>

<style>
@media (max-width: 767px) {
  .page-careers [style*="grid-template-columns:repeat(3,1fr)"] {
    grid-template-columns: 1fr !important;
  }
}
</style>

{% schema %}
{
  "name": "Careers Page",
  "tag": "div"
}
{% endschema %}
