{%- comment -%} Journal Index — necked. {%- endcomment -%}
<section style="background:#F4ECDF;padding:clamp(3.5rem,7vw,6rem) 0 clamp(3rem,6vw,5rem);">
  <div style="max-width:1200px;margin:0 auto;padding:0 clamp(1.5rem,4vw,2rem);">

    {%- comment -%} Hero {%- endcomment -%}
    <div style="text-align:center;max-width:680px;margin:0 auto clamp(2.5rem,5vw,4rem);">
      <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.35em;text-transform:uppercase;color:#9A7E62;margin:0 0 1rem;font-weight:400;">{{ section.settings.kicker }}</p>
      <h1 style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(2rem,5vw,3.25rem);font-weight:400;color:#2A1D14;line-height:1.15;margin:0 0 1.25rem;letter-spacing:0.005em;">{{ section.settings.heading }}</h1>
      <p style="font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:clamp(1rem,1.6vw,1.2rem);color:#5C4632;line-height:1.55;margin:0;">{{ section.settings.subheading }}</p>
    </div>

    {%- assign articles = blog.articles -%}
    {%- if articles.size > 0 -%}

      {%- comment -%} Featured (first article) — wide card {%- endcomment -%}
      {%- assign featured = articles | first -%}
      <a href="{{ featured.url }}" style="display:grid;grid-template-columns:1.1fr 1fr;gap:clamp(1.5rem,3vw,3rem);align-items:center;background:#FFFFFF;border:1px solid #E8DCC6;text-decoration:none;color:inherit;margin-bottom:clamp(2rem,4vw,3.5rem);overflow:hidden;">
        <div style="aspect-ratio:4/3;background:#E8DCC6;display:flex;align-items:center;justify-content:center;overflow:hidden;">
          {%- if featured.image -%}
            <img src="{{ featured.image | image_url: width: 900 }}" alt="{{ featured.title | escape }}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
          {%- else -%}
            <span style="font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:clamp(1.5rem,3vw,2.25rem);color:#9A7E62;padding:2rem;text-align:center;">{{ featured.title | truncate: 40 }}</span>
          {%- endif -%}
        </div>
        <div style="padding:clamp(1.5rem,3vw,2.5rem) clamp(1.5rem,3vw,2.5rem) clamp(1.5rem,3vw,2.5rem) 0;">
          <p style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:#9A7E62;margin:0 0 0.75rem;font-weight:400;">Featured &middot; {{ featured.published_at | date: '%b %Y' }}</p>
          <h2 style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:400;color:#2A1D14;line-height:1.2;margin:0 0 1rem;">{{ featured.title }}</h2>
          {%- if featured.excerpt_or_content != blank -%}
            <p style="font-family:'Montserrat',sans-serif;font-size:0.9rem;line-height:1.65;color:#5C4632;margin:0 0 1.5rem;font-weight:300;">{{ featured.excerpt_or_content | strip_html | truncatewords: 30 }}</p>
          {%- endif -%}
          <span style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.25em;text-transform:uppercase;color:#2A1D14;border-bottom:1px solid #2A1D14;padding-bottom:2px;">Read the piece &rarr;</span>
        </div>
      </a>

      {%- comment -%} Grid (rest) {%- endcomment -%}
      {%- if articles.size > 1 -%}
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:clamp(1.5rem,3vw,2.5rem);">
          {%- for article in articles offset: 1 -%}
            <article style="display:flex;flex-direction:column;">
              <a href="{{ article.url }}" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;height:100%;">
                <div style="aspect-ratio:4/3;background:#E8DCC6;margin-bottom:1.25rem;overflow:hidden;display:flex;align-items:center;justify-content:center;">
                  {%- if article.image -%}
                    <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
                  {%- else -%}
                    <span style="font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:1.15rem;color:#9A7E62;padding:1.5rem;text-align:center;line-height:1.3;">{{ article.title | truncate: 50 }}</span>
                  {%- endif -%}
                </div>
                <p style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;color:#9A7E62;margin:0 0 0.5rem;font-weight:400;">{{ article.published_at | date: '%b %Y' }}</p>
                <h3 style="font-family:'Playfair Display',Georgia,serif;font-size:1.2rem;font-weight:400;color:#2A1D14;line-height:1.3;margin:0 0 0.75rem;">{{ article.title }}</h3>
                {%- if article.excerpt_or_content != blank -%}
                  <p style="font-family:'Montserrat',sans-serif;font-size:0.82rem;line-height:1.6;color:#5C4632;margin:0 0 1rem;font-weight:300;flex:1;">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p>
                {%- endif -%}
                <span style="font-family:'Montserrat',sans-serif;font-size:0.62rem;letter-spacing:0.25em;text-transform:uppercase;color:#5C4632;border-bottom:1px solid #5C4632;padding-bottom:1px;align-self:flex-start;">Read &rarr;</span>
              </a>
            </article>
          {%- endfor -%}
        </div>
      {%- endif -%}

    {%- else -%}
      <p style="text-align:center;font-family:'Playfair Display',Georgia,serif;font-style:italic;color:#9A7E62;font-size:1.1rem;padding:3rem 0;">Soft drops coming soon.</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Journal Index",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "The Journal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Soft notes from the screen body club." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Rituals, manifestos, and small ways of inhabiting your screen body on purpose." }
  ]
}
{% endschema %}
