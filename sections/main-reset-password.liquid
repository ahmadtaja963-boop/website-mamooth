<div class="customer-page pt-nav">
  <div class="container">
    <h1>Reset Password</h1>
    {%- form 'reset_customer_password', class: 'customer-form' -%}
      {{ form.errors | default_errors }}
      <div class="form-field"><label>New password</label><input type="password" name="customer[password]" autocomplete="new-password" required></div>
      <div class="form-field"><label>Confirm new password</label><input type="password" name="customer[password_confirmation]" autocomplete="new-password" required></div>
      <button type="submit" class="btn btn-primary">Reset Password</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Reset Password",
  "tag": "div"
}
{% endschema %}
