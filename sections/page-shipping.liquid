<div class="page-shipping pt-nav">

  <div class="page-hero" style="position:relative;height:40vh;min-height:300px;overflow:hidden;background:#1a1a1a;">
    <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:2rem;">
      <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3.5rem);color:#fff;margin-bottom:1rem;letter-spacing:0.05em;">Shipping & Delivery</h1>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.8);max-width:500px;">Everything you need to know about receiving your DIAZ order</p>
    </div>
  </div>

  <section style="padding:5rem 0;background:#fff;">
    <div class="container" style="max-width:860px;margin:0 auto;">

      <div style="margin-bottom:3.5rem;">
        <h2 style="font-family:var(--font-heading);font-size:1.6rem;margin-bottom:1.25rem;border-bottom:1px solid #e5e5e5;padding-bottom:0.75rem;">Processing Time</h2>
        <p style="color:var(--color-text-muted);line-height:1.8;margin-bottom:1rem;">
          All DIAZ orders are carefully prepared and dispatched within <strong>1–3 business days</strong> of purchase confirmation. Orders placed on weekends or public holidays will begin processing on the next business day.
        </p>
        <p style="color:var(--color-text-muted);line-height:1.8;">
          You will receive a shipping confirmation email with your tracking number as soon as your order leaves our facility.
        </p>
      </div>

      <div style="margin-bottom:3.5rem;">
        <h2 style="font-family:var(--font-heading);font-size:1.6rem;margin-bottom:1.25rem;border-bottom:1px solid #e5e5e5;padding-bottom:0.75rem;">Shipping Options</h2>
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:0.95rem;">
            <thead>
              <tr style="background:#f5f0ea;">
                <th style="text-align:left;padding:0.85rem 1rem;font-family:var(--font-heading);font-weight:600;">Method</th>
                <th style="text-align:left;padding:0.85rem 1rem;font-family:var(--font-heading);font-weight:600;">Estimated Delivery</th>
                <th style="text-align:left;padding:0.85rem 1rem;font-family:var(--font-heading);font-weight:600;">Cost</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom:1px solid #e5e5e5;">
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">Standard Shipping</td>
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">5–7 business days</td>
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">Free</td>
              </tr>
              <tr style="border-bottom:1px solid #e5e5e5;">
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">Express Shipping</td>
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">2–3 business days</td>
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">$18.00</td>
              </tr>
              <tr style="border-bottom:1px solid #e5e5e5;">
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">Overnight</td>
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">Next business day</td>
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">$35.00</td>
              </tr>
              <tr>
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">Free Shipping</td>
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">5–7 business days</td>
                <td style="padding:0.85rem 1rem;color:var(--color-text-muted);">Free on all orders</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div style="margin-bottom:3.5rem;">
        <h2 style="font-family:var(--font-heading);font-size:1.6rem;margin-bottom:1.25rem;border-bottom:1px solid #e5e5e5;padding-bottom:0.75rem;">International Shipping</h2>
        <p style="color:var(--color-text-muted);line-height:1.8;margin-bottom:1rem;">
          We ship to most countries worldwide. International delivery typically takes <strong>7–14 business days</strong> depending on the destination and customs clearance.
        </p>
        <p style="color:var(--color-text-muted);line-height:1.8;">
          Please note that international orders may be subject to import duties and taxes, which are the responsibility of the recipient. DIAZ is not liable for any additional charges imposed by customs authorities.
        </p>
      </div>

      <div style="margin-bottom:3.5rem;">
        <h2 style="font-family:var(--font-heading);font-size:1.6rem;margin-bottom:1.25rem;border-bottom:1px solid #e5e5e5;padding-bottom:0.75rem;">Tracking Your Order</h2>
        <p style="color:var(--color-text-muted);line-height:1.8;">
          Once your order ships, you will receive an email with a tracking link. You can also track your order at any time by visiting your account page or contacting our customer service team at <a href="/pages/contact" style="color:inherit;text-decoration:underline;">contact us</a>.
        </p>
      </div>

      <div style="background:#f5f0ea;padding:2rem;border-radius:4px;">
        <h3 style="font-family:var(--font-heading);font-size:1.2rem;margin-bottom:0.75rem;">Need Help?</h3>
        <p style="color:var(--color-text-muted);line-height:1.8;margin-bottom:1rem;">
          If you have any questions about your shipment or haven't received your order within the expected timeframe, please don't hesitate to reach out.
        </p>
        <a href="/pages/contact" style="display:inline-block;background:#1a1a1a;color:#fff;padding:0.75rem 2rem;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;">Contact Us</a>
      </div>

    </div>
  </section>

</div>

{% schema %}
{
  "name": "Shipping Page",
  "tag": "div"
}
{% endschema %}
