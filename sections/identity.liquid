{%- comment -%} Identity — For the soft girls with screen bodies {%- endcomment -%}
<section style="background:#D9C7AC;padding:0;">
  <div style="display:grid;grid-template-columns:1fr 1fr;align-items:stretch;min-height:clamp(380px,55vh,560px);">
    <div style="position:relative;overflow:hidden;background:#C9A98A;">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1400 }}" alt="{{ section.settings.heading | escape }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" loading="lazy">
      {%- else -%}
        <img src="{{ 'founder.jpeg' | asset_url }}" alt="{{ section.settings.heading | escape }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" loading="lazy">
      {%- endif -%}
    </div>
    <div style="display:flex;flex-direction:column;justify-content:center;padding:clamp(2.5rem,5vw,5rem);background:#F4ECDF;">
      <p style="margin:0 0 1rem;font-family:'Montserrat',sans-serif;font-size:0.7rem;letter-spacing:0.25em;text-transform:uppercase;color:#9A7E62;">{{ section.settings.eyebrow }}</p>
      <h2 style="margin:0 0 1.25rem;font-family:'Playfair Display',serif;font-weight:400;font-size:clamp(1.75rem,3.5vw,2.6rem);line-height:1.15;color:#2A1D14;letter-spacing:-0.01em;">{{ section.settings.heading }}</h2>
      <p style="margin:0;font-family:'Inter',sans-serif;font-size:clamp(0.95rem,1.4vw,1.05rem);line-height:1.65;color:#5C4632;max-width:480px;">{{ section.settings.body }}</p>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Identity",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHO IT'S FOR" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "For the soft girls with screen bodies." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "For the beauty-first, Pilates-adjacent, low-effort ambitious girl who wants to look lifted, rested, and put-together — without turning her life into a routine." }
  ],
  "presets": [{ "name": "Identity" }]
}
{% endschema %}