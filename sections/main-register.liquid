<div class="customer-page pt-nav">
  <div class="container">
    <h1>{{ 'customer.register.title' | t }}</h1>

    {%- form 'create_customer', class: 'customer-form' -%}
      {{ form.errors | default_errors }}

      <div class="form-field">
        <label for="FirstName">First name</label>
        <input type="text" name="customer[first_name]" id="FirstName" autocomplete="given-name">
      </div>
      <div class="form-field">
        <label for="LastName">Last name</label>
        <input type="text" name="customer[last_name]" id="LastName" autocomplete="family-name">
      </div>
      <div class="form-field">
        <label for="Email">Email</label>
        <input type="email" name="customer[email]" id="Email" autocomplete="email" required>
      </div>
      <div class="form-field">
        <label for="Password">Password</label>
        <input type="password" name="customer[password]" id="Password" autocomplete="new-password" required>
      </div>

      <button type="submit" class="btn btn-primary">{{ 'customer.register.submit' | t }}</button>
      <a href="{{ routes.account_login_url }}" style="display:block;margin-top:.75rem;font-size:.875rem;">Already have an account? Sign in</a>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Register",
  "tag": "div"
}
{% endschema %}
