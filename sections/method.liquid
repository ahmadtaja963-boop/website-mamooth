{%- comment -%} Method — Smooth / Lift / Align / Rest {%- endcomment -%}
<section style="background:#E8DCC6;padding:clamp(3rem,6vw,5rem) clamp(1.5rem,5vw,4rem);">
  <div style="max-width:1200px;margin:0 auto;text-align:center;">
    <p style="margin:0 0 0.75rem;font-family:'Montserrat',sans-serif;font-size:0.7rem;letter-spacing:0.25em;text-transform:uppercase;color:#9A7E62;">{{ section.settings.eyebrow }}</p>
    <h2 style="margin:0 0 clamp(2rem,4vw,3rem);font-family:'Playfair Display',serif;font-weight:400;font-size:clamp(1.75rem,4vw,2.75rem);color:#2A1D14;letter-spacing:-0.01em;">{{ section.settings.heading }}</h2>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:clamp(1rem,2vw,1.5rem);">
      {%- for i in (1..4) -%}
        {%- assign tk = 'title' | append: i -%}
        {%- assign bk = 'body' | append: i -%}
        <div style="background:#F4ECDF;padding:clamp(1.5rem,2.5vw,2.25rem) clamp(1rem,2vw,1.5rem);text-align:center;">
          <h3 style="margin:0 0 0.75rem;font-family:'Playfair Display',serif;font-weight:400;font-size:clamp(1.25rem,2vw,1.75rem);color:#2A1D14;">{{ section.settings[tk] }}</h3>
          <p style="margin:0;font-family:'Inter',sans-serif;font-size:0.9rem;line-height:1.55;color:#5C4632;">{{ section.settings[bk] }}</p>
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url }}" style="display:inline-block;margin-top:clamp(2rem,3vw,2.5rem);padding:0.9rem 2.25rem;background:#2A1D14;color:#F4ECDF;font-family:'Montserrat',sans-serif;font-size:0.75rem;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;">{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "Method",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "THE NECKED. METHOD" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Meet the necked. method." },
    { "type": "text", "id": "title1", "label": "Card 1 title", "default": "Smooth" },
    { "type": "textarea", "id": "body1", "label": "Card 1 body", "default": "For neck lines, texture, and tired-looking skin." },
    { "type": "text", "id": "title2", "label": "Card 2 title", "default": "Lift" },
    { "type": "textarea", "id": "body2", "label": "Card 2 body", "default": "For jawline, double chin appearance, and neck definition." },
    { "type": "text", "id": "title3", "label": "Card 3 title", "default": "Align" },
    { "type": "textarea", "id": "body3", "label": "Card 3 body", "default": "For pretty posture, shoulders, and the Pilates-princess look." },
    { "type": "text", "id": "title4", "label": "Card 4 title", "default": "Rest" },
    { "type": "textarea", "id": "body4", "label": "Card 4 body", "default": "For passive care while you work, scroll, sleep, and recover." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Find Your Fix" },
    { "type": "url", "id": "cta_url", "label": "CTA url" }
  ],
  "presets": [{ "name": "Method" }]
}
{% endschema %}
