<div class="locale-selector">
  {%- comment -%} Currency selector — deduplicated by currency code {%- endcomment -%}
  {%- form 'localization', id: 'FooterCountryForm', class: 'locale-selector__form' -%}
    {%- if localization.available_countries.size > 1 -%}
      {%- assign current_currency = localization.country.currency.iso_code -%}
      {%- assign seen_currencies = '' -%}
      <label class="locale-selector__group">
        <svg class="locale-selector__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20M12 2a14.5 14.5 0 0 1 0 20M2 12h20"/></svg>
        <select name="country_code" class="locale-selector__select" aria-label="Currency" onchange="this.form.submit()">
          {%- for country in localization.available_countries -%}
            {%- assign curr = country.currency.iso_code -%}
            {%- unless seen_currencies contains curr -%}
              {%- assign seen_currencies = seen_currencies | append: curr | append: '|' -%}
              <option value="{{ country.iso_code }}"{% if curr == current_currency %} selected{% endif %}>
                {{ country.currency.symbol }} {{ curr }}
              </option>
            {%- endunless -%}
          {%- endfor -%}
        </select>
      </label>
    {%- endif -%}
  {%- endform -%}

  {%- comment -%} Language selector {%- endcomment -%}
  {%- form 'localization', id: 'FooterLanguageForm', class: 'locale-selector__form' -%}
    {%- if localization.available_languages.size > 1 -%}
      <label class="locale-selector__group">
        <svg class="locale-selector__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 8 6 6M4 14l6-6 2-3M2 5h12M7 2h1M22 22l-5-10-5 10M14 18h6"/></svg>
        <select name="locale_code" class="locale-selector__select" aria-label="Language" onchange="this.form.submit()">
          {%- for language in localization.available_languages -%}
            <option value="{{ language.iso_code }}" lang="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>
              {{ language.endonym_name | capitalize }}
            </option>
          {%- endfor -%}
        </select>
      </label>
    {%- endif -%}
  {%- endform -%}
</div>

<style>
  .locale-selector {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .locale-selector__form { margin: 0; padding: 0; }
  .locale-selector__group {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    padding: 5px 8px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .locale-selector__group:hover { background: rgba(255,255,255,0.12); }
  .locale-selector__icon { width: 14px; height: 14px; flex-shrink: 0; color: rgba(255,255,255,0.5); }
  .locale-selector__select {
    background: transparent;
    border: none;
    color: inherit;
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    padding-right: 2px;
    appearance: none;
    -webkit-appearance: none;
  }
  .locale-selector__select:focus { outline: none; }
  .locale-selector__select option { color: #1a2332; background: #fff; }
</style>
