<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#F4ECDF">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Caveat+Brush&family=Montserrat:wght@400;500;600&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Caveat+Brush&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet"></noscript>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- else -%}
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='12' fill='%23F4ECDF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='Playfair Display, Georgia, serif' font-size='44' font-weight='500' fill='%232A1D14'>n.</text></svg>">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif -%}
    {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
    {%- assign brand_name = 'necked.' -%}
    {%- unless page_title contains brand_name %} &ndash; {{ brand_name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <meta name="google-site-verification" content="nVkdAMdfQK_8kMkHPnkDZOLPuiDy_A7fSogVc5d3bNU" />
</head>

<body>
  <a class="sr-only" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>

  {% section 'header' %}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {%- render 'cart-drawer' -%}

  <div class="cart-overlay" id="CartOverlay" aria-hidden="true"></div>

  <div class="toast" id="Toast" role="status" aria-live="polite"></div>

  <div class="mobile-nav" id="MobileNav" aria-hidden="true">
    <a href="/collections/all">Shop</a>
    <a href="/collections/wellness">Wellness</a>
    <a href="/collections/skincare">Skincare</a>
    <a href="/collections/fitness">Fitness</a>
    <a href="/collections/lifestyle">Lifestyle</a>
    <hr style="border-color:rgba(255,255,255,0.15);margin:0.5rem 0">
    <a href="/pages/about">About</a>
  </div>

  <script>
    window.MammothCartCurrency = {{ cart.currency.iso_code | json }};
    window.MammothT = {
      free_shipping_label: {{ 'cart.discount.free_shipping_label' | t | json }},
      percent_off: {{ 'cart.discount.percent_off' | t: percent: '__P__' | json }},
      free_shipping_unlocked: {{ 'cart.discount.free_shipping_unlocked' | t | json }},
      away_from: {{ 'cart.discount.away_from' | t: amount: '__A__', tier: '__T__' | json }},
      more_for: {{ 'cart.discount.more_for' | t: amount: '__A__', tier: '__T__' | json }},
      max_unlocked: {{ 'cart.discount.max_unlocked' | t: tier: '__T__' | json }},
      added: {{ 'cart.toast.added' | t | json }},
      adding: {{ 'cart.toast.adding' | t | json }},
      add_to_cart: {{ 'cart.toast.add_to_cart' | t | json }},
      add_error: {{ 'cart.toast.error' | t | json }},
      bundle_added: {{ 'cart.toast.bundle_added' | t | json }}
    };
  </script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

</body>
</html>
