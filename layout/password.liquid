<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Playfair+Display:wght@400&display=swap" rel="stylesheet">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <div class="password-page">
    <div class="password-content">
      <h1>{{ shop.name }}</h1>
      <p>Opening soon. Enter the password to preview the store.</p>
      {{ content_for_layout }}
    </div>
  </div>
</body>
</html>
